# apps/app — SlicedLabs member cockpit (app.slicedlabs.io). Copy to .env.local for dev.
# Real secrets live in Vercel env — never commit real values.

# Supabase — the publishable (anon) key is safe to ship. Without these set, the shared
# @slicedlabs/supabase package falls back to the correct public defaults, so dev works as-is.
NEXT_PUBLIC_SUPABASE_URL=https://zaskrhtcadamiutdecgu.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_5-pJNSReTfveXzk023-HsA_ZVyko0a2

# Cookie domain — set in PROD so the session is shared across app./shop./apex.
# Leave UNSET in dev (host-only cookie on localhost, secure=false over http).
SUPABASE_COOKIE_DOMAIN=

# Absolute origin used for the magic-link redirect target.
NEXT_PUBLIC_SITE_URL=https://app.slicedlabs.io
