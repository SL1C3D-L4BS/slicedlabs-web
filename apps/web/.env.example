# apps/web — SlicedLabs marketing site.
# Real secrets live in Vercel env / pass — NEVER commit real values. Copy to .env for local dev.

# ── beehiiv (owned list) — required for /api/lead + /api/subscribe ──
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=pub_fa6993a4-fd60-443d-9ef1-816f77aa3c05

# ── HubSpot CRM upsert (optional, best-effort) ──
HUBSPOT_TOKEN=

# ── Discord live inbox for inquiries (optional, best-effort) ──
DISCORD_WEBHOOK_URL=

# ── n8n funnel brain — Lead Intake → Enrich → Score → Route (optional) ──
# When set, /api/lead hands each lead to n8n: enrich + score + provision a Supabase
# account + deliver the perk via Resend + tag HubSpot. x-sl-secret authenticates the call.
N8N_LEAD_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=

# ── Supabase (SSR auth on /account/* — Phase 1). Publishable key is safe to ship. ──
PUBLIC_SUPABASE_URL=https://zaskrhtcadamiutdecgu.supabase.co
PUBLIC_SUPABASE_ANON_KEY=sb_publishable_5-pJNSReTfveXzk023-HsA_ZVyko0a2
# .slicedlabs.io in prod so the session is shared across app./shop.; leave blank in dev
SUPABASE_COOKIE_DOMAIN=
# server-only (NEVER prefix PUBLIC_): service-role for trusted writes (webhooks/n8n)
SUPABASE_SERVICE_ROLE_KEY=

# ── canonical site URL (flip to https://slicedlabs.io at go-live) ──
SITE_URL=https://slicedlabs-web.vercel.app

# ── Stripe — own-your-revenue checkout (Embedded Checkout). Test keys in sandbox. ──
# Publishable key is safe to ship to the browser.
PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Server-only (NEVER prefix PUBLIC_). Creates checkout sessions + prices.
STRIPE_SECRET_KEY=
# Signing secret for /api/webhooks/stripe (Stripe CLI `stripe listen` or dashboard endpoint).
STRIPE_WEBHOOK_SECRET=

# ── Printful — print-on-demand fulfillment (POST orders on paid; status webhooks back). ──
PRINTFUL_API_KEY=
# Optional shared secret to verify /api/webhooks/printful.
PRINTFUL_WEBHOOK_SECRET=
# Auto-confirm Printful orders post-payment (true = live-fulfill; default draft).
PRINTFUL_CONFIRM=

# ── Commerce tuning (optional) ──
# Flat shipping in cents (0 = free). Free automatically once an order clears the
# threshold below; digital-only carts skip shipping + the address form entirely.
SL_SHIPPING_FLAT_CENTS=
SL_FREE_SHIP_THRESHOLD_CENTS=
# Stripe automatic tax (true/false).
STRIPE_TAX_ENABLED=
# Recurring membership — Stripe recurring Price ids (price_…). Monthly required; annual
# optional. Each unset = that plan hidden; both unset = the /membership offer is dark.
STRIPE_MEMBERSHIP_PRICE_ID=
STRIPE_MEMBERSHIP_ANNUAL_PRICE_ID=

# ── Resend — transactional email (order + shipping confirmations). Env-gated. ──
RESEND_API_KEY=
RESEND_FROM="SlicedLabs <orders@slicedlabs.io>"

# ── /admin allowlist (comma-separated emails; Supabase-auth gated cockpit). ──
ADMIN_EMAILS=

# ── Cloudflare Turnstile — bot wall on /api/lead. Both empty = disabled. ──
# Public site key renders the widget; secret key verifies the token server-side.
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Mapbox public token — the live food-truck map on /truck. Empty = map hidden. ──
PUBLIC_MAPBOX_TOKEN=

# ── Clerk auth (sign-in). pk_test/sk_test = dev instance; use pk_live/sk_live in prod.
# Also configure Supabase → Authentication → Third-Party Auth → Clerk (the Clerk domain),
# so RLS trusts Clerk tokens (auth.jwt()->>'sub'). Rotate any secret shared in plaintext. ──
PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Clerk webhook (svix) signing secret — /api/webhooks/clerk mirrors users into profiles.
CLERK_WEBHOOK_SIGNING_SECRET=
