---
// SlicedLabs · studio · © 2026 SlicedLabs
import "../styles/global.css";
import Analytics from "@vercel/analytics/astro";
import { MARK_PATH, OG_PATH } from "../lib/brand";
import LeadForm from "../components/LeadForm.astro";
import SocialRow from "../components/SocialRow.astro";
import ShaderField from "../components/ShaderField.astro";
interface Props {
  title?: string;
  description?: string;
  temp?: "dark" | "warm";
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /** Override the OG image path (e.g. SSR pages with no per-route static card). */
  ogImage?: string;
}
const {
  title = "SlicedLabs — own your slice",
  description = "A food · media · marketing company building a real food empire in public. The future, sliced.",
  temp = "warm",
  noindex = false,
  jsonLd,
  ogImage,
} = Astro.props;
// Canonical = the trailing-slash-normalized URL on the live origin (Astro.site).
// One canonical per page keeps /kitchen vs /recipes overlap from splitting authority.
const _canonPath = Astro.url.pathname.replace(/\/+$/, "") || "/";
const canonicalUrl = Astro.site ? new URL(_canonPath, Astro.site).href : _canonPath;
const _op = (Astro.url.pathname.replace(/\/+$/, "") || "/");
const ogRoute = _op === "/" ? "index" : _op.replace(/^\//, "");
// OG image: an explicit override wins; noindex surfaces (e.g. /style) and SSR pages with
// no per-route static card fall back to the brand default; everything else uses its card.
const ogPath = ogImage ?? (noindex ? OG_PATH : `/og/${ogRoute}.png`);
const ogUrl = Astro.site ? new URL(ogPath, Astro.site).href : ogPath;
const path = (Astro.url.pathname.replace(/\/+$/, "") || "/");
const ic = {
  home: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M11.3 2.45a1 1 0 0 1 1.4 0l8.63 7.63A1 1 0 0 1 20.66 11.8H19.5V20a1 1 0 0 1-1 1H14.6v-5.6H9.4V21H5.5a1 1 0 0 1-1-1v-8.2H3.34A1 1 0 0 1 2.67 10.08l8.63-7.63Z"/></svg>`,
  build: `<svg viewBox="0 0 24 24" fill="currentColor"><rect x="3" y="3" width="8" height="8" rx="2.2"/><rect x="13" y="3" width="8" height="8" rx="2.2"/><rect x="3" y="13" width="8" height="8" rx="2.2"/><rect x="13" y="13" width="8" height="8" rx="2.2"/></svg>`,
  watch: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm-1.7 6.04 5.25 3.1a1 1 0 0 1 0 1.72l-5.25 3.1A1 1 0 0 1 8.8 15.1V8.9a1 1 0 0 1 1.5-.86Z"/></svg>`,
  manifesto: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M6 2a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6H6Zm7 1.6L18.4 9H14a1 1 0 0 1-1-1V3.6Z"/></svg>`,
  sun: `<svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="4.4"/><g stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 2.6v2.1M12 19.3v2.1M2.6 12h2.1M19.3 12h2.1M5.2 5.2l1.5 1.5M17.3 17.3l1.5 1.5M18.8 5.2l-1.5 1.5M6.7 17.3l-1.5 1.5"/></g></svg>`,
  moon: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M21.1 13.6A8.4 8.4 0 0 1 10.4 2.9.85.85 0 0 0 9.3 1.85 9.5 9.5 0 1 0 22.15 14.7.85.85 0 0 0 21.1 13.6Z"/></svg>`,
  truck: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M3 5.5A1.5 1.5 0 0 1 4.5 4h8A1.5 1.5 0 0 1 14 5.5V14H3V5.5Z"/><path d="M14 8h3.3a1 1 0 0 1 .8.4l2.7 3.6a1 1 0 0 1 .2.6V14h-7V8Z"/><circle cx="7" cy="17.5" r="2.3"/><circle cx="17" cy="17.5" r="2.3"/></svg>`,
  shop: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M6.5 7V6a5.5 5.5 0 0 1 11 0v1H20a1 1 0 0 1 1 1.07l-.72 11A2 2 0 0 1 18.28 22H5.72a2 2 0 0 1-2-1.93l-.72-11A1 1 0 0 1 4 7h2.5Zm2 0h7V6a3.5 3.5 0 0 0-7 0v1Z"/></svg>`,
  workshops: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M11.6 2.9a1.2 1.2 0 0 1 .8 0l9 3.2a.9.9 0 0 1 0 1.7l-9 3.2a1.2 1.2 0 0 1-.8 0l-9-3.2a.9.9 0 0 1 0-1.7l9-3.2Z"/><path d="M6 11.2v3.6C6 16.6 8.7 18 12 18s6-1.4 6-3.2v-3.6l-5.4 1.9a2 2 0 0 1-1.2 0L6 11.2Z"/></svg>`,
  menu: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M9 2h6a1 1 0 0 1 1 1v1h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2V3a1 1 0 0 1 1-1Zm1 2v1h4V4h-4Zm-2 6h8v2H8v-2Zm0 4h8v2H8v-2Z"/></svg>`,
  cart: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M7 4h-.6a1 1 0 0 0 0 2H7l1.6 9.6A2 2 0 0 0 10.57 17.3H18.5a1 1 0 0 0 0-2h-7.93l-.27-1.6h8.2a2 2 0 0 0 1.96-1.6l1.02-5.1A1 1 0 0 0 20.5 4H8.86l-.2-1.16A1 1 0 0 0 7.67 2H6a1 1 0 0 0 0 2h.83L7 4Z"/><circle cx="10.5" cy="20" r="1.5"/><circle cx="17.5" cy="20" r="1.5"/></svg>`,
};
// nav order = purpose → fun → sell: Home, then the why (Manifesto) + the receipts
// (The Build), then the show (Watch), then commerce (Truck, Shop) last.
const nav = [
  { href: "/", label: "Home", hue: "#38B6FF", icon: ic.home },
  { href: "/about", label: "Manifesto", hue: "#2F9B80", icon: ic.manifesto },
  { href: "/build", label: "The Build", hue: "#CB6820", icon: ic.build },
  { href: "/watch", label: "Watch", hue: "#D9583C", icon: ic.watch },
  { href: "/truck", label: "Truck", hue: "#3D9C6F", icon: ic.truck },
  { href: "/menu", label: "Menu", hue: "#D9583C", icon: ic.menu },
  { href: "/shop", label: "Shop", hue: "#6C7BE8", icon: ic.shop },
  { href: "/workshops", label: "Workshops", hue: "#C99A2E", icon: ic.workshops },
];
const isActive = (href: string) => (href === "/" ? path === "/" : path === href || path.startsWith(href + "/"));
---
<!doctype html>
<html lang="en" data-temp={temp}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogUrl} />
    <meta name="theme-color" content="#FBF6EE" />
    {/* SlicedLabs favicon & icon pack — operator-provided handoff (public/) */}
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title="SlicedLabs — The Build" href="/rss.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700;9..144,800&family=Geist+Mono:wght@300..800&family=Inter:wght@400..700&display=swap" rel="stylesheet" />
  </head>
  <body>
    {/* The living GPU backdrop — fixed behind everything (fills behind the floating header,
        appears on every page). Theme-aware + heavily gated; static gradient fallback. */}
    <ShaderField fixed />
    <div class="sl-vignette" aria-hidden="true"></div>
    <div class="sl-grain" aria-hidden="true"></div>
    <div class="sl-topblur" aria-hidden="true"><i></i><i></i><i></i><i></i></div>
    {/* Liquid-glass refraction filter — referenced by .glass backdrop-filter (Chromium,
        @supports-gated in global.css). Organic low-freq displacement = the backdrop lenses. */}
    <svg width="0" height="0" aria-hidden="true" style="position:absolute; pointer-events:none;">
      <filter id="sl-lens" x="-20%" y="-20%" width="140%" height="140%" color-interpolation-filters="sRGB">
        <feTurbulence type="fractalNoise" baseFrequency="0.006 0.010" numOctaves="2" seed="7" result="n" />
        <feGaussianBlur in="n" stdDeviation="1.1" result="nb" />
        <feDisplacementMap in="SourceGraphic" in2="nb" scale="15" xChannelSelector="R" yChannelSelector="G" />
      </filter>
    </svg>
    <div class="scroll-progress" aria-hidden="true"></div>
    <a href="#main" class="skip">Skip to content</a>
    <header class="pillbar-wrap">
      <div class="pillbar" data-pillbar>
        <a href="/" class="pb-brand" aria-label="SlicedLabs — home">
          <img src={MARK_PATH} alt="" width="24" height="24" />
          <span class="pb-word">SlicedLabs</span>
        </a>
        <span class="pb-sep"></span>
        <nav class="pb-nav" data-magnify aria-label="Primary">
          {nav.map((n) => (
            <a href={n.href} class:list={["pb-chip", isActive(n.href) && "is-active"]} style={`--hue:${n.hue}`} aria-current={isActive(n.href) ? "page" : undefined}>
              <span class="pb-ico" set:html={n.icon}></span>
              <span class="pb-label">{n.label}</span>
            </a>
          ))}
        </nav>
        <span class="pb-sep"></span>
        <a href="/cart" class="pb-chip pb-cart" aria-label="Cart" title="Cart" style="--hue:#6C7BE8;">
          <span class="pb-ico" set:html={ic.cart}></span>
          <span class="pb-cart-count" data-cart-count hidden aria-hidden="true">0</span>
        </a>
        <button id="temp" class="pb-chip pb-toggle" aria-label="Toggle light and dark" title="light ↔ dark">
          <span class="pb-ico" data-ico-moon set:html={ic.moon}></span>
          <span class="pb-ico" data-ico-sun set:html={ic.sun}></span>
        </button>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="wrap" style="border-top:1px solid var(--stroke); margin-top:4rem; padding-block:2rem; color:var(--muted);">
      <nav aria-label="Footer" style="display:flex; gap:1.2rem; flex-wrap:wrap; margin-bottom:1.1rem;">
        {[["/work","Work with us"],["/truck","Truck"],["/menu","Menu"],["/shop","Shop"],["/recipes","Recipes"],["/kitchen/tools","Food tools"],["/workshops","Workshops"],["/playbooks","Playbooks"],["/membership","Membership"],["/kitchen","Kitchen"],["/watch","Watch"],["/build","The Build"],["/numbers","The Numbers"],["/freshsave","FreshSave"],["/community","Community"],["/about","Manifesto"],["/contact","Contact"],["/free","Free Drops"],["/style","Design system"]].map(([h,l]) => (
          <a href={h} style="color:var(--muted); text-decoration:none; font-size:.9rem;">{l}</a>
        ))}
      </nav>
      <div style="display:flex; gap:1rem 1.4rem; flex-wrap:wrap; justify-content:space-between; align-items:center; margin-bottom:1.2rem;">
        <SocialRow />
        <span class="mono">one handle · @slicedlabs everywhere</span>
      </div>
      <nav aria-label="Legal" style="display:flex; gap:1rem; flex-wrap:wrap; margin-bottom:1rem;">
        {[["/privacy","Privacy"],["/terms","Terms"],["/refunds","Refunds"],["/shipping","Shipping"],["/accessibility","Accessibility"]].map(([h,l]) => (
          <a href={h} style="color:var(--muted); text-decoration:none; font-size:.82rem;">{l}</a>
        ))}
      </nav>
      <div style="display:flex; gap:1rem; flex-wrap:wrap; justify-content:space-between; align-items:center;">
        <span class="mono">own your slice · build it in public</span>
        <span class="mono">© 2026 SlicedLabs</span>
      </div>
    </footer>

    <dialog id="exit-gate" class="gate" aria-label="Free drops from SlicedLabs">
      <div class="gate-inner">
        <button class="gate-x" aria-label="Close" data-gate-close>✕</button>
        <p class="mono">before you go</p>
        <h2 class="blend-text t-h3" style="font-family:var(--font-display); font-weight:800; line-height:1.05; margin:.2rem 0 .5rem;">Take the receipts.</h2>
        <p style="color:var(--muted); margin:0 auto 1.1rem; max-width:26rem;">The real $85k truck budget, the Atomise Machine, and the running build numbers — free. We mail them and get out of your way.</p>
        <LeadForm source="vault" anchor="" cta="Send me the drops →" />
        <button class="gate-skip" data-gate-close>No thanks, I'll keep browsing</button>
      </div>
    </dialog>

    <Analytics />

    <script is:inline>
      // dark ↔ warm temperature (the two-temperature system). Persists; respects no-shimmer.
      const root = document.documentElement;
      const readCookie = () => (document.cookie.match(/(?:^|;\s*)sl-temp=(warm|dark)/) || [])[1];
      const saved = readCookie() || localStorage.getItem("sl-temp");
      if (saved === "warm" || saved === "dark") root.setAttribute("data-temp", saved);
      // persist to BOTH localStorage and an apex-scoped cookie so the app. / shop.
      // subdomains (which SSR-read the cookie) stay continuous with the marketing site.
      const persistTemp = (next) => {
        try { localStorage.setItem("sl-temp", next); } catch (e) {}
        const domain = location.hostname.endsWith("slicedlabs.io") ? "; domain=.slicedlabs.io" : "";
        const secure = location.protocol === "https:" ? "; secure" : "";
        document.cookie = "sl-temp=" + next + "; path=/; max-age=31536000; samesite=lax" + domain + secure;
      };
      document.getElementById("temp")?.addEventListener("click", () => {
        const next = root.getAttribute("data-temp") === "warm" ? "dark" : "warm";
        root.setAttribute("data-temp", next);
        persistTemp(next);
      });
    </script>

    <script is:inline>
      // Dock-style magnification on the pill nav (web flourish over the cockpit chips).
      (function () {
        var nav = document.querySelector("[data-magnify]");
        if (!nav) return;
        if (!matchMedia("(hover:hover) and (pointer:fine)").matches) return;
        if (matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        var chips = Array.prototype.slice.call(nav.querySelectorAll(".pb-chip"));
        var AMP = 0.55, SPREAD = 64;
        nav.addEventListener("pointermove", function (e) {
          for (var i = 0; i < chips.length; i++) {
            var r = chips[i].getBoundingClientRect();
            var d = e.clientX - (r.left + r.width / 2);
            chips[i].style.setProperty("--mag", (1 + AMP * Math.exp(-(d * d) / (2 * SPREAD * SPREAD))).toFixed(3));
          }
        });
        nav.addEventListener("pointerleave", function () {
          for (var i = 0; i < chips.length; i++) chips[i].style.setProperty("--mag", "1");
        });
      })();
    </script>

    <script is:inline>
      // Lead-capture status — shows the result after the /api/lead redirect (?lead=&src=).
      (function () {
        var p = new URLSearchParams(location.search);
        var st = p.get("lead"); if (!st) return;
        var src = p.get("src") || "";
        var el = document.querySelector('[data-lead-status][data-src="' + src + '"]') || document.querySelector("[data-lead-status]");
        var msg = {
          success: "You're in — check your inbox to confirm. The receipts are coming.",
          invalid: "That email didn't look right. Mind trying again?",
          error: "Something hiccupped on our end. Try again in a moment.",
        }[st];
        if (el && msg) {
          el.textContent = msg;
          el.style.color = st === "success" ? "var(--ink)" : "var(--muted)";
          el.hidden = false;
          el.scrollIntoView({ block: "center", behavior: "smooth" });
        }
        // conversion event (owned analytics) — measure signups by source
        if (st === "success") { try { window.va && window.va("event", { name: "signup", data: { source: src } }); } catch (e) {} }
        history.replaceState({}, "", location.pathname + location.hash);
      })();
    </script>

    <script is:inline>
      // Lead forms → AJAX submit (no reload, inline confirm; graceful no-JS fallback)
      // + the exit-intent value-exchange gate (dismissible, shown once per visitor).
      (function () {
        document.querySelectorAll('form[action="/api/lead"]').forEach(function (form) {
          form.addEventListener("submit", function (e) {
            if (!window.fetch) return; // no JS / old browser → normal redirect submit
            e.preventDefault();
            var s = form.querySelector("[data-lead-status]");
            var btn = form.querySelector("button[type=submit]");
            if (btn) btn.disabled = true;
            fetch("/api/lead", { method: "POST", body: new FormData(form), headers: { accept: "application/json" } })
              .then(function (r) { return r.json().catch(function () { return { ok: false }; }); })
              .then(function (j) {
                if (s) { s.textContent = j.ok ? "You're in — check your inbox to confirm. The receipts are coming." : "Something hiccupped — try again in a moment."; s.style.color = j.ok ? "var(--ink)" : "var(--muted)"; s.hidden = false; }
                if (j.ok) { form.reset(); try { var srcEl = form.querySelector("[name=source]"); window.va && window.va("event", { name: "signup", data: { source: srcEl ? srcEl.value : "" } }); } catch (e) {} }
                if (btn) btn.disabled = false;
              })
              .catch(function () { if (s) { s.textContent = "Something hiccupped — try again."; s.hidden = false; } if (btn) btn.disabled = false; });
          });
        });
        var d = document.getElementById("exit-gate");
        if (d) {
          var KEY = "sl-gate-v1";
          var open = function () { if (localStorage.getItem(KEY)) return; try { d.showModal(); } catch (e) {} localStorage.setItem(KEY, "1"); };
          document.addEventListener("mouseout", function (e) { if (!e.relatedTarget && e.clientY <= 0) open(); });
          setTimeout(function () { if (window.scrollY > 700) open(); }, 45000);
          d.querySelectorAll("[data-gate-close]").forEach(function (b) { b.addEventListener("click", function () { d.close(); }); });
          d.addEventListener("click", function (e) { if (e.target === d) d.close(); });
          d.addEventListener("submit", function () { setTimeout(function () { try { d.close(); } catch (e) {} }, 2400); });
        }
      })();
    </script>

    <script is:inline>
      // Entrance choreography — plays ONCE per element, reduced-motion gated.
      // Drives [data-reveal] fades, the .blade slice, and [data-count-to] count-ups.
      (function () {
        var reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
        var targets = document.querySelectorAll("[data-reveal], .blade, [data-count-to]");
        function fmt(el, v) {
          var dp = +(el.getAttribute("data-count-decimals") || 0);
          var pre = el.getAttribute("data-count-prefix") || "";
          var suf = el.getAttribute("data-count-suffix") || "";
          return pre + v.toLocaleString("en-US", { minimumFractionDigits: dp, maximumFractionDigits: dp }) + suf;
        }
        function run(el) {
          var to = +el.getAttribute("data-count-to");
          var dur = +(el.getAttribute("data-count-dur") || 1500);
          var t0 = null;
          (function step(ts) {
            if (!t0) t0 = ts;
            var p = Math.min((ts - t0) / dur, 1);
            var e = 1 - Math.pow(1 - p, 3); // easeOutCubic
            el.textContent = fmt(el, to * e);
            if (p < 1) requestAnimationFrame(step); else el.textContent = fmt(el, to);
          })(performance.now());
        }
        if (reduce) {
          targets.forEach(function (el) {
            el.classList.add("is-in");
            if (el.hasAttribute("data-count-to")) el.textContent = fmt(el, +el.getAttribute("data-count-to"));
          });
          return;
        }
        // pre-zero the counters so the count-up reads from 0 → target
        targets.forEach(function (el) { if (el.hasAttribute("data-count-to")) el.textContent = fmt(el, 0); });
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (en) {
            if (!en.isIntersecting) return;
            en.target.classList.add("is-in");
            if (en.target.hasAttribute("data-count-to")) run(en.target);
            io.unobserve(en.target);
          });
        }, { threshold: 0.2, rootMargin: "0px 0px -8% 0px" });
        targets.forEach(function (el) { io.observe(el); });
      })();
    </script>

    <script is:inline>
      // Liquid Glass++ specular + magnetic buttons. ONE rAF-throttled pointer handler,
      // mouse-only, fine-pointer-only, NEVER under reduced-motion (input-driven, no loop).
      (function () {
        if (matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        if (!matchMedia("(hover:hover) and (pointer:fine)").matches) return;
        var px = 0, py = 0, raf = 0, lastBtn = null;
        function apply() {
          raf = 0;
          var el = document.elementFromPoint(px, py);
          if (!el || !el.closest) return;
          var glass = el.closest(".glass");
          if (glass) {
            var gr = glass.getBoundingClientRect();
            glass.style.setProperty("--mx", ((px - gr.left) / gr.width).toFixed(3));
            glass.style.setProperty("--my", ((py - gr.top) / gr.height).toFixed(3));
          }
          var btn = el.closest(".btn");
          if (btn) {
            var br = btn.getBoundingClientRect();
            var dx = (px - (br.left + br.width / 2)) / (br.width / 2 || 1);
            var dy = (py - (br.top + br.height / 2)) / (br.height / 2 || 1);
            btn.style.setProperty("--mbx", (dx * 6).toFixed(2) + "px");
            btn.style.setProperty("--mby", (dy * 6 - 1).toFixed(2) + "px");
            lastBtn = btn;
          } else if (lastBtn) {
            lastBtn.style.setProperty("--mbx", "0px");
            lastBtn.style.setProperty("--mby", "0px");
            lastBtn = null;
          }
        }
        addEventListener("pointermove", function (e) {
          if (e.pointerType !== "mouse") return;
          px = e.clientX; py = e.clientY;
          if (!raf) raf = requestAnimationFrame(apply);
        }, { passive: true });
      })();
    </script>

    <script>
      // Lenis inertial smooth-scroll — the unified scroll heartbeat. Gated off under
      // reduced-motion (native scroll). Feeds normalized scroll velocity to the GPU field
      // (scroll-reactive: crisp when still, liquid when moving) + a --scroll-vel CSS var.
      import Lenis from "lenis";
      import { shouldRunHeavyFx } from "../lib/clientCaps";
      if (shouldRunHeavyFx()) {
        const lenis = new Lenis({ lerp: 0.1, smoothWheel: true });
        lenis.on("scroll", (e: { velocity: number }) => {
          const v = Math.min(Math.abs(e.velocity) / 40, 1);
          (window as unknown as { __slVel?: number }).__slVel = v;
          document.documentElement.style.setProperty("--scroll-vel", v.toFixed(3));
        });
        const raf = (t: number) => { lenis.raf(t); requestAnimationFrame(raf); };
        requestAnimationFrame(raf);
        // smooth in-page anchor jumps (e.g. /work #inquire)
        document.addEventListener("click", (e) => {
          const a = (e.target as HTMLElement)?.closest?.('a[href^="#"]') as HTMLAnchorElement | null;
          if (!a) return;
          const href = a.getAttribute("href") || "";
          const el = href.length > 1 ? document.getElementById(href.slice(1)) : null;
          if (el) { e.preventDefault(); lenis.scrollTo(el, { offset: -72 }); }
        });
      }
    </script>

    <script>
      // Behavior-based personalization (local, no LLM/network): record this route's affinity
      // so the home "where to next" row can lead with the visitor's interest on return.
      import { recordVisit } from "../scripts/affinity";
      recordVisit();
    </script>

    <script>
      // Nav cart-count badge — reads the localStorage cart on load + listens for changes
      // (cart.ts dispatches `sl-cart-change` on every add/setQty/clear). One-shot pop, no loop.
      import { count } from "../scripts/cart";
      const badge = document.querySelector("[data-cart-count]") as HTMLElement | null;
      function render(n: number) {
        if (!badge) return;
        badge.textContent = String(n);
        badge.hidden = n <= 0;
        if (n > 0) {
          badge.classList.remove("pop");
          void badge.offsetWidth; // reflow → re-trigger the pop
          badge.classList.add("pop");
        }
      }
      render(count());
      document.addEventListener("sl-cart-change", (e) => {
        const n = (e as CustomEvent<{ count: number }>).detail?.count ?? count();
        render(n);
      });
      // keep continuous across cross-document View Transitions (badge re-reads on pageshow)
      window.addEventListener("pageshow", () => render(count()));
    </script>

    {/* Speculation Rules — prerender same-origin pages on hover/pointerdown so the card→detail
        View-Transition morph fires instantly. Chromium-only; graceful no-op elsewhere. */}
    <script type="speculationrules" is:inline set:html={JSON.stringify({
      prerender: [{
        where: { and: [
          { href_matches: "/*" },
          { not: { href_matches: "/api/*" } },
          { not: { href_matches: "/admin/*" } },
          { not: { href_matches: "/account/*" } },
          { not: { href_matches: "/auth/*" } },
          { not: { href_matches: "/checkout*" } },
          { not: { href_matches: "/cart*" } },
        ] },
        eagerness: "moderate",
      }],
    })} />
  </body>
</html>
