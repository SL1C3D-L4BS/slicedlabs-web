---
// HeroPass.astro — "THE PASS, EXPLODED": a scattered field of food-photo tiles.
//
// A crisp centred lockup (eyebrow · mark · "The future, sliced." · promise · CTAs · blade)
// sits in a protected SAFE LANE while a scatter of photo tiles "explodes" all over the
// frame in real CSS Z-depth — denser near the gutters, deep + faint behind the headline.
// Several tiles carry honest sourcing tags (local · in season · Spokane …); two double as
// the real shop / numbers links so the affordances survive. Pointer parallax drifts the field.
//
// BLANK-LIKE-THE-SHOP-MERCH (operator's call): every tile uses the SAME blank treatment as
// the shop's coming-soon merch (`.ghost-media` in shop.astro) — a branded bloom panel with
// a faint masked chevron-mark watermark, NO "coming soon" text. ZERO stock, CLS 0. Each
// tile is a full-bleed image slot: drop a real photo with ONE property —
//   style="--photo:url('/food/x.webp')"  → the photo covers the blank panel (.ntile-img::after).
// When a tile gets a real photo, give that <figure> role="img" + an aria-label describing the
// dish and drop aria-hidden — a bare `alt` is a no-op on <figure>/<span> and the image is a CSS
// background, so role+label is how AT gets it; or keep it decorative with aria-hidden. The
// watermark sits UNDER the photo so the swap is clean.
//
// Reuses verbatim: the operator mark (/slicedlabs-mark.svg — NEVER redrawn, here as a mask),
// the token hues, .btn/.btn-ghost, .kinetic/.blend-text.spectrum, .blade, and Base.astro's
// [data-reveal] IntersectionObserver (reveal + .blade slice). Tiles are FLAT bloom panels
// (no backdrop-blur) so a dense field stays cheap — only the lockup is heavy.
//
// A11y: the lockup is the FIRST child (CTAs lead tab order; painted on top via z-index). All
// blank tiles + sourcing tags are decorative → aria-hidden; the two link
// tiles are real <a> with aria-labels and keyboard-reachable. CLS 0 (every tile reserved via
// width + aspect-ratio). Parallax is input-driven (no idle loop), mouse-only, rAF
// self-cancels, NEVER attached under reduced-motion. LCP = the server-rendered lockup.

// Tiles: pos = inset anchors (edge-gutters + a deep inner cloud that stays behind the
// lockup); d = depth 1(deep)..3(near); rot baked into every transform state; tier = the
// responsive shed (core ≥520 · mid ≥760 · extra ≥1080). Two carry href → real links.
const tiles = [
  // ── corners (f-core: present from tablet up; includes both real links) ──
  { pos: "top:4%;left:1%",     w: "11rem",  ar: "4 / 3", d: 3, rot: -4, i: 11, tier: "f-core",  tag: "local" },
  { pos: "top:5%;right:1%",    w: "12rem",  ar: "4 / 3", d: 3, rot:  4, i: 11, tier: "f-core",  tag: "Spokane" },
  { pos: "bottom:5%;left:1%",  w: "12rem",  ar: "4 / 3", d: 2, rot:  2, i: 9,  tier: "f-core",  tag: "shop →",        href: "/shop",    label: "Visit the shop" },
  { pos: "bottom:4%;right:1%", w: "11rem",  ar: "4 / 3", d: 2, rot: -4, i: 9,  tier: "f-core",  tag: "the numbers →", href: "/numbers", label: "See the numbers" },
  // ── mid gutters (f-mid) ──
  { pos: "top:31%;left:0",     w: "8rem",   ar: "1 / 1", d: 2, rot:  3, i: 8,  tier: "f-mid",   tag: "in season" },
  { pos: "top:34%;right:0",    w: "8.5rem", ar: "1 / 1", d: 2, rot: -3, i: 8,  tier: "f-mid" },
  // ── outer extras (f-extra: the full explosion ≥1080) ──
  { pos: "top:55%;left:2.5%",  w: "9.5rem", ar: "3 / 4", d: 3, rot: -3, i: 12, tier: "f-extra", tag: "from scratch" },
  { pos: "top:57%;right:3.5%", w: "9rem",   ar: "3 / 4", d: 3, rot:  3, i: 12, tier: "f-extra", tag: "wood-fired" },
  // ── deep inner cloud (faint, behind the lockup edges — never the dead centre) ──
  { pos: "top:8%;left:27%",    w: "6.5rem", ar: "1 / 1", d: 1, rot:  5, i: 6,  tier: "f-extra" },
  { pos: "top:11%;right:28%",  w: "6rem",   ar: "4 / 3", d: 1, rot: -5, i: 6,  tier: "f-extra" },
  { pos: "bottom:11%;left:31%",w: "6rem",   ar: "1 / 1", d: 1, rot:  4, i: 7,  tier: "f-extra" },
  { pos: "bottom:12%;right:30%",w:"6.5rem", ar: "3 / 4", d: 1, rot: -4, i: 7,  tier: "f-extra", tag: "on the pass" },
  // ── denser fill (f-extra ≥1080): extra gutter rungs + deep-cloud tiles weaving the net.
  //    Gutter rungs hug the edges; near-centre tiles stay deep(d1)+faint at the extreme
  //    top/bottom rows (above the eyebrow / below the blade), never the dead centre band. ──
  { pos: "top:17%;left:1%",     w: "6rem",   ar: "4 / 3", d: 1, rot:  6, i: 7,  tier: "f-extra" },
  { pos: "top:43%;left:0",      w: "7rem",   ar: "1 / 1", d: 2, rot: -4, i: 8,  tier: "f-extra", tag: "prep" },
  { pos: "bottom:27%;left:0.5%",w: "5.5rem", ar: "1 / 1", d: 1, rot:  5, i: 7,  tier: "f-extra" },
  { pos: "top:18%;right:1%",    w: "6rem",   ar: "3 / 4", d: 1, rot: -6, i: 7,  tier: "f-extra" },
  { pos: "top:45%;right:0",     w: "7rem",   ar: "1 / 1", d: 2, rot:  4, i: 8,  tier: "f-extra", tag: "plated" },
  { pos: "bottom:28%;right:0.5%",w:"5.5rem", ar: "4 / 3", d: 1, rot: -5, i: 7,  tier: "f-extra" },
  { pos: "top:3%;left:35%",     w: "5rem",   ar: "1 / 1", d: 1, rot:  7, i: 6,  tier: "f-extra" },
  { pos: "bottom:3%;right:36%", w: "5rem",   ar: "4 / 3", d: 1, rot: -7, i: 6,  tier: "f-extra", tag: "seasonal" },
];
const tstyle = (t: (typeof tiles)[number]) => `${t.pos}; --w:${t.w}; --ar:${t.ar}; --rot:${t.rot}deg; --i:${t.i};`;
---
<section class="pass" aria-label="SlicedLabs — the future, sliced. A food empire built in public.">
  <div class="pass-stage" data-pass-stage>
    <!-- ── focal lockup. FIRST in source (CTAs lead the tab order); painted on top via
            z-index regardless of DOM position. The LCP. ── -->
    <div class="pass-lockup" data-depth="4">
      <p class="mono" data-reveal style="--i:0;">food · media · marketing — built in public</p>

      <img
        src="/slicedlabs-mark.svg"
        alt="SlicedLabs"
        width="92"
        height="92"
        fetchpriority="high"
        decoding="async"
        class="pass-mark"
        data-reveal
        style="--i:1;"
      />

      <!-- two-line weight-led kinetic headline with a clip-window mask-wipe. Pure
           transform/clip — no CLS, no deps. Line 1 in --ink wipes up; line 2 keeps the
           single deliberate spectrum payoff word and resolves as the .blade sweeps. -->
      <h1 class="kinetic pass-head" data-reveal style="--i:2;">
        <span class="pass-line"><span class="pass-line-in">The future,</span></span>
        <span class="pass-line"><span class="pass-line-in blend-text spectrum">sliced.</span></span>
      </h1>

      <p class="pass-sub" data-reveal style="--i:3;">
        We don't just show the machine — we slice it into pieces. A food empire, engineered in public, every number shown.
      </p>

      <div class="pass-cta" data-reveal style="--i:4;">
        <a class="btn" href="/watch">Watch the build →</a>
        <a class="btn btn-ghost" href="/build">Read the receipts</a>
      </div>

      <hr class="blade center" data-reveal style="--i:5; max-width:42rem; margin:2.4rem auto 0;" />
    </div>

    <!-- ambient: deep bloom field (z0) + the warm heat-lamp wash over the pass -->
    <div class="pass-field" data-depth="0" aria-hidden="true"></div>
    <div class="pass-lamp" aria-hidden="true"></div>

    <!-- ── the exploded photo tiles — blank shop-merch panels, swap-ready for full images ── -->
    {tiles.map((t) => (
      t.href ? (
        <a class:list={["pass-float", "ntile", t.tier]} href={t.href} aria-label={t.label}
           data-depth={t.d} data-reveal style={tstyle(t)}>
          <span class="ntile-img"></span>
          <span class="ntile-tag ntile-tag-link mono">{t.tag}</span>
        </a>
      ) : (
        <figure class:list={["pass-float", "ntile", t.tier]} aria-hidden="true"
           data-depth={t.d} data-reveal style={tstyle(t)}>
          <span class="ntile-img"></span>
          {t.tag && <span class="ntile-tag mono">{t.tag}</span>}
        </figure>
      )
    ))}
  </div>
</section>

<style>
  /* ── the camera + reserved frame (no CLS: fixed min-height, transforms only) ── */
  .pass {
    position: relative;
    min-height: clamp(38rem, 88vh, 52rem);
    display: grid;
    place-items: center;
    padding-block: clamp(2rem, 6vw, 4rem);
    overflow: clip;
  }
  .pass-stage {
    position: relative;
    width: min(var(--maxw), 100%);
    height: 100%;
    min-height: inherit;
    perspective: 1400px;
    transform-style: preserve-3d;
  }
  .pass-field,
  .pass-float,
  .pass-lockup { position: absolute; }

  /* ── z4 focal lockup — always crisp, always on top (z-index, not DOM order) ── */
  .pass-lockup {
    inset: 0;
    display: grid;
    align-content: center;
    justify-items: center;
    text-align: center;
    z-index: 5;
    transform: translateZ(0);
    padding-inline: 1rem;
    pointer-events: none;                 /* let parallax own the field; re-enable interactives below */
  }
  .pass-lockup a,
  .pass-lockup .pass-cta { pointer-events: auto; }
  /* the SAFE LANE scrim — a theme-aware radial behind the text so the dense field never
     drops the headline's contrast (darkens on dark, lifts on cream). Stronger than before
     because there are more tiles behind it. */
  .pass-lockup::before {
    content: ""; position: absolute; inset: 0; z-index: -1; pointer-events: none;
    background: radial-gradient(62% 56% at 50% 50%, color-mix(in oklab, var(--bg) 66%, transparent), transparent 76%);
  }

  .pass-mark {
    display: block;
    margin: 0 auto 1.2rem;
    filter: drop-shadow(0 10px 34px color-mix(in oklab, var(--mark) 32%, transparent));
  }
  .pass-sub {
    font-size: clamp(1.05rem, 2.3vw, 1.45rem);
    color: var(--muted);
    max-width: 44rem;
    margin: 1.3rem auto 0;
  }
  .pass-cta { display: flex; gap: .8rem; justify-content: center; flex-wrap: wrap; margin-top: 1.9rem; }

  /* ── kinetic headline: clip-window mask-wipe, two weight-led lines ── */
  .pass-head { margin: 0; }
  .pass-line { display: block; overflow: clip; padding-block: .02em; }   /* the clip window */
  .pass-line-in {
    display: inline-block;
    transform: translateY(110%);                                          /* hidden below the window */
    transition: transform var(--t-slow) var(--ease);
  }
  .pass-head[data-reveal].is-in .pass-line:nth-child(1) .pass-line-in { transition-delay: 60ms; transform: translateY(0); }
  .pass-head[data-reveal].is-in .pass-line:nth-child(2) .pass-line-in { transition-delay: 220ms; transform: translateY(0); }
  /* the headline element rides [data-reveal] for the opacity beat; kill its default
     translate so only the inner clip-wipe moves (no double motion) */
  .pass-head[data-reveal] { --reveal-rise: 0px; --reveal-scale: 1; }

  /* ── the floats — shared depth + entrance behaviour ─────────────────────────
     z-order by depth so nearer tiles sit over deeper ones; the lockup (z5) always wins. */
  .pass-float { z-index: 2; }
  .pass-float[data-depth="1"] { z-index: 1; }
  .pass-float[data-depth="3"] { z-index: 3; }

  /* ── exploded photo tiles — blank, branded, swap-ready (the shop ghost-media recipe) ── */
  .ntile {
    width: var(--w);
    border: 0; padding: 0; background: none; cursor: inherit;
    text-decoration: none; color: inherit;
    filter: drop-shadow(0 14px 30px rgba(0,0,0,.30));
  }
  a.ntile { cursor: pointer; }
  .ntile-img {
    position: relative; display: block; width: 100%; aspect-ratio: var(--ar, 4 / 3);
    border-radius: var(--radius); border: 1px solid var(--stroke); overflow: hidden;
    background:
      radial-gradient(60% 60% at 30% 20%, color-mix(in oklab, var(--coral) 14%, transparent), transparent 70%),
      radial-gradient(70% 70% at 80% 90%, color-mix(in oklab, var(--blue)  14%, transparent), transparent 70%),
      var(--bg-alt);
    box-shadow: inset 0 1px 0 var(--rim);
  }
  /* faint masked chevron-mark watermark — sits UNDER the photo so the --photo swap is clean */
  .ntile-img::before {
    content: ""; position: absolute; inset: 0; pointer-events: none;
    -webkit-mask: url("/slicedlabs-mark.svg") center / 34% no-repeat;
    mask: url("/slicedlabs-mark.svg") center / 34% no-repeat;
    background: var(--blend); opacity: .3;
  }
  /* the full-image slot — real photo paints over the blank panel with one --photo prop */
  .ntile-img::after {
    content: ""; position: absolute; inset: 0; border-radius: inherit; pointer-events: none;
    background-image: var(--photo, none); background-size: cover; background-position: center;
  }
  a.ntile:hover .ntile-img { border-color: color-mix(in oklab, var(--mark) 42%, var(--stroke)); }

  /* sourcing / nav tags */
  .ntile-tag {
    position: absolute; left: .45rem; bottom: .45rem; z-index: 2;
    font-size: .56rem; letter-spacing: .08em; text-transform: uppercase;
    padding: .16rem .44rem; border-radius: 999px;
    background: color-mix(in oklab, var(--bg-alt) 86%, transparent);
    border: 1px solid var(--stroke); color: var(--muted-strong);
  }
  /* link labels read --muted-strong (AA on both temperatures — raw --mark fails on cream);
     the brand-blue accent lives on the border + the hover lift instead. */
  .ntile-tag-link { color: var(--muted-strong); font-weight: 600; font-size: .72rem; letter-spacing: .04em; text-transform: none; border-color: color-mix(in oklab, var(--mark) 45%, var(--stroke)); }
  a.ntile:hover .ntile-tag-link { color: var(--ink); background: color-mix(in oklab, var(--mark) 14%, var(--bg-alt)); }

  /* the field — a faint brand-bloom veil pushed deep; lenses through the tiles */
  .pass-field {
    inset: -10%;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(40rem 30rem at 72% 6%,  color-mix(in oklab, var(--blue)  14%, transparent), transparent 60%),
      radial-gradient(36rem 28rem at 16% 84%, color-mix(in oklab, var(--coral) 12%, transparent), transparent 60%);
    transform: translateZ(-320px) scale(1.34);
  }
  /* the warm heat-lamp wash pooling from top-centre (no data-depth → excluded from parallax) */
  .pass-lamp {
    left: 50%; top: -6%; width: min(72%, 42rem); height: 46%;
    transform: translateX(-50%);
    background: radial-gradient(50% 72% at 50% 0%, color-mix(in oklab, var(--brass) 26%, transparent), transparent 70%);
    filter: blur(8px); pointer-events: none; z-index: 0;
  }
  [data-temp="warm"] .pass-lamp { background: radial-gradient(50% 72% at 50% 0%, color-mix(in oklab, var(--orange) 20%, transparent), transparent 70%); }

  /* ── entrance "pass": extend [data-reveal] with a Z-arrival on the floats ──
     The .is-in toggle is added by Base.astro's observer. Each tile keeps its baked --rot
     through every state (entrance / rest / parallax / reduced-motion) so rotation never
     fights the JS transform. Deep tiles arrive first → the web assembles toward the camera. */
  .pass-float[data-reveal] {
    --rest-z: 0px; --rot: 0deg;
    transform: translateZ(-600px) translateY(26px) rotate(var(--rot));
    opacity: 0;
    transition: transform var(--t-slow) var(--ease), opacity var(--t-slow) var(--ease);
    transition-delay: calc(var(--i) * 55ms);
    /* no persistent will-change — the entrance is one-shot + parallax rAF self-cancels when
       idle; a standing compositor layer per tile is the cost the substrate policy avoids. */
  }
  .pass-float[data-depth="1"][data-reveal] { --rest-z: -180px; }
  .pass-float[data-depth="2"][data-reveal] { --rest-z:  -90px; }
  .pass-float[data-depth="3"][data-reveal] { --rest-z:  -30px; }
  .pass-float[data-reveal].is-in { transform: translateZ(var(--rest-z)) rotate(var(--rot)); opacity: 1; }
  .pass-float[data-depth="1"][data-reveal].is-in { opacity: .55; }   /* deep cloud reads whispery */
  .pass-float[data-depth="2"][data-reveal].is-in { opacity: .96; }

  /* ── responsive — progressively shed tiles so the lockup always owns the frame ──
     ≥1080: all 20 · 1025–1080: drop f-extra → 4 corners + 2 mid ·
     761–1024: drop f-mid → 4 corner tiles (incl. both links) · 641–760: same, shrunk ·
     <640: lockup only. (f-mid sheds at ≤1024 so the mid tiles only show where the side gutters
     clearly clear the 44rem text column; f-core sheds at ≤640 so the corner panels never crowd
     the centred eyebrow/headline on short, narrow viewports.) */
  @media (max-width: 1080px) { .f-extra { display: none; } }
  @media (max-width: 1024px) { .f-mid   { display: none; } }
  @media (max-width: 760px)  { .ntile   { width: min(var(--w), 8.5rem); } }
  @media (max-width: 640px)  { .f-core  { display: none; } }

  /* ── reduced-motion: no entrance pass, no wipe — resting scene, full + crisp ──
     (global block forces [data-reveal].is-in + .blade full; we add the resting-Z + baked
      rotation, the deep-tile opacities, and pin the headline lines open.) */
  @media (prefers-reduced-motion: reduce) {
    .pass-float[data-reveal] { transform: translateZ(var(--rest-z)) rotate(var(--rot)) !important; opacity: 1 !important; }
    .pass-float[data-depth="1"][data-reveal] { opacity: .55 !important; }
    .pass-float[data-depth="2"][data-reveal] { opacity: .96 !important; }
    .pass-line-in { transform: none !important; }
  }

  /* ── reduced-transparency: kill the ambient washes; tiles are already flat opaque panels,
        tags lose their translucency to stay legible. */
  @media (prefers-reduced-transparency: reduce) {
    .pass-field, .pass-lamp { display: none; }
    .ntile-tag { background: var(--bg-alt); }
  }
</style>

<script is:inline>
  // THE PASS — pointer parallax. Input-driven (NOT a perpetual loop → satisfies the
  // no-shimmer law), mouse-only (touch/coarse stays static), rAF self-cancels when settled,
  // and is NEVER attached under reduced-motion. The entrance reveal + the .blade sweep are
  // driven by Base.astro's observer — unchanged. Each tile's baked --rot is composed into
  // the transform so rotation survives the parallax write.
  (function () {
    if (matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    var stage = document.querySelector("[data-pass-stage]");
    if (!stage) return;

    // gain per depth plane (0..4): deeper planes move LESS (correct parallax). The focal
    // lockup (.pass-lockup, depth 4) is EXCLUDED so the LCP text stays crisp + legible.
    var GAIN = [0.18, 0.34, 0.55, 0.78, 1.0];
    var ZMAP = { "0": -320, "1": -180, "2": -90, "3": -30, "4": 0 };   // matches CSS --rest-z
    var planes = [].map.call(stage.querySelectorAll("[data-depth]:not(.pass-lockup)"), function (el) {
      var d = +el.dataset.depth;
      var rot = parseFloat(getComputedStyle(el).getPropertyValue("--rot")) || 0;   // read once, baked rotation
      return { el: el, gain: GAIN[d] != null ? GAIN[d] : 0.5, z: ZMAP[el.dataset.depth] || 0, rot: rot };
    });

    // Hold parallax until the one-shot entrance has fully landed (slowest tile = max --i 12
    // → 12*55ms + --t-slow ≈ 1120ms), measured from first paint. Writing an inline transform
    // mid-entrance would retarget the in-flight transition; once we take over we STRIP the
    // entrance transition so the per-frame lerp drives motion directly (otherwise every
    // parallax frame inherits the ease + delay = sluggish).
    // Parallax may begin only after the one-shot entrance has landed. Derive the wait from the
    // live --t-slow token + the stagger cadence so a tokens.toml bump can't desync it (max --i
    // in the tiles array is 12). The leading rAF just defers the timer past first paint;
    // parallax itself only fires on pointermove, which requires a focused tab.
    var ready = false;
    var tSlow = parseFloat(getComputedStyle(document.documentElement).getPropertyValue("--t-slow")) || 460;
    var gate = 12 * 55 + tSlow + 180;   // slowest tile's entrance end + buffer
    requestAnimationFrame(function () { setTimeout(function () { ready = true; }, gate); });

    var tx = 0, ty = 0, cx = 0, cy = 0, raf = 0;
    function tick() {
      cx += (tx - cx) * 0.08;
      cy += (ty - cy) * 0.08;
      for (var i = 0; i < planes.length; i++) {
        var p = planes[i], el = p.el;
        // never drive a reveal tile that hasn't entered yet — let its CSS entrance play first
        // (covers a scrolled-past / bfcache load where .is-in lands late, so it never pops).
        if (el.hasAttribute("data-reveal") && !el.classList.contains("is-in")) continue;
        // hand each tile off from the CSS entrance tween to the lerp on its first parallax write
        if (!p.stripped) { el.style.transition = "none"; p.stripped = true; }
        var sx = (el.dataset.depth === "0") ? 1.34 : 1;     // keep the field's scale
        el.style.transform =
          "translate3d(" + (cx * p.gain * 18).toFixed(2) + "px," +
                           (cy * p.gain * 12).toFixed(2) + "px," + p.z + "px)" +
          " rotate(" + p.rot + "deg)" +
          (sx !== 1 ? " scale(" + sx + ")" : "");
      }
      if (Math.abs(tx - cx) > 0.001 || Math.abs(ty - cy) > 0.001) raf = requestAnimationFrame(tick);
      else raf = 0;                                          // settled → stop (no idle rAF)
    }
    function kick() { if (!raf) raf = requestAnimationFrame(tick); }

    addEventListener("pointermove", function (e) {
      if (e.pointerType !== "mouse" || !ready) return;      // mouse only; wait out the entrance
      tx = (e.clientX / innerWidth) * 2 - 1;
      ty = (e.clientY / innerHeight) * 2 - 1;
      kick();
    }, { passive: true });

    addEventListener("pointerout", function (e) {
      if (e.relatedTarget || !ready) return;
      tx = 0; ty = 0; kick();                                // ease back to centre, then halt
    }, { passive: true });
  })();
</script>
