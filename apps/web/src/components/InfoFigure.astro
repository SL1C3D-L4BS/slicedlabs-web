---
// InfoFigure.astro — the figure renderer for the Infographic shell. Emits ONE viewBox SVG
// (preserveAspectRatio="xMidYMid meet" → the ENTIRE figure always fits, no clip) with a
// PADDED glow filter (region x/y=-50% w/h=200% so bloom is never clipped at the path bbox),
// brand-spectrum fills, and an owned "runner" tracer — a glowing comet that orbits the path
// (pure transform rotation = compositor-friendly; freezes to a static highlight under
// reduced-motion, full data parity). REAL numbers render as DOM text (selectable, AA,
// themed), never baked into the SVG. The SVG is decorative → aria-hidden; the data the
// tracer traces lives in adjacent DOM (the stat + the caption legend).
//
// v1 variant: "donut" (the home "what we stand on" card). bars / ladder / kpi-grid follow.
interface Seg { label: string; hue: string }   // hue = a CSS var name, e.g. "--coral"
interface Row { label: string; material: string; hue: string; status: string; stage: 1 | 2 | 3 }
// kpi-grid: a real number + label + source, with an honest CONFIDENCE state (sourced vs estimate).
interface Cell { value: string; label: string; source: string; hue: string; confidence: "sourced" | "estimate"; count?: number; prefix?: string; suffix?: string }
interface Props {
  variant?: "donut" | "ledger" | "kpi-grid" | "ladder";
  segments?: Seg[];     // donut variant
  rows?: Row[];         // ledger variant — a spec table of record
  cells?: Cell[];       // kpi-grid variant
  steps?: string[];     // ladder variant — a sequenced climb (you-are-here = step 0)
  stat?: string;        // the big real number, e.g. "3" (count-up if numeric)
  statLabel?: string;   // e.g. "lines on the bench"
  stamp?: string;       // a small pre-launch status pill, e.g. "pre-launch · on the bench"
  class?: string;
  id?: string;
}
const { variant = "donut", segments = [], rows = [], cells = [], steps = [], stat, statLabel, stamp, class: cls = "", id } = Astro.props;
const STAGE_FILL = [24, 54, 86];   // ledger: rail fill % by build stage (1 sketching / 2 in works / 3 on bench)
const uid = id ?? "ig" + Math.random().toString(36).slice(2, 8);

// donut geometry
const R = 40;
const C = 2 * Math.PI * R;                 // circumference (~251.33)
const N = Math.max(segments.length, 1);
const GAP = 8;                             // gap between segments (user units)
const SEG = C / N - GAP;                   // each segment's arc length
const TAIL = 20;                           // comet tail arc length
const headDeg = (TAIL / C) * 360;          // leading-edge angle of the comet
const hr = (headDeg * Math.PI) / 180;
const headX = (50 + R * Math.cos(hr)).toFixed(2);
const headY = (50 + R * Math.sin(hr)).toFixed(2);
const statIsNum = stat != null && /^\d+(\.\d+)?$/.test(stat);
---
{variant === "donut" && (
  <div class:list={["info-fig", "info-donut", cls]}>
    <svg class="if-svg" viewBox="0 0 100 100" preserveAspectRatio="xMidYMid meet" aria-hidden="true" focusable="false">
      <defs>
        {/* static head halo — a radial GRADIENT, not an SVG filter, so the orbiting comet
            rides the compositor transform with no per-frame blur re-raster (composite-only). */}
        <radialGradient id={`${uid}-head`}>
          <stop class="if-head-0" offset="0%" />
          <stop class="if-head-1" offset="55%" />
          <stop class="if-head-2" offset="100%" />
        </radialGradient>
      </defs>

      {/* faint full track behind the segments */}
      <circle class="if-track" cx="50" cy="50" r={R} />

      {/* the real data — equal segments, true 2D (honest scale; no fake-3D tilt) */}
      {segments.map((s, i) => (
        <circle
          class="if-seg"
          cx="50" cy="50" r={R}
          stroke={`var(${s.hue})`}
          stroke-dasharray={`${SEG} ${C - SEG}`}
          transform={`rotate(${-90 + i * (360 / N)} 50 50)`}
        />
      ))}

      {/* the runner tracer — a glowing comet that orbits the ring (composite-only: a static
          gradient halo + dots that the compositor transforms each frame, no filter recompute) */}
      <g class="if-comet">
        <circle class="if-comet-tail" cx="50" cy="50" r={R} stroke-dasharray={`${TAIL} ${C - TAIL}`} />
        <circle class="if-comet-glow" cx={headX} cy={headY} r="7" fill={`url(#${uid}-head)`} />
        <circle class="if-comet-head" cx={headX} cy={headY} r="2.6" />
      </g>
    </svg>

    {stat && (
      <div class="if-stat" aria-hidden="true">
        <span class="if-stat-n" data-count-to={statIsNum ? stat : undefined}>{stat}</span>
        {statLabel && <span class="if-stat-k">{statLabel}</span>}
      </div>
    )}
  </div>
)}

{variant === "ledger" && (
  <div class:list={["info-fig", "info-ledger", cls]}>
    <header class="il-head">
      <span class="il-n" data-count-to={statIsNum ? stat : undefined}>{stat}</span>
      {statLabel && <span class="il-k">{statLabel}</span>}
      {stamp && <span class="il-stamp">{stamp}</span>}
    </header>
    <ul class="il-rows">
      {rows.map((r, i) => {
        const fill = STAGE_FILL[r.stage - 1] ?? 50;
        return (
          <li class="il-row" style={`--h:var(${r.hue}); --i:${i};`}>
            <span class="il-dot" aria-hidden="true"></span>
            <span class="il-name">{r.label}</span>
            <span class="il-mat mono">{r.material}</span>
            {/* the bench rail — decorative tracer (real status is the .il-status text) */}
            <span class="il-rail" aria-hidden="true">
              <svg viewBox="0 0 100 8" preserveAspectRatio="none" focusable="false">
                <line class="il-track" x1="1" y1="4" x2="99" y2="4" />
                <line class="il-fill" x1="1" y1="4" x2={fill} y2="4" />
                {/* a short lit pulse that RUNS along the filled portion to the ship node */}
                <line class="il-pulse" x1="1" y1="4" x2={fill} y2="4" pathLength="1" />
                <circle class="il-node-halo" cx={fill} cy="4" r="5.5" />
                <circle class="il-node" cx={fill} cy="4" r="2.2" />
              </svg>
            </span>
            <span class="il-status mono">{r.status}</span>
          </li>
        );
      })}
    </ul>
  </div>
)}

{(variant === "ledger" || variant === "kpi-grid" || variant === "ladder") && (
  <script is:inline>
    // run the figure tracers (ledger pulse / kpi rail / climb runner) only while on screen
    // (no offscreen loop); never under reduced-motion. The static rails/nodes carry the data
    // meanwhile, so it reads fully with or without the motion.
    (function () {
      if (matchMedia("(prefers-reduced-motion: reduce)").matches) return;
      var els = document.querySelectorAll(".info-ledger, .info-kpi, .info-climb, .info-connector");
      if (!els.length) return;
      if (!("IntersectionObserver" in window)) {
        els.forEach(function (e) { e.classList.add("is-live"); });
        return;
      }
      var io = new IntersectionObserver(function (ents) {
        ents.forEach(function (en) { en.target.classList.toggle("is-live", en.isIntersecting); });
      }, { rootMargin: "200px" });
      els.forEach(function (e) { io.observe(e); });
    })();
  </script>
)}

{variant === "kpi-grid" && (
  <div class:list={["info-fig", "info-kpi", cls]}>
    <div class="ik-grid">
      {cells.map((c, i) => (
        <article class="ik-cell" style={`--i:${i}; --h:var(${c.hue});`} data-conf={c.confidence}>
          <div class="ik-n">
            {c.count != null
              ? <span data-count-to={c.count} data-count-prefix={c.prefix ?? ""} data-count-suffix={c.suffix ?? ""}>{(c.prefix ?? "") + c.count + (c.suffix ?? "")}</span>
              : c.value}
          </div>
          {/* confidence rail — solid + running tracer = sourced; dashed/ghost = estimate.
              The rail is decorative; the state is announced to AT by the sr-only text below. */}
          <span class="ik-rail" aria-hidden="true"></span>
          <span class="sr-only">{c.confidence === "sourced" ? "Sourced figure." : "Estimate."}</span>
          <p class="ik-k">{c.label}</p>
          <span class="ik-src mono">{c.source}</span>
        </article>
      ))}
    </div>
  </div>
)}

{variant === "ladder" && (
  <ol class:list={["info-fig", "info-climb", cls]}>
    {steps.map((s, i) => (
      <li class="ic-step" style={`--i:${i};`} data-here={i === 0 ? "" : undefined} aria-current={i === 0 ? "step" : undefined}>
        <span class="ic-node" aria-hidden="true"></span>
        <span class="ic-num mono">{String(i).padStart(2, "0")}</span>
        <span class="ic-text">{s}</span>
      </li>
    ))}
  </ol>
)}

<style>
  .info-fig { position: relative; width: 100%; height: 100%; }
  .if-svg { display: block; width: 100%; height: 100%; overflow: visible; }

  .if-track { fill: none; stroke: color-mix(in oklab, var(--ink) 9%, var(--stroke)); stroke-width: 8; }
  .if-seg {
    fill: none; stroke-width: 8; stroke-linecap: round;
    transition: stroke-width var(--t-quick, .18s) var(--ease);
  }

  /* the orbiting comet tracer + glow head */
  .if-comet { transform-box: view-box; transform-origin: 50% 50%; animation: if-orbit 4.6s linear infinite; }
  .if-comet-tail {
    fill: none; stroke: var(--specular); stroke-width: 8; stroke-linecap: round;
    opacity: .9;
  }
  .if-comet-head { fill: color-mix(in oklab, #fff 30%, var(--specular)); }
  /* the head's soft halo gradient — theme-aware via --specular (brass on warm, blue on dark) */
  .if-head-0 { stop-color: color-mix(in oklab, #fff 35%, var(--specular)); stop-opacity: 1; }
  .if-head-1 { stop-color: var(--specular); stop-opacity: .5; }
  .if-head-2 { stop-color: var(--specular); stop-opacity: 0; }
  @keyframes if-orbit { to { transform: rotate(360deg); } }

  /* the real number, centered on the donut (DOM text → selectable, AA, themed) */
  .if-stat {
    position: absolute; inset: 0; display: grid; place-content: center; text-align: center;
    pointer-events: none;
  }
  .if-stat-n {
    display: block; font-family: var(--font-display); font-weight: 800; line-height: 1;
    font-size: clamp(2.4rem, 16cqi, 4rem); color: var(--ink);
    font-variant-numeric: tabular-nums; font-feature-settings: "tnum" 1;
    text-shadow: 0 2px 18px color-mix(in oklab, var(--bg) 60%, transparent);
  }
  .if-stat-k {
    font-family: var(--font-mono); font-size: clamp(.6rem, 2.4cqi, .72rem);
    letter-spacing: .14em; text-transform: uppercase; color: var(--muted-strong);
  }

  /* ── LEDGER variant — a spec table of record (real, accessible DOM text + tracer rails) ── */
  .info-ledger { display: grid; grid-template-rows: auto 1fr; gap: clamp(.5rem, 2.4cqi, 1.1rem); align-content: center; }
  .il-head { display: flex; align-items: baseline; gap: clamp(.4rem, 1.6cqi, .8rem); flex-wrap: wrap; }
  .il-n {
    font-family: var(--font-display); font-weight: 800; line-height: .85; color: var(--ink);
    font-size: clamp(2rem, 9cqi, 3.4rem); font-variant-numeric: tabular-nums; font-feature-settings: "tnum" 1;
  }
  .il-k { font-family: var(--font-mono); font-size: clamp(.6rem, 2.4cqi, .74rem); letter-spacing: .12em; text-transform: uppercase; color: var(--muted-strong); }
  .il-stamp {
    margin-left: auto; font-family: var(--font-mono); font-size: clamp(.52rem, 1.9cqi, .62rem);
    letter-spacing: .1em; text-transform: uppercase; color: var(--muted-strong); white-space: nowrap;
    border: 1px solid color-mix(in oklab, var(--brass) 48%, var(--stroke)); border-radius: 999px; padding: .2rem .6rem;
  }
  .il-rows { list-style: none; margin: 0; padding: 0; display: grid; grid-auto-rows: 1fr; }
  .il-row {
    display: grid; align-items: center; gap: clamp(.5rem, 2cqi, 1.1rem);
    grid-template-columns: auto minmax(0, 1fr) minmax(0, 1.3fr) minmax(0, 1.8fr) auto;
    padding-block: clamp(.45rem, 1.8cqi, .9rem);
    border-top: 1px solid color-mix(in oklab, var(--brass) 30%, transparent);
  }
  .il-row:last-child { border-bottom: 1px solid color-mix(in oklab, var(--brass) 30%, transparent); }
  .il-dot { width: .62rem; height: .62rem; border-radius: 50%; flex: none; background: var(--h); box-shadow: 0 0 10px color-mix(in oklab, var(--h) 60%, transparent); }
  .il-name { font-family: var(--font-display); font-weight: 700; font-size: clamp(.95rem, 3.4cqi, 1.3rem); color: var(--ink); line-height: 1.1; }
  .il-mat { color: var(--muted-strong); font-size: clamp(.58rem, 2.1cqi, .72rem); }
  .il-status { color: var(--muted-strong); font-size: clamp(.56rem, 1.9cqi, .68rem); white-space: nowrap; text-align: right; }
  .il-rail { display: block; height: .55rem; min-width: 4rem; }
  .il-rail svg { display: block; width: 100%; height: 100%; overflow: visible; }
  .il-track { stroke: color-mix(in oklab, var(--ink) 10%, var(--stroke)); stroke-width: 2; }
  .il-fill { stroke: var(--h); stroke-width: 2.5; stroke-linecap: round; }
  .il-node-halo { fill: var(--h); opacity: .22; }
  .il-node { fill: var(--h); }
  /* the runner — a short lit pulse running along the filled rail to the ship node (staggered relay).
     Animates ONLY while the ledger is on screen (.is-live, set by the observer below) so there's
     no offscreen paint loop; renders as a static lit dash before/without activation. */
  .il-pulse {
    stroke: var(--specular); stroke-width: 2.5; stroke-linecap: round;
    stroke-dasharray: .12 .88;
  }
  .info-ledger.is-live .il-pulse { animation: il-pulse 3s linear infinite; animation-delay: calc(var(--i) * .9s); opacity: calc(.82 + var(--scroll-vel, 0) * .18); }
  @keyframes il-pulse { from { stroke-dashoffset: .12; } to { stroke-dashoffset: -.88; } }

  /* narrow container → 2-line rows (no data hidden): name+status on top, material+rail below */
  @container (max-width: 32rem) {
    .il-row {
      grid-template-columns: auto 1fr auto;
      grid-template-areas: "dot name status" ". mat mat" ". rail rail";
      row-gap: .35rem;
    }
    .il-dot { grid-area: dot; } .il-name { grid-area: name; } .il-status { grid-area: status; }
    .il-mat { grid-area: mat; } .il-rail { grid-area: rail; }
  }

  /* ── KPI-GRID variant — sourced data cells on SOLID surfaces (AA), source chips + a
        confidence rail (solid + running tracer = sourced · dashed/ghost = estimate) ── */
  .info-kpi { width: 100%; }
  .ik-grid { display: grid; gap: clamp(.7rem, 2.4cqi, 1.1rem); grid-template-columns: repeat(auto-fit, minmax(min(100%, 13rem), 1fr)); }
  .ik-cell {
    background: var(--bg-alt); border: 1px solid var(--stroke); border-radius: var(--radius);
    box-shadow: var(--shadow-1); padding: clamp(1rem, 3cqi, 1.6rem);
    display: grid; justify-items: center; text-align: center; gap: .1rem;
  }
  .ik-n {
    font-family: var(--font-display); font-weight: 800; line-height: 1; color: var(--ink);
    font-size: clamp(1.7rem, 7cqi, 2.7rem); font-variant-numeric: tabular-nums; font-feature-settings: "tnum" 1;
  }
  .ik-rail { position: relative; display: block; width: 2.6rem; height: 3px; border-radius: 3px; margin: .55rem 0 .5rem; overflow: hidden; background: var(--h); }
  .ik-cell[data-conf="estimate"] .ik-rail { background: repeating-linear-gradient(90deg, var(--h) 0 4px, transparent 4px 8px); opacity: .55; }
  /* the running tracer renders only while the grid is on screen (.is-live); the static solid
     rail already encodes the "sourced" state, so nothing is lost when it's idle/offscreen */
  .info-kpi.is-live .ik-cell[data-conf="sourced"] .ik-rail::after {
    content: ""; position: absolute; top: 0; bottom: 0; width: 45%;
    background: linear-gradient(90deg, transparent, color-mix(in oklab, #fff 55%, var(--specular)), transparent);
    transform: translateX(-120%); animation: ik-run 2.6s linear infinite; animation-delay: calc(var(--i) * .3s);
    opacity: calc(.82 + var(--scroll-vel, 0) * .18);
  }
  @keyframes ik-run { to { transform: translateX(240%); } }
  .ik-k { font-weight: 600; color: var(--ink); font-size: clamp(.85rem, 2.6cqi, 1rem); line-height: 1.2; }
  .ik-src { display: block; font-size: clamp(.58rem, 1.8cqi, .68rem); color: var(--muted-strong); margin-top: .15rem; }

  /* ── LADDER variant — a sequenced climb rail with a running tracer + a you-are-here node ── */
  .info-climb { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(6, 1fr); gap: clamp(.5rem, 2cqi, 1rem); position: relative; }
  .info-climb::before { content: ""; position: absolute; left: 8%; right: 8%; top: .55rem; height: 2px; background: color-mix(in oklab, var(--ink) 12%, var(--stroke)); }
  /* energy flows phase→phase — a bright segment sweeping the rail (composite transform),
     gated to on-screen (.is-live); the static rail + nodes carry the sequence meanwhile */
  .info-climb.is-live::after {
    content: ""; position: absolute; left: 8%; top: .55rem; height: 2px; width: 26%;
    background: linear-gradient(90deg, transparent, color-mix(in oklab, #fff 50%, var(--specular)), transparent);
    transform: translateX(-60%); animation: ic-run 5s linear infinite;
    opacity: calc(.82 + var(--scroll-vel, 0) * .18);
  }
  @keyframes ic-run { to { transform: translateX(350%); } }
  .ic-step { display: grid; justify-items: center; text-align: center; gap: .3rem; position: relative; }
  .ic-node {
    width: 1.1rem; height: 1.1rem; border-radius: 50%; background: var(--bg-alt);
    border: 2px solid color-mix(in oklab, var(--mark) 50%, var(--stroke)); position: relative; z-index: 1;
  }
  .ic-step[data-here] .ic-node { background: var(--specular); border-color: var(--specular); box-shadow: 0 0 0 4px color-mix(in oklab, var(--specular) 22%, transparent); }
  .ic-num { font-family: var(--font-mono); font-size: .62rem; letter-spacing: .06em; color: var(--muted-strong); }
  .ic-text { font-size: clamp(.7rem, 2.2cqi, .86rem); color: var(--ink); font-weight: 600; line-height: 1.2; }
  @container (max-width: 40rem) {
    .info-climb { grid-template-columns: 1fr 1fr 1fr; row-gap: 1.3rem; }
    .info-climb::before, .info-climb::after { display: none; }
  }

  /* reduced-motion: freeze the comet + the rail pulses + the kpi tracer + the climb runner */
  @media (prefers-reduced-motion: reduce) {
    .if-comet { animation: none; }
    .il-pulse { animation: none; opacity: .55; }
    .ik-cell[data-conf="sourced"] .ik-rail::after { animation: none; display: none; }
    .info-climb::after { animation: none; display: none; }
  }
  /* reduced-transparency: drop the soft halos so everything stays crisp */
  @media (prefers-reduced-transparency: reduce) {
    .if-stat-n { text-shadow: none; }
    .il-node-halo { display: none; }
  }
</style>
