---
// SlicedLabs · studio · © 2026 SlicedLabs — Showpiece3D
// A gated, lazy Three.js island for a cinematic product/hero moment. Mirrors ShaderField:
// renders a static brand-gradient fallback first; only when the shared capability gate
// passes does it dynamically import the renderer (so `three` never ships to gated / no-JS
// / reduced-data visits). Decorative by default (aria-hidden) — pass `label` to announce it.
// `modelUrl` is the asset-swap seam: omit it and the renderer draws a procedural board;
// drop a .glb in /public/models and pass its path to swap in with zero code change.
interface Props {
  modelUrl?: string;
  variant?: "mark" | "board";
  class?: string;
  height?: string;
  label?: string;
}
const { modelUrl, variant, class: cls = "", height = "clamp(18rem, 42vw, 30rem)", label } = Astro.props;
---
<div
  class:list={["showpiece", cls]}
  style={`--sp-h:${height}`}
  aria-hidden={label ? undefined : "true"}
  aria-label={label}
>
  <div class="showpiece-fallback"></div>
  <canvas class="showpiece-canvas" data-showpiece data-model={modelUrl} data-variant={variant}></canvas>
</div>

<style>
  .showpiece { position: relative; width: 100%; height: var(--sp-h); overflow: hidden; border-radius: inherit; }
  .showpiece-fallback {
    position: absolute; inset: -10%;
    background:
      radial-gradient(58% 52% at 72% 12%, color-mix(in oklab, var(--blue) 30%, transparent), transparent 60%),
      radial-gradient(52% 50% at 16% 24%, color-mix(in oklab, var(--coral) 26%, transparent), transparent 62%),
      radial-gradient(60% 55% at 50% 108%, color-mix(in oklab, var(--teal) 22%, transparent), transparent 64%);
  }
  [data-temp="warm"] .showpiece-fallback { opacity: .6; }
  .showpiece-canvas {
    position: absolute; inset: 0; width: 100%; height: 100%; display: block;
    opacity: 0; transition: opacity 1100ms ease;
  }
  .showpiece-canvas.is-on { opacity: 1; }
  /* reduced-motion → the canvas never mounts; the static gradient carries it. */
  @media (prefers-reduced-motion: reduce) { .showpiece-canvas { display: none; } }
</style>

<script>
  import { shouldRunHeavyFx } from "../lib/clientCaps";
  (function () {
    const nodes = Array.from(
      document.querySelectorAll<HTMLCanvasElement>("[data-showpiece]:not([data-sp-on])"),
    );
    if (!nodes.length || !shouldRunHeavyFx()) return;

    const handles: { dispose: () => void }[] = [];
    import("./showpiece3d")
      .then(({ initShowpiece }) => {
        for (const canvas of nodes) {
          canvas.setAttribute("data-sp-on", "");
          handles.push(
            initShowpiece(canvas, {
              modelUrl: canvas.dataset.model || undefined,
              variant: (canvas.dataset.variant as "mark" | "board" | undefined) || undefined,
            }),
          );
          canvas.classList.add("is-on");
        }
      })
      .catch(() => {
        /* import/WebGL failure → leave the static gradient fallback */
      });

    // tear down the GL context on navigation away (client-router swap) + on unload.
    const teardown = () => handles.forEach((h) => h.dispose());
    document.addEventListener("astro:before-swap", teardown, { once: true });
    addEventListener("pagehide", teardown, { once: true });
  })();
</script>
