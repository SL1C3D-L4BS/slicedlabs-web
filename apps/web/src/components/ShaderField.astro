---
// SlicedLabs · studio · © 2026 SlicedLabs — ShaderField
// A real-time GPU background: a flowing, domain-warped color field in the brand blend
// (coral → orange → teal → blue → mark). Progressive enhancement + heavily gated:
//   · prefers-reduced-motion / prefers-reduced-data / Save-Data / low-power → NEVER runs
//   · IntersectionObserver pauses it off-screen; visibilitychange pauses on tab blur
//   · capped DPR + half-res buffer; one fullscreen triangle; no allocations in the loop
// Fallback (and the no-WebGL / no-JS path) = a static CSS blend gradient underneath, so
// the surface is always beautiful even with the canvas off. Fill a position:relative parent.
interface Props { class?: string }
const { class: cls = "" } = Astro.props;
---
<div class:list={["shaderfield", cls]} aria-hidden="true">
  <div class="shaderfield-fallback"></div>
  <canvas class="shaderfield-canvas" data-shaderfield></canvas>
</div>

<style>
  .shaderfield { position: absolute; inset: 0; overflow: hidden; z-index: -1; pointer-events: none; }
  /* always-present static base — the brand blend, very calm. The canvas layers over it. */
  .shaderfield-fallback {
    position: absolute; inset: -10%;
    background:
      radial-gradient(60% 50% at 78% 8%, color-mix(in oklab, var(--blue) 38%, transparent), transparent 60%),
      radial-gradient(55% 50% at 12% 22%, color-mix(in oklab, var(--coral) 30%, transparent), transparent 62%),
      radial-gradient(60% 55% at 50% 110%, color-mix(in oklab, var(--teal) 26%, transparent), transparent 64%);
    filter: saturate(1.1);
  }
  .shaderfield-canvas { position: absolute; inset: 0; width: 100%; height: 100%; display: block; opacity: 0; transition: opacity 900ms ease; }
  .shaderfield-canvas.is-on { opacity: 1; }
  /* if the canvas never turns on, the fallback carries it. */
  @media (prefers-reduced-motion: reduce) { .shaderfield-canvas { display: none; } }
</style>

<script>
  // One shared renderer per page (there's normally a single ShaderField). Bail safely on
  // any unsupported / low-power condition — the CSS fallback already looks good.
  (function () {
    const canvas = document.querySelector<HTMLCanvasElement>("[data-shaderfield]");
    if (!canvas) return;

    const mq = matchMedia("(prefers-reduced-motion: reduce)");
    const lowData =
      matchMedia("(prefers-reduced-data: reduce)").matches ||
      // @ts-ignore - navigator.connection is non-standard
      (navigator.connection && navigator.connection.saveData);
    // crude low-power heuristic: very few cores or little memory → keep it static
    const weak =
      (navigator.hardwareConcurrency || 8) <= 4 ||
      // @ts-ignore - deviceMemory is non-standard
      (navigator.deviceMemory && navigator.deviceMemory <= 4);
    if (mq.matches || lowData || weak) return;

    const gl = canvas.getContext("webgl2", { antialias: false, alpha: true, premultipliedAlpha: false, powerPreference: "low-power" });
    if (!gl) return;

    const VERT = `#version 300 es
    void main(){ vec2 p = vec2((gl_VertexID<<1)&2, gl_VertexID&2); gl_Position = vec4(p*2.0-1.0,0,1); }`;

    const FRAG = `#version 300 es
    precision highp float;
    out vec4 o;
    uniform vec2 u_res;
    uniform float u_time;
    // brand blend, linearised-ish
    const vec3 CORAL=vec3(0.851,0.345,0.235);
    const vec3 ORANGE=vec3(0.796,0.408,0.125);
    const vec3 TEAL=vec3(0.184,0.608,0.502);
    const vec3 BLUE=vec3(0.188,0.545,0.859);
    const vec3 MARK=vec3(0.298,0.714,1.0);
    // hash + value noise + fbm
    float hash(vec2 p){ p=fract(p*vec2(123.34,456.21)); p+=dot(p,p+45.32); return fract(p.x*p.y); }
    float noise(vec2 p){ vec2 i=floor(p), f=fract(p); vec2 u=f*f*(3.0-2.0*f);
      return mix(mix(hash(i),hash(i+vec2(1,0)),u.x), mix(hash(i+vec2(0,1)),hash(i+vec2(1,1)),u.x), u.y); }
    float fbm(vec2 p){ float v=0.0,a=0.5; mat2 m=mat2(1.6,1.2,-1.2,1.6);
      for(int i=0;i<5;i++){ v+=a*noise(p); p=m*p; a*=0.5; } return v; }
    vec3 ramp(float t){ t=clamp(t,0.0,1.0);
      if(t<0.25) return mix(CORAL,ORANGE,t/0.25);
      if(t<0.5)  return mix(ORANGE,TEAL,(t-0.25)/0.25);
      if(t<0.75) return mix(TEAL,BLUE,(t-0.5)/0.25);
      return mix(BLUE,MARK,(t-0.75)/0.25); }
    void main(){
      vec2 uv=(gl_FragCoord.xy-0.5*u_res)/min(u_res.x,u_res.y);
      float t=u_time*0.045;
      // domain warp — flowing, organic
      vec2 q=vec2(fbm(uv*1.4+vec2(0.0,t)), fbm(uv*1.4+vec2(5.2,-t)));
      vec2 r=vec2(fbm(uv*1.4+3.0*q+vec2(1.7,9.2)+t*0.7), fbm(uv*1.4+3.0*q+vec2(8.3,2.8)-t*0.7));
      float f=fbm(uv*1.2+2.2*r);
      vec3 col=ramp(f*0.85+0.18*r.x+0.1);
      // soft luminance lift in the warped cores, then deepen at the edges (cinematic vignette)
      col*=0.85+0.5*smoothstep(0.2,0.9,f);
      float vig=smoothstep(1.25,0.25,length(uv));
      col*=mix(0.55,1.0,vig);
      // faint grain to kill banding
      col+=(hash(gl_FragCoord.xy+u_time)-0.5)*0.025;
      o=vec4(col, 0.92);
    }`;

    function compile(type: number, src: string) {
      const s = gl!.createShader(type)!;
      gl!.shaderSource(s, src);
      gl!.compileShader(s);
      return s;
    }
    const prog = gl.createProgram()!;
    gl.attachShader(prog, compile(gl.VERTEX_SHADER, VERT));
    gl.attachShader(prog, compile(gl.FRAGMENT_SHADER, FRAG));
    gl.linkProgram(prog);
    if (!gl.getProgramParameter(prog, gl.LINK_STATUS)) return; // shader failed → keep fallback
    gl.useProgram(prog);
    const uRes = gl.getUniformLocation(prog, "u_res");
    const uTime = gl.getUniformLocation(prog, "u_time");

    const DPR = Math.min(window.devicePixelRatio || 1, 1.5);
    function resize() {
      const w = Math.max(1, Math.floor(canvas!.clientWidth * DPR * 0.6)); // half-ish res
      const h = Math.max(1, Math.floor(canvas!.clientHeight * DPR * 0.6));
      if (canvas!.width !== w || canvas!.height !== h) { canvas!.width = w; canvas!.height = h; gl!.viewport(0, 0, w, h); }
    }
    const ro = new ResizeObserver(resize); ro.observe(canvas);
    resize();

    let raf = 0, t0 = 0, onScreen = true;
    function frame(now: number) {
      if (!t0) t0 = now;
      resize();
      gl!.uniform2f(uRes, canvas!.width, canvas!.height);
      gl!.uniform1f(uTime, (now - t0) / 1000);
      gl!.drawArrays(gl!.TRIANGLES, 0, 3);
      raf = requestAnimationFrame(frame);
    }
    function start() { if (!raf && onScreen && !document.hidden) { canvas!.classList.add("is-on"); raf = requestAnimationFrame(frame); } }
    function stop() { if (raf) { cancelAnimationFrame(raf); raf = 0; } }

    const io = new IntersectionObserver((e) => { onScreen = e[0].isIntersecting; onScreen ? start() : stop(); }, { threshold: 0 });
    io.observe(canvas);
    document.addEventListener("visibilitychange", () => (document.hidden ? stop() : start()));
    mq.addEventListener?.("change", (e) => { if (e.matches) { stop(); canvas!.classList.remove("is-on"); } });
    start();
  })();
</script>
