---
// SlicedLabs · studio · © 2026 SlicedLabs — ShaderField
// The real-time GPU "living backdrop" (theme-aware brand-blend / Italian-latte field).
// Renders OFF the main thread via an OffscreenCanvas WORKER when supported (so it can't
// stutter scroll/input), with a robust main-thread fallback (shared shaderGL.ts). Use
// `fixed` to mount it once site-wide behind a transparent header. Heavily gated:
//   · prefers-reduced-motion / prefers-reduced-data / Save-Data / low-power → NEVER runs
//   · paused on tab blur + off-screen; capped DPR + half-res; scroll velocity is SMOOTHED
// Fallback (no-WebGL / no-JS / reduced-motion) = a static, theme-tinted CSS gradient.
interface Props { class?: string; fixed?: boolean }
const { class: cls = "", fixed = false } = Astro.props;
---
<div class:list={["shaderfield", fixed && "is-fixed", cls]} aria-hidden="true">
  <div class="shaderfield-fallback"></div>
  <canvas class="shaderfield-canvas" data-shaderfield></canvas>
</div>

<style>
  .shaderfield { position: absolute; inset: 0; overflow: hidden; z-index: -1; pointer-events: none; }
  .shaderfield.is-fixed { position: fixed; }
  .shaderfield-fallback {
    position: absolute; inset: -10%;
    background:
      radial-gradient(60% 50% at 78% 8%, color-mix(in oklab, var(--blue) 30%, transparent), transparent 60%),
      radial-gradient(55% 50% at 12% 22%, color-mix(in oklab, var(--coral) 24%, transparent), transparent 62%),
      radial-gradient(60% 55% at 50% 110%, color-mix(in oklab, var(--teal) 22%, transparent), transparent 64%);
  }
  [data-temp="warm"] .shaderfield-fallback { opacity: .5; }
  .shaderfield-canvas { position: absolute; inset: 0; width: 100%; height: 100%; display: block; opacity: 0; transition: opacity 1100ms ease; }
  .shaderfield-canvas.is-on { opacity: 1; }
  @media (prefers-reduced-motion: reduce) { .shaderfield-canvas { display: none; } }
</style>

<script>
  import { initGL } from "./shaderGL";

  (function () {
    const canvas = document.querySelector<HTMLCanvasElement>("[data-shaderfield]");
    if (!canvas) return;

    const mq = matchMedia("(prefers-reduced-motion: reduce)");
    const lowData =
      matchMedia("(prefers-reduced-data: reduce)").matches ||
      // @ts-ignore - navigator.connection is non-standard
      (navigator.connection && navigator.connection.saveData);
    const weak =
      (navigator.hardwareConcurrency || 8) <= 4 ||
      // @ts-ignore - deviceMemory is non-standard
      (navigator.deviceMemory && navigator.deviceMemory <= 4);
    if (mq.matches || lowData || weak) return;

    const root = document.documentElement;
    const warmVal = () => (root.getAttribute("data-temp") !== "dark" ? 1 : 0);
    const DPR = Math.min(window.devicePixelRatio || 1, 1.5);
    const sizeOf = () => ({
      w: Math.max(1, Math.floor(canvas!.clientWidth * DPR * 0.6)),
      h: Math.max(1, Math.floor(canvas!.clientHeight * DPR * 0.6)),
    });
    const velNow = () => (window as unknown as { __slVel?: number }).__slVel || 0;

    // ── OffscreenCanvas worker path — render OFF the main thread ──────────────
    if (typeof OffscreenCanvas !== "undefined" && "transferControlToOffscreen" in canvas) {
      try {
        const worker = new Worker(new URL("./shader.worker.ts", import.meta.url), { type: "module" });
        const off = (canvas as HTMLCanvasElement).transferControlToOffscreen();
        const s = sizeOf();
        worker.postMessage({ canvas: off, w: s.w, h: s.h, warm: warmVal() }, [off]);
        worker.onmessage = (e) => { if (e.data && e.data.started) canvas!.classList.add("is-on"); };
        new ResizeObserver(() => { const s2 = sizeOf(); worker.postMessage({ size: true, w: s2.w, h: s2.h }); }).observe(canvas);
        new MutationObserver(() => worker.postMessage({ warm: warmVal() })).observe(root, { attributes: true, attributeFilter: ["data-temp"] });
        let vraf = 0;
        const pump = () => { vraf = 0; worker.postMessage({ vel: velNow() }); };
        addEventListener("scroll", () => { if (!vraf) vraf = requestAnimationFrame(pump); }, { passive: true });
        document.addEventListener("visibilitychange", () => worker.postMessage({ pause: document.hidden }));
        new IntersectionObserver((en) => worker.postMessage({ pause: !en[0].isIntersecting }), { threshold: 0 }).observe(canvas);
        mq.addEventListener?.("change", (e) => { if (e.matches) { worker.postMessage({ pause: true }); canvas!.classList.remove("is-on"); } });
        return;
      } catch (err) {
        /* worker / transfer unsupported → main-thread fallback below */
      }
    }

    // ── main-thread fallback (shared initGL) ─────────────────────────────────
    const r = initGL(canvas);
    if (!r) return;
    let raf = 0, t0 = 0, vel = 0, onScreen = true;
    function frame(now: number) {
      if (!t0) t0 = now;
      const s = sizeOf();
      r!.resize(s.w, s.h);
      vel += (velNow() - vel) * 0.05; // smooth → no glitchy jumps on fast scroll
      r!.draw((now - t0) / 1000, warmVal(), vel);
      raf = requestAnimationFrame(frame);
    }
    function start() { if (!raf && onScreen && !document.hidden) { canvas!.classList.add("is-on"); raf = requestAnimationFrame(frame); } }
    function stop() { if (raf) { cancelAnimationFrame(raf); raf = 0; } }
    new IntersectionObserver((e) => { onScreen = e[0].isIntersecting; onScreen ? start() : stop(); }, { threshold: 0 }).observe(canvas);
    document.addEventListener("visibilitychange", () => (document.hidden ? stop() : start()));
    mq.addEventListener?.("change", (e) => { if (e.matches) { stop(); canvas!.classList.remove("is-on"); } });
    start();
  })();
</script>
