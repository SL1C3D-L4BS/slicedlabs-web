---
<div class="soc" role="list" aria-label="SlicedLabs on social">
  {socials.map((s) => (
    <a
      class="soc-link"
      role="listitem"
      href={s.href}
      style={`--hue:${s.hue}`}
      target="_blank"
      rel="me noopener"
      aria-label={`SlicedLabs on ${s.name} (${s.handle})`}
      title={`${s.name} · ${s.handle}`}
    >
      <span class="soc-ico" set:html={s.svg}></span>
    </a>
  ))}
</div>

<style>
  .soc { display: flex; gap: 0.55rem; align-items: center; flex-wrap: wrap; }
  .soc-link {
    --hue: var(--mark);
    display: inline-flex; align-items: center; justify-content: center;
    width: 38px; height: 38px; border-radius: 999px;
    color: var(--muted); border: 1px solid var(--stroke); background: transparent;
    transition: color var(--t-normal), border-color var(--t-normal),
                background-color var(--t-normal), transform var(--t-quick) var(--ease);
  }
  .soc-ico { display: inline-flex; width: 18px; height: 18px; }
  .soc-ico :global(svg) { width: 100%; height: 100%; display: block; }
  .soc-link:hover, .soc-link:focus-visible {
    color: var(--ink);
    border-color: color-mix(in oklab, var(--hue) 55%, var(--stroke));
    background: color-mix(in oklab, var(--hue) 12%, transparent);
    transform: translateY(-2px);
  }
  @media (prefers-reduced-motion: reduce) {
    .soc-link { transition: none; }
    .soc-link:hover, .soc-link:focus-visible { transform: none; }
  }
</style>
