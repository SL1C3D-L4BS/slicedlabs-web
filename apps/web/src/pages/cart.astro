---
// SlicedLabs · studio · © 2026 SlicedLabs — Cart
// Client-rendered: the cart lives in localStorage and is repriced by /api/cart
// (RLS → active products only) so titles/prices/images are always trustworthy.
export const prerender = false;
import Base from "../layouts/Base.astro";
---
<Base title="Your cart — SlicedLabs" description="Review your order before checkout." noindex={true}>
  <section class="wrap" style="padding-block:clamp(2rem,6vw,3.5rem);">
    <p class="mono" data-reveal>order review</p>
    <h1 data-reveal style="--i:1; font-size:clamp(2rem,7vw,3.4rem);"><span class="blend-text">Your cart</span></h1>
    <hr class="blade" data-reveal style="--i:2; max-width:12rem; margin:1.2rem 0 1.8rem;" />

    <div id="cart-root">
      <p class="mono" style="color:var(--muted);">Loading…</p>
    </div>
  </section>

  <script>
    import * as cart from "../scripts/cart";
    import { formatMoney } from "../lib/commerce/cart";

    const root = document.getElementById("cart-root");

    type PricedItem = {
      variantId: string;
      productSlug: string;
      title: string;
      image: string | null;
      unitPriceCents: number;
      currency: string;
      qty: number;
      lineTotalCents: number;
    };

    function esc(s: string): string {
      return s.replace(/[&<>"']/g, (c) =>
        ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" })[c] as string,
      );
    }

    function renderEmpty() {
      if (!root) return;
      root.innerHTML = `
        <div class="glass island" style="text-align:center;">
          <p class="mono" style="color:var(--muted); margin:0 0 1rem;">Your cart is empty</p>
          <a class="btn" href="/shop">Browse the shop →</a>
        </div>`;
    }

    function renderError() {
      if (!root) return;
      root.innerHTML = `
        <div class="glass island" style="text-align:center;">
          <p class="mono" style="color:var(--coral); margin:0 0 1rem;">We couldn't load your cart. Try again in a moment.</p>
          <a class="btn btn-ghost" href="/cart">Retry</a>
        </div>`;
    }

    function render(items: PricedItem[], subtotalCents: number, currency: string) {
      if (!root) return;
      if (items.length === 0) {
        renderEmpty();
        return;
      }
      const rows = items
        .map((i) => `
          <div class="glass" style="display:grid; grid-template-columns:auto 1fr auto; gap:1rem; align-items:center; padding:1rem; border-radius:var(--radius);">
            <div style="width:4.5rem; height:4.5rem; border-radius:12px; overflow:hidden; background:var(--panel); border:1px solid var(--stroke); flex-shrink:0;">
              <img src="${i.image ? esc(i.image) : "/placeholder-product.svg"}" alt="" style="width:100%; height:100%; object-fit:cover; display:block;">
            </div>
            <div style="min-width:0;">
              <a href="/shop/${esc(i.productSlug)}" style="color:inherit; text-decoration:none; font-weight:600;">${esc(i.title)}</a>
              <p class="mono" style="margin:.3rem 0 .6rem; color:var(--muted);">${formatMoney(i.unitPriceCents, i.currency)} each</p>
              <div style="display:flex; align-items:center; gap:.5rem;">
                <button type="button" class="btn btn-ghost qty-dec" data-variant="${esc(i.variantId)}" aria-label="Decrease quantity" style="padding:.3rem .8rem; min-width:2.4rem;">–</button>
                <span class="mono" aria-live="polite" style="min-width:2rem; text-align:center;">${i.qty}</span>
                <button type="button" class="btn btn-ghost qty-inc" data-variant="${esc(i.variantId)}" aria-label="Increase quantity" style="padding:.3rem .8rem; min-width:2.4rem;">+</button>
                <button type="button" class="qty-remove" data-variant="${esc(i.variantId)}" style="background:none; border:none; color:var(--muted); cursor:pointer; text-decoration:underline; font:inherit; font-size:.85rem; margin-left:.4rem;">Remove</button>
              </div>
            </div>
            <div class="mono" style="font-size:1.05rem; white-space:nowrap;">${formatMoney(i.lineTotalCents, i.currency)}</div>
          </div>`)
        .join("");

      root.innerHTML = `
        <div style="display:grid; gap:.8rem;">${rows}</div>
        <div class="glass island" style="margin-top:1.4rem; display:flex; flex-direction:column; gap:.6rem;">
          <div style="display:flex; justify-content:space-between; align-items:baseline;">
            <span class="mono" style="color:var(--muted);">Subtotal</span>
            <span class="mono" style="font-size:1.3rem;">${formatMoney(subtotalCents, currency)}</span>
          </div>
          <p class="mono" style="color:var(--muted); margin:0; font-size:.8rem;">Shipping &amp; tax calculated at checkout</p>
          <button type="button" id="checkout-btn" class="btn" style="margin-top:.4rem;">Checkout →</button>
        </div>`;

      document.getElementById("checkout-btn")?.addEventListener("click", () => {
        location.href = "/checkout";
      });
      wireSteppers();
    }

    function wireSteppers() {
      for (const el of document.querySelectorAll<HTMLButtonElement>(".qty-inc")) {
        el.addEventListener("click", () => {
          const id = el.dataset.variant;
          if (!id) return;
          const cur = cart.read().find((l) => l.variantId === id)?.qty ?? 0;
          cart.setQty(id, cur + 1);
          refresh();
        });
      }
      for (const el of document.querySelectorAll<HTMLButtonElement>(".qty-dec")) {
        el.addEventListener("click", () => {
          const id = el.dataset.variant;
          if (!id) return;
          const cur = cart.read().find((l) => l.variantId === id)?.qty ?? 0;
          cart.setQty(id, cur - 1); // setQty <= 0 removes the line
          refresh();
        });
      }
      for (const el of document.querySelectorAll<HTMLButtonElement>(".qty-remove")) {
        el.addEventListener("click", () => {
          const id = el.dataset.variant;
          if (!id) return;
          cart.setQty(id, 0);
          refresh();
        });
      }
    }

    async function refresh() {
      const lines = cart.read();
      if (lines.length === 0) {
        renderEmpty();
        return;
      }
      try {
        const res = await fetch("/api/cart", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ lines }),
        });
        if (!res.ok) {
          renderError();
          return;
        }
        const data = (await res.json()) as {
          items: PricedItem[];
          subtotalCents: number;
          currency: string;
        };
        // Reconcile localStorage to whatever the server still recognizes (drops
        // inactive/unknown lines so we don't keep showing phantom items).
        const valid = new Set(data.items.map((i) => i.variantId));
        for (const l of lines) if (!valid.has(l.variantId)) cart.setQty(l.variantId, 0);

        render(data.items, data.subtotalCents, data.currency);
      } catch {
        renderError();
      }
    }

    refresh();
  </script>
</Base>
