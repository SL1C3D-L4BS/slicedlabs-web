---
// SlicedLabs · studio · © 2026 SlicedLabs — The Numbers (the data case)
import Base from "../layouts/Base.astro";
import Infographic from "../components/Infographic.astro";
import InfoFigure from "../components/InfoFigure.astro";
// The market case — REAL figures. Each carries its source + an honest CONFIDENCE state:
// a solid rail + running tracer = sourced; a dashed/ghost rail = an estimate/benchmark.
const cells: { value: string; label: string; source: string; hue: string; confidence: "sourced" | "estimate"; count?: number; prefix?: string; suffix?: string }[] = [
  { value: "$2.8B", label: "US food-truck market", source: "13.2% CAGR 2020–2025 · IBISWorld", hue: "--coral", confidence: "sourced" },
  { value: "6–9%", label: "food-truck net margin", source: "owner-run · vs restaurants ~1–3% · Toast / Harvest", hue: "--teal", confidence: "estimate" },
  { value: "64%", count: 64, suffix: "%", label: "value local sourcing", source: "the #1 2025 trend · Nat'l Restaurant Assoc.", hue: "--brass", confidence: "sourced" },
  { value: "+32%", count: 32, prefix: "+", suffix: "%", label: "YouTube food views YoY", source: "4th-largest category, Q1 2025 · Pixability", hue: "--blue", confidence: "sourced" },
  { value: "99%", count: 99, suffix: "%", label: "top food channels are creators", source: "1% are brands · Pixability", hue: "--coral", confidence: "sourced" },
  { value: "email ≫ social", label: "owned vs rented conversion", source: "owned email converts several × better · benchmarks", hue: "--teal", confidence: "estimate" },
];
const why = [
  ["Why a truck", "Low startup vs brick-and-mortar, far better margins, and it moves to the crowd. The gold-rush phase is over — the truck count's flattened — so operator quality wins now. That's the opening."],
  ["Why local", "Local sourcing is the #1 restaurant trend and what Millennials + Gen Z expect. Spokane sits in farm country — Green Bluff, the Palouse, grass-fed ranches, LINC Foods. The supply chain is the story."],
  ["Why media", "Food is the 4th-biggest thing on YouTube and 99% of the winners are individuals, not brands. A documented build compounds into an audience no competitor can buy."],
  ["Why the list", "Owned email converts several times better than rented social, with far higher engagement — and we own it outright. No algorithm, no de-platforming. The newsletter is the asset."],
];
---
<Base title="The Numbers — SlicedLabs" description="Why we're building what we're building — the real market data behind a PNW food + media + marketing company. Sourced, with the honest caveats.">
  <section class="wrap section">
    <p class="mono" data-reveal>the data · why we chose this</p>
    <h1 class="t-h1" data-reveal style="--i:1;"><span class="blend-text">The Numbers</span></h1>
    <hr class="blade" data-reveal style="--i:2; max-width:16rem; margin:1.4rem 0 0;" />
    <p data-reveal style="--i:3; font-size:var(--step-1); color:var(--muted); max-width:46rem; margin-top:1.4rem;">
      No pitch — here's the data we're betting on, sourced and unspun. The case for a PNW food truck, a food channel, and an owned list.
    </p>
  </section>

  <section class="wrap" aria-label="Key statistics" style="padding-block:1rem 2rem;" data-reveal>
    <Infographic ratio="auto" glowSafe="0%" label="The market case — sourced figures and honest estimates behind the bet">
      <InfoFigure variant="kpi-grid" cells={cells} />
      <p slot="caption" class="mono" style="text-align:center; color:var(--muted); margin:0;">
        solid rail = sourced · dashed rail = estimate / benchmark
      </p>
    </Infographic>
  </section>

  <section class="wrap" aria-labelledby="why" style="padding-block:2rem;">
    <h2 id="why" class="mono" data-reveal style="color:var(--muted); margin-bottom:1rem;">the choices, explained</h2>
    <div class="bento">
      {why.map(([h, d], i) => (
        <article class="glass island col-3" data-reveal style={`--i:${i}`}>
          <h3 style="font-size:1.3rem; margin:0 0 .4rem;"><span class="blend-text">{h}</span></h3>
          <p style="color:var(--muted); margin:0;">{d}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="wrap" style="padding-block:1rem 2rem;">
    <article class="glass island" data-reveal style="border-left:3px solid; border-image:var(--blend) 1;">
      <p class="mono" style="margin:0 0 .5rem;">the honest caveats (because we don't fake it)</p>
      <p style="color:var(--muted); margin:0;">
        Spokane isn't on a current "best food city" list — it's a <em>growing</em> scene with real, ambitious chefs — enough for a truck to land. The "consumers pay 34% more for local" stat is a stated ceiling; people pay less at the register than they say. And "build-in-public" has no clean headline number — we lead with the proof, not a borrowed stat. Full sourcing lives in the repo's <code>research/</code>.
      </p>
    </article>
  </section>

  <section class="wrap" style="text-align:center; padding-block:1rem 2rem;">
    <a class="btn" href="/free" data-reveal>Get the receipts →</a>
  </section>
</Base>
