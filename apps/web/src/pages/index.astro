---
// SlicedLabs · studio · © 2026 SlicedLabs — Home
import Base from "../layouts/Base.astro";
import Newsletter from "../components/Newsletter.astro";
import HeroPass from "../components/HeroPass.astro";
import ScrollScene from "../components/ScrollScene.astro";
import Infographic from "../components/Infographic.astro";
import InfoFigure from "../components/InfoFigure.astro";
import PersonalizedSections from "../components/PersonalizedSections.astro";
import { organizationLd } from "../lib/brand";

const orgLd = organizationLd(Astro.site?.href ?? "https://slicedlabs.io");

const pillars = [
  { k: "Food", t: "the empire", d: "The truck, then the lot, the venue, an owned commissary, the homestead. It makes the money — and the content.", tag: "make" },
  { k: "Media", t: "the proof", d: "YouTube is home base. The build documentary, repurposed across every surface, with the real numbers shown.", tag: "show" },
  { k: "Marketing", t: "the leverage", d: "The funnel and the offer ladder — the Atomise Machine, Own The List, Sell Without Sleaze — sold by living them.", tag: "compound" },
];
const principles = [
  ["Show the machine, not the dream.", "Everyone sells the dream. We show the machine — the ~$85k budget, the permit list, the real failures."],
  ["Buy the commodity, build only the edge.", "Rent the editor, scheduler, store, CRM. Build the one thing no subscription gives you: your own pipeline."],
  ["Ship one thing, all the way.", "Huge dreams diffuse into nothing unless the first thing reaches a real sale. Focus is how the vision gets built."],
  ["Sequence, don't scatter.", "Truck → first lot → property + commissary → homestead → skills center. Don't start phase N+1 until N throws off cash."],
];
const climb = ["Brand + the channel", "One truck", "The first lot", "Venue + owned commissary", "The homestead", "The skills center"];
---
<Base jsonLd={orgLd}>
  {/* HERO — "THE PASS": the receipts staged in Z-depth. LCP = the focal lockup. */}
  <HeroPass />

  <ScrollScene />

  <!-- WHAT WE STAND ON — the craft infographic (Infographic shell → no-cutoff donut of the
       3 real product lines, with an orbiting glow tracer). The caption/legend live in NORMAL
       FLOW below the figure (never an overlay), so nothing is clipped or obscured. -->
  <section class="wrap section" aria-labelledby="craft">
    <h2 id="craft" class="mono" data-reveal style="color:var(--muted); margin-bottom:1rem;">what we stand on</h2>
    <article class="glass glass-ultra craft-card" data-reveal>
      <Infographic
        ratio="auto"
        label="Three lines we'd stake our name on — cutting boards (on the bench), aprons (in the works), chef coats (sketching)"
      >
        <InfoFigure
          variant="ledger"
          stat="3"
          statLabel="lines on the bench"
          stamp="pre-launch"
          rows={[
            { label: "Cutting Boards", material: "black walnut · maple", hue: "--coral", status: "on the bench", stage: 3 },
            { label: "Aprons", material: "full-grain leather", hue: "--brass", status: "in the works", stage: 2 },
            { label: "Chef Coats", material: "cotton twill", hue: "--teal", status: "sketching", stage: 1 },
          ]}
        />
        <div slot="caption" class="craft-cap">
          <h3 class="t-h2" style="margin:0;">Tools we'd stake our name on.</h3>
          <p class="craft-sub">Three lines, made by hand to outlast the trend cycle. None shipped yet — you'll watch each one get made. <a href="/shop" class="craft-link">See the bench →</a></p>
        </div>
      </Infographic>
    </article>
  </section>

  <!-- THREE PILLARS — bento of glass islands, assembling on scroll -->
  <section class="wrap" aria-labelledby="pillars" style="padding-block:2rem;">
    <h2 id="pillars" class="mono" data-reveal style="color:var(--muted); margin-bottom:1rem;">one company, three limbs</h2>
    {/* connector tracer — a brand-spectrum spine tying the three limbs (food·media·marketing)
        into one company; nodes align over the three columns, a runner-tracer sweeps across.
        Decorative (the cards carry the content); gated on-screen via .is-live + reduced-motion. */}
    <div class="pillars-connector info-connector" aria-hidden="true" data-reveal>
      <svg class="pc-svg" viewBox="0 0 100 4" preserveAspectRatio="none" focusable="false"><line class="pc-runner" x1="2" y1="2" x2="98" y2="2" pathLength="1" /></svg>
      <span class="pc-node" style="left:16.66%; --c:var(--coral);"></span>
      <span class="pc-node" style="left:50%; --c:var(--teal);"></span>
      <span class="pc-node" style="left:83.33%; --c:var(--brass);"></span>
    </div>
    <div class="bento">
      {pillars.map((p, i) => (
        <article class="glass island col-2" data-reveal style={`--i:${i}`}>
          <span class="tag">{p.tag}</span>
          <h3 style="font-size:1.9rem; margin:.8rem 0 .1rem;"><span class="blend-text">{p.k}</span></h3>
          <p class="mono" style="margin:0 0 .6rem;">{p.t}</p>
          <p style="color:var(--muted); margin:0;">{p.d}</p>
        </article>
      ))}
    </div>
  </section>

  {/* WHERE TO NEXT — a wayfinding row that reorders to the visitor's affinity (local, no LLM) */}
  <PersonalizedSections />

  <!-- PRINCIPLES — the depth (what the books taught, lived) -->
  <section class="wrap section" aria-labelledby="principles">
    <h2 class="t-h1" id="principles" data-reveal style="margin-bottom:.4rem;">The principles we actually run.</h2>
    <p data-reveal style="color:var(--muted); max-width:42rem; margin:0 0 1.6rem;">Not theory. The operating laws behind every decision — earned, then lived on camera.</p>
    <div class="bento">
      {principles.map(([h, d], i) => (
        <article class="glass island col-3" data-reveal style={`--i:${i}`}>
          <h3 style="font-size:1.25rem; margin:0 0 .4rem;">{h}</h3>
          <p style="color:var(--muted); margin:0;">{d}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- THE CLIMB — the sequence -->
  <section class="wrap" aria-labelledby="climb" style="padding-block:2rem;">
    <h2 id="climb" class="mono" data-reveal style="color:var(--muted); margin-bottom:1rem;">the climb (you are here → phase 0)</h2>
    <div data-reveal>
      <Infographic ratio="auto" glowSafe="0%" label="The build sequence — six phases; you are here at phase 0 (brand + the channel)">
        <InfoFigure variant="ladder" steps={climb} />
      </Infographic>
    </div>
  </section>

  <!-- WHAT WE GIVE BACK — the mission arms (built as the business throws off cash) -->
  <section class="wrap" aria-labelledby="mission" style="padding-block:2rem;">
    <h2 id="mission" class="mono" data-reveal style="color:var(--muted); margin-bottom:1rem;">what we give back</h2>
    <div class="bento">
      <a href="/freshsave" class="glass island col-3" data-reveal style="text-decoration:none; display:block; border-color:color-mix(in oklab, var(--freshsave) 30%, var(--stroke));">
        <span class="tag" style="color:var(--freshsave); border-color:var(--freshsave);">FreshSave</span>
        <h3 style="font-size:1.5rem; margin:.7rem 0 .3rem;">Fight food waste.</h3>
        <p style="color:var(--muted); margin:0;">Teach the skill, publish our own numbers, and amplify the orgs already doing the work. <span style="color:var(--freshsave);">See the plan →</span></p>
      </a>
      <a href="/community" class="glass island col-3" data-reveal style="--i:1; text-decoration:none; display:block; border-color:color-mix(in oklab, var(--community) 30%, var(--stroke));">
        <span class="tag" style="color:var(--community); border-color:var(--community);">Community</span>
        <h3 style="font-size:1.5rem; margin:.7rem 0 .3rem;">Show up local.</h3>
        <p style="color:var(--muted); margin:0;">Spokane first — markets, inclusive hiring, and sponsorships starting with autism support. <span style="color:var(--community);">How we help →</span></p>
      </a>
    </div>
  </section>

  <div class="wrap"><Newsletter /></div>

  <section class="wrap" style="text-align:center; padding-block:2.5rem 1rem;">
    <p class="mono" data-reveal style="margin-bottom:.9rem;">free · no catch · just the receipts</p>
    <a class="btn btn-ghost" href="/free" data-reveal>Grab the free drops →</a>
    <hr class="blade center" data-reveal style="max-width:10rem; margin:2.6rem auto 1rem;" />
    <p class="mono">build it in public</p>
  </section>

  <style>
    /* "what we stand on" craft card — the Infographic shell flows the donut figure over a
       caption/legend in normal flow (no overlay → no cutoffs). */
    .craft-card { padding: clamp(1.4rem, 3.5vw, 2.4rem); }
    .craft-cap { display: grid; gap: .7rem; justify-items: center; text-align: center; }
    .craft-sub { color: var(--muted); margin: 0; max-width: 42rem; }
    /* AA on both themes (raw --mark fails on cream); --mark underline comes from global a{} */
    .craft-link { color: var(--ink); font-weight: 600; }

    /* pillars connector — a brand-spectrum spine + 3 hue nodes + a runner-tracer */
    .pillars-connector { position: relative; height: .8rem; margin: .1rem 0 1.4rem; }
    .pillars-connector::before {
      content: ""; position: absolute; left: 1%; right: 1%; top: 50%; height: 2px;
      transform: translateY(-50%); background: var(--blend); opacity: .5; border-radius: 2px;
    }
    .pc-svg { position: absolute; inset: 0; width: 100%; height: 100%; overflow: visible; }
    .pc-runner {
      fill: none; stroke: color-mix(in oklab, #fff 55%, var(--specular)); stroke-width: 2;
      stroke-linecap: round; stroke-dasharray: .1 .9; opacity: 0;
    }
    /* the runner appears + sweeps only while on screen (.is-live, toggled by the figure
       observer); brightens with scroll velocity. Composite/gated, frozen under reduced-motion. */
    .info-connector.is-live .pc-runner { opacity: calc(.6 + var(--scroll-vel, 0) * .4); animation: pc-run 4s linear infinite; }
    @keyframes pc-run { from { stroke-dashoffset: .1; } to { stroke-dashoffset: -.9; } }
    .pc-node {
      position: absolute; top: 50%; width: .72rem; height: .72rem; border-radius: 50%; z-index: 1;
      transform: translate(-50%, -50%); background: var(--bg-alt); border: 2px solid var(--c);
      box-shadow: 0 0 8px color-mix(in oklab, var(--c) 50%, transparent);
    }
    @media (prefers-reduced-motion: reduce) { .info-connector.is-live .pc-runner { animation: none; opacity: .5; } }
    @media (max-width: 720px) { .pillars-connector { display: none; } }
  </style>
</Base>
