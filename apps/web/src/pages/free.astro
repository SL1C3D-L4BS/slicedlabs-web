---
// SlicedLabs · studio · © 2026 SlicedLabs — Free Drops (the lead magnets)
import Base from "../layouts/Base.astro";
import LeadForm from "../components/LeadForm.astro";
const drops = [
  { k: "The $85k Truck Budget", d: "A real line-item Spokane startup budget — permits, commissary, the truck, the buffer. The numbers nobody shows.", tag: "the budget", slug: "the-85k-truck-budget" },
  { k: "The Atomise Machine", d: "Film once, publish six. Our content-repurposing system as a one-page playbook.", tag: "playbook", slug: "the-atomise-machine" },
  { k: "The Build Receipts", d: "The running numbers — budget spent, permits filed, first sales. Updated as the build moves.", tag: "living doc", slug: "the-build-receipts" },
];
---
<Base title="Free Drops — SlicedLabs" description="The real $85k truck budget, the Atomise Machine, and the running build receipts — free. The honest move: show the numbers.">
  <section class="wrap section">
    <p class="mono" data-reveal>free · no catch · just the receipts</p>
    <h1 class="t-h1" data-reveal style="--i:1;"><span class="blend-text">Take the receipts.</span></h1>
    <hr class="blade" data-reveal style="--i:2; max-width:18rem; margin:1.4rem 0 0;" />
    <p data-reveal style="--i:3; font-size:var(--step-1); color:var(--muted); max-width:46rem; margin-top:1.4rem;">
      We show the machine. These three drops are the proof — the real budget, the marketing system, and the live numbers. Free, because the receipts <em>are</em> the marketing.
    </p>
  </section>

  <section class="wrap" style="padding-block:1rem 2rem;">
    <div class="bento">
      {drops.map((d, i) => (
        <a href={`/free/${d.slug}`} class="glass island col-2" data-reveal style={`--i:${i}; text-decoration:none; display:block;`}>
          <span class="tag">{d.tag}</span>
          <h3 style="font-size:1.3rem; margin:.6rem 0 .3rem;"><span class="blend-text">{d.k}</span></h3>
          <p style="color:var(--muted); margin:0 0 .5rem;">{d.d}</p>
          <span class="mono" style="font-size:.72rem;">read it →</span>
        </a>
      ))}
    </div>
    <article class="glass glass-ultra island" data-reveal style="text-align:center; margin-top:1.6rem;">
      <h2 class="t-h3" style="margin:0 0 .5rem;">One email. All three.</h2>
      <p style="color:var(--muted); max-width:36rem; margin:0 auto 1.1rem;">We mail the drops and add you to the weekly receipts. Unsubscribe anytime — no sleaze.</p>
      <LeadForm source="vault" anchor="free" cta="Send me all three →" />
    </article>
  </section>
</Base>
