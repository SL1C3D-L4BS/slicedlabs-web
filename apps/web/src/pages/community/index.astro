---
// SlicedLabs · studio · © 2026 SlicedLabs — Community (outreach + sponsorships index)
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import LeadForm from "../../components/LeadForm.astro";

const entries = (
  await getCollection("community", ({ data }) => (import.meta.env.PROD ? !data.draft : true))
).sort((a, b) => +b.data.date - +a.data.date);

const KIND_LABEL: Record<string, string> = {
  outreach: "outreach",
  sponsorship: "sponsorship",
  autism: "inclusion",
  partner: "partner",
};
---
<Base
  title="Community — local outreach & sponsorships · SlicedLabs"
  description="A food business is a neighbor first. How SlicedLabs shows up for the Inland NW — markets, schools, inclusive hiring, and sponsorships starting with autism support."
>
  <section class="wrap section">
    <p class="mono" data-reveal style="color:var(--community);">neighbors first</p>
    <h1 class="t-h1" data-reveal style="--i:1; margin:.3rem 0 0;"><span class="blend-text">Community</span></h1>
    <hr data-reveal style="--i:2; height:4px; border:0; border-radius:999px; max-width:14rem; margin:1.4rem 0 1.2rem; background:var(--community);" />
    <p data-reveal style="--i:3; font-size:var(--step-1); color:var(--muted); max-width:46rem;">
      Buy local and say so. Cook in the open at the markets. Put real seats and real dollars behind the people who feed and build this place — starting with autism support and an inclusive kitchen. Sequenced honestly against what the business can carry, and shown in public.
    </p>
  </section>

  <section class="wrap" style="padding-block:clamp(1rem,3vw,2rem);">
    {entries.length === 0 && <p data-reveal style="color:var(--muted);">First entry lands soon.</p>}
    <div class="bento">
      {entries.map((e, i) => (
        <a href={`/community/${e.id}`} class="glass island col-3" data-reveal style={`--i:${i}; text-decoration:none; display:block;`}>
          <p class="mono" style="color:var(--community); margin:0;">{KIND_LABEL[e.data.kind] ?? e.data.kind}</p>
          <h2 style={`font-size:1.3rem; margin:.3rem 0 .4rem; view-transition-name:vtc-${e.id};`}>{e.data.title}</h2>
          <p style="color:var(--muted); margin:0;">{e.data.summary}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="wrap section" style="text-align:center;">
    <h2 class="t-h3" data-reveal style="margin:0 0 .4rem;">Run a local org? Let's build something.</h2>
    <p data-reveal style="color:var(--muted); max-width:34rem; margin:0 auto 1.4rem;">Outreach, sponsorship, or an inclusive-hiring fit in the Inland NW — reach out early and we'll find the overlap.</p>
    <div data-reveal><LeadForm source="sponsorship" cta="Start the conversation →" placeholder="you@org.org" /></div>
  </section>
</Base>
