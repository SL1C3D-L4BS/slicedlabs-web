---
// SlicedLabs · studio · © 2026 SlicedLabs — The Truck (live status + map)
export const prerender = false;
import Base from "../layouts/Base.astro";
import Newsletter from "../components/Newsletter.astro";
import CateringForm from "../components/CateringForm.astro";
import { getServerSupabase } from "../lib/supabase";

// Live status (RLS: public read). SSR the latest; the client script keeps it live.
const supabase = getServerSupabase(Astro.cookies, Astro.request);
const { data: truck } = await supabase
  .from("truck_status")
  .select("status, label, message, lat, lng, next_stop, updated_at")
  .eq("id", 1)
  .maybeSingle();

const MAPBOX = import.meta.env.PUBLIC_MAPBOX_TOKEN;
const STATUS_LABEL: Record<string, string> = {
  rolling: "Rolling now",
  parked: "Parked & serving",
  heading: "On the move",
  closed: "Not open right now",
};
const st = truck?.status ?? "closed";
const open = st !== "closed";
const dotColor = open ? "var(--teal)" : "var(--muted)";
const hasCoords = typeof truck?.lat === "number" && typeof truck?.lng === "number";

const menu = [
  { k: "The rotating drop", d: "A chaos menu — a tight set that changes with what's good and local that week. Scarcity by design." },
  { k: "Sourced local-first", d: "The farms and breweries behind the food, named on the board. Buy the commodity, build the relationship." },
  { k: "Priced in the open", d: "The plate cost, the margin, the why — shown on camera. The receipts are the marketing." },
];
const steps = [
  ["Form the LLC + license", "WA Secretary of State (~$200), then the WA Business License / UBI from the Dept. of Revenue ($50)."],
  ["Plans to L&I", "Submit the unit plans to Labor & Industries early — the review can take 8+ weeks before a wrench turns."],
  ["Health permit + commissary", "Spokane Regional Health District plan review, and the daily commissary agreement the code requires (~$300–800/mo)."],
  ["Build → inspect → insignia", "Outfit the truck, then the L&I cover + final inspections earn the insignia. Then the Fire inspection — propane, hood, extinguishers."],
  ["Cards + manager", "Food Worker Cards for every handler ($10), plus one certified ServSafe manager per the 2023 rule."],
  ["Launch when it pays", "Permit in hand, we open when the numbers say go — not before. You'll see every figure."],
];
---
<Base title="The Truck — SlicedLabs" description="The chaos-menu food truck — the first rung of the climb. Built in public, opened when the receipts say go.">
  <section class="wrap" style="padding-block:clamp(2.5rem,7vw,4rem);">
    <p class="mono" data-reveal>the first rung · phase 1</p>
    <h1 data-reveal style="--i:1; font-size:clamp(2.4rem,8vw,4.6rem);"><span class="blend-text">The Truck</span></h1>
    <hr class="blade" data-reveal style="--i:2; max-width:18rem; margin:1.4rem 0 0;" />
    <p data-reveal style="--i:3; font-size:clamp(1.1rem,2.4vw,1.4rem); color:var(--muted); max-width:46rem; margin-top:1.4rem;">
      One truck, a rotating chaos menu, and every number shown. It's where the empire starts — the first real money, and the first real content.
    </p>
    <div data-reveal style="--i:4; display:flex; gap:.8rem; flex-wrap:wrap; margin-top:1.8rem;">
      <a class="btn" href="#catering">Book the truck →</a>
      <a class="btn btn-ghost" href="/build">Follow the build</a>
    </div>
  </section>

  {/* LIVE STATUS — SSR'd from truck_status, kept live by Supabase Realtime */}
  <section class="wrap" style="padding-block:1rem 2rem;">
    <article class="glass glass-ultra island" data-reveal data-truck-card style="text-align:center;">
      <div style="display:flex; align-items:center; gap:.6rem; justify-content:center;">
        <span
          data-truck-dot
          style={`width:.7rem; height:.7rem; border-radius:50%; background:${dotColor}; box-shadow:0 0 0 4px color-mix(in oklab, ${dotColor} 22%, transparent);`}
        ></span>
        <p class="mono" style="margin:0;">live truck status</p>
      </div>
      <h2 data-truck-status style="font-size:clamp(1.5rem,4vw,2.2rem); margin:.5rem 0 .2rem;">{STATUS_LABEL[st] ?? "Status"}</h2>
      {truck?.label && <p data-truck-label style="font-weight:600; margin:0 0 .3rem;">{truck.label}</p>}
      {!truck?.label && <p data-truck-label hidden style="font-weight:600; margin:0 0 .3rem;"></p>}
      <p data-truck-message style="color:var(--muted); max-width:40rem; margin:0 auto;">
        {truck?.message ?? "We never sell a future as a present. The day it opens, you'll have watched it happen."}
      </p>
      {truck?.next_stop && <p data-truck-next class="mono" style="margin:.7rem 0 0;">next stop — {truck.next_stop}</p>}
      {hasCoords && MAPBOX && (
        <div
          id="truck-map"
          data-lat={truck.lat}
          data-lng={truck.lng}
          style="height:340px; border-radius:var(--radius); margin-top:1.3rem; overflow:hidden; border:1px solid var(--stroke);"
        ></div>
      )}
      {hasCoords && !MAPBOX && (
        <p class="mono" style="color:var(--muted); margin-top:1rem;">live map appears once PUBLIC_MAPBOX_TOKEN is set</p>
      )}
    </article>
  </section>

  <section class="wrap" aria-labelledby="menu" style="padding-block:2rem;">
    <h2 id="menu" class="mono" data-reveal style="color:var(--muted); margin-bottom:1rem;">the menu, the concept</h2>
    <div class="bento">
      {menu.map((m, i) => (
        <article class="glass island col-2" data-reveal style={`--i:${i}`}>
          <h3 style="font-size:1.4rem; margin:0 0 .3rem;"><span class="blend-text">{m.k}</span></h3>
          <p style="color:var(--muted); margin:0;">{m.d}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="wrap" aria-labelledby="path" style="padding-block:2rem;">
    <h2 id="path" data-reveal style="font-size:clamp(1.6rem,4.5vw,2.6rem); margin-bottom:.3rem;">The path to opening.</h2>
    <p data-reveal style="color:var(--muted); max-width:42rem; margin:0 0 1.4rem;">Spokane, in order. No skipped steps — the boring sequence is the moat.</p>
    <ol style="list-style:none; padding:0; margin:0; display:grid; gap:.8rem;">
      {steps.map(([h, d], i) => (
        <li class="glass island" data-reveal style={`--i:${i}; display:flex; gap:1rem; align-items:baseline;`}>
          <span class="blend-text" style="font-family:var(--font-display); font-weight:800; font-size:1.3rem;">{String(i + 1).padStart(2, "0")}</span>
          <div><h3 style="font-size:1.15rem; margin:0 0 .2rem;">{h}</h3><p style="color:var(--muted); margin:0;">{d}</p></div>
        </li>
      ))}
    </ol>
  </section>

  <section id="catering" class="wrap" style="padding-block:2rem;">
    <article class="glass glass-focal island" data-reveal>
      <p class="mono" style="text-align:center;">the catering lever</p>
      <h2 style="font-size:clamp(1.5rem,4vw,2.2rem); margin:.3rem 0 .4rem; text-align:center;">Book the truck for your event.</h2>
      <p style="color:var(--muted); max-width:40rem; margin:0 auto 1.4rem; text-align:center;">Breweries, markets, private events — catering is how the truck earns between services. Tell us the date; we'll send the build status and a quote the moment we're rolling.</p>
      <div style="max-width:34rem; margin:0 auto;"><CateringForm /></div>
    </article>
  </section>

  <div class="wrap"><Newsletter /></div>
</Base>

<script>
  // Live truck status — Supabase Realtime updates the SSR'd card + the Mapbox pin.
  import { createClient } from "@supabase/supabase-js";
  const SB_URL = import.meta.env.PUBLIC_SUPABASE_URL;
  const SB_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
  const MAPBOX = import.meta.env.PUBLIC_MAPBOX_TOKEN;
  const STATUS_LABEL: Record<string, string> = {
    rolling: "Rolling now",
    parked: "Parked & serving",
    heading: "On the move",
    closed: "Not open right now",
  };

  const card = document.querySelector("[data-truck-card]");
  if (card && SB_URL && SB_KEY) {
    let map: any = null;
    let marker: any = null;
    const mapEl = document.getElementById("truck-map");

    async function ensureMapbox() {
      if ((window as any).mapboxgl) return (window as any).mapboxgl;
      if (!document.querySelector("link[data-mapbox]")) {
        const l = document.createElement("link");
        l.rel = "stylesheet";
        l.href = "https://api.mapbox.com/mapbox-gl-js/v3.9.0/mapbox-gl.css";
        l.setAttribute("data-mapbox", "1");
        document.head.appendChild(l);
      }
      await new Promise<void>((res, rej) => {
        const s = document.createElement("script");
        s.src = "https://api.mapbox.com/mapbox-gl-js/v3.9.0/mapbox-gl.js";
        s.onload = () => res();
        s.onerror = () => rej(new Error("mapbox load failed"));
        document.head.appendChild(s);
      });
      return (window as any).mapboxgl;
    }

    async function initMap(lat: number, lng: number) {
      if (!MAPBOX || !mapEl || map) return;
      try {
        const gl = await ensureMapbox();
        gl.accessToken = MAPBOX;
        map = new gl.Map({ container: mapEl, style: "mapbox://styles/mapbox/dark-v11", center: [lng, lat], zoom: 13 });
        marker = new gl.Marker({ color: "#CB6820" }).setLngLat([lng, lat]).addTo(map);
      } catch {
        /* leave the fallback */
      }
    }

    function paint(t: any) {
      if (!t) return;
      const setText = (sel: string, val: any) => {
        const el = card!.querySelector(sel) as HTMLElement | null;
        if (el && val != null) {
          el.textContent = String(val);
          el.hidden = String(val).length === 0;
        }
      };
      if (t.status) setText("[data-truck-status]", STATUS_LABEL[t.status] ?? "Status");
      setText("[data-truck-label]", t.label ?? "");
      setText("[data-truck-message]", t.message ?? "");
      const dot = card!.querySelector("[data-truck-dot]") as HTMLElement | null;
      if (dot && t.status) {
        const c = t.status === "closed" ? "var(--muted)" : "var(--teal)";
        dot.style.background = c;
        dot.style.boxShadow = `0 0 0 4px color-mix(in oklab, ${c} 22%, transparent)`;
      }
      if (typeof t.lat === "number" && typeof t.lng === "number") {
        if (!map) initMap(t.lat, t.lng);
        else if (marker) {
          marker.setLngLat([t.lng, t.lat]);
          map.easeTo({ center: [t.lng, t.lat] });
        }
      }
    }

    if (mapEl?.dataset.lat && mapEl?.dataset.lng) {
      initMap(Number(mapEl.dataset.lat), Number(mapEl.dataset.lng));
    }

    const sb = createClient(SB_URL, SB_KEY);
    sb.channel("truck-status")
      .on("postgres_changes", { event: "*", schema: "public", table: "truck_status" }, (payload: any) =>
        paint(payload.new),
      )
      .subscribe();
  }
</script>
