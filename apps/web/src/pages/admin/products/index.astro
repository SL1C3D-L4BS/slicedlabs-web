---
// SlicedLabs · commerce · © 2026 SlicedLabs — Admin: products list + create
export const prerender = false;
import Base from "../../../layouts/Base.astro";
import { getServerSupabase, createServiceSupabase } from "../../../lib/supabase";
import { isAdmin } from "../../../lib/admin";

const supabase = getServerSupabase(Astro.cookies, Astro.request);
const {
  data: { user },
} = await supabase.auth.getUser();
if (!user) return Astro.redirect("/account/login?next=" + encodeURIComponent(Astro.url.pathname));
if (!isAdmin(user.email)) return new Response("Forbidden", { status: 403 });

let svc;
try {
  svc = createServiceSupabase();
} catch {
  /* SUPABASE_SERVICE_ROLE_KEY not set — render a friendly notice below */
}

type ProductRow = {
  id: string;
  slug: string;
  title: string;
  status: string;
  fulfillment_type: string;
  created_at: string;
  variants: { id: string }[] | null;
};

let products: ProductRow[] = [];
let loadError: string | null = null;
if (svc) {
  const { data, error } = await svc
    .from("products")
    .select("id,slug,title,status,fulfillment_type,created_at,variants(id)")
    .order("created_at", { ascending: false });
  if (error) loadError = error.message;
  else products = (data as ProductRow[]) ?? [];
}

const PRODUCT_STATUS = ["draft", "active", "archived"];
const FULFILLMENT = ["pod", "in_house", "digital"];

const statusHue = (st: string): string => {
  switch (st) {
    case "active":
      return "var(--teal)";
    case "archived":
      return "var(--muted)";
    default:
      return "var(--coral)"; // draft
  }
};

const fmtDate = (iso: string) =>
  new Date(iso).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });

const err = Astro.url.searchParams.get("err");
---

<Base
  title="Admin — Products · SlicedLabs"
  description="SlicedLabs operator cockpit — products."
  noindex={true}
>
  <section class="wrap" style="padding-block:clamp(2rem,6vw,3rem)">
    <div
      style="display:flex; align-items:baseline; gap:1rem; flex-wrap:wrap; justify-content:space-between;"
    >
      <div>
        <p class="mono" data-reveal>operator cockpit</p>
        <h1 data-reveal style="--i:1; font-size:clamp(2rem,6vw,3.4rem); margin:.2rem 0 0;">
          <span class="blend-text">Products</span>
        </h1>
      </div>
      <a href="/admin" class="btn btn-ghost" data-reveal style="--i:2;">← Orders</a>
    </div>

    {
      err && (
        <p class="mono" data-reveal style="color:var(--coral); margin-top:1rem;">
          {err}
        </p>
      )
    }

    {
      !svc && (
        <div class="glass island" data-reveal style="margin-top:1.6rem;">
          <h2 style="font-size:1.2rem; margin:0 0 .4rem;">Service role key not set</h2>
          <p style="color:var(--muted); margin:0;">
            Set <code>SUPABASE_SERVICE_ROLE_KEY</code> so the cockpit can read drafts and write
            products.
          </p>
        </div>
      )
    }

    {
      svc && (
        <>
          {/* ---- new product ------------------------------------------------ */}
          <div class="glass island" data-reveal style="margin-top:1.6rem;">
            <h2 style="font-size:1.25rem; margin:0 0 1rem;">New product</h2>
            <form
              method="POST"
              action="/api/admin/product"
              style="display:flex; flex-direction:column; gap:.8rem;"
            >
              <input type="hidden" name="action" value="create" />
              <div class="row2">
                <label>
                  <span class="mono">Title *</span>
                  <input class="fld" type="text" name="title" required placeholder="The chevron tee" />
                </label>
                <label>
                  <span class="mono">Slug (optional)</span>
                  <input class="fld" type="text" name="slug" placeholder="auto from title" />
                </label>
              </div>
              <label>
                <span class="mono">Description</span>
                <textarea class="fld" name="description" placeholder="What it is, who it's for."></textarea>
              </label>
              <label style="max-width:18rem;">
                <span class="mono">Fulfillment</span>
                <select class="fld" name="fulfillment_type">
                  {FULFILLMENT.map((f) => (
                    <option value={f} selected={f === "pod"}>
                      {f}
                    </option>
                  ))}
                </select>
              </label>

              <fieldset style="border:1px solid var(--stroke); border-radius:var(--radius); padding:1rem; margin:0;">
                <legend class="mono" style="padding:0 .4rem;">First variant</legend>
                <div class="row2">
                  <label>
                    <span class="mono">Variant title</span>
                    <input class="fld" type="text" name="variant_title" placeholder="Default" />
                  </label>
                  <label>
                    <span class="mono">Price (USD) *</span>
                    <input class="fld" type="number" name="price" step="0.01" min="0" required placeholder="28.00" />
                  </label>
                  <label>
                    <span class="mono">SKU (optional)</span>
                    <input class="fld" type="text" name="sku" placeholder="TEE-CHV-M" />
                  </label>
                  <label>
                    <span class="mono">Printful variant id (optional)</span>
                    <input class="fld" type="text" name="printful_variant_id" placeholder="sync_variant_id" />
                  </label>
                </div>
              </fieldset>

              <div>
                <button type="submit" class="btn">Create product</button>
              </div>
            </form>
          </div>

          {/* ---- products table -------------------------------------------- */}
          {loadError && (
            <p class="mono" data-reveal style="color:var(--coral); margin-top:1.4rem;">
              Couldn't load products: {loadError}
            </p>
          )}

          <div
            data-reveal
            style="--i:1; margin-top:1.8rem; overflow-x:auto; border:1px solid var(--stroke); border-radius:var(--radius);"
          >
            <table style="width:100%; border-collapse:collapse; min-width:48rem; font-size:.92rem;">
              <thead>
                <tr style="text-align:left;">
                  {["Title", "Slug", "Status", "Fulfillment", "Variants", "Created", "Set status"].map(
                    (h) => (
                      <th
                        class="mono"
                        style="padding:.7rem .8rem; border-bottom:1px solid var(--stroke); white-space:nowrap;"
                      >
                        {h}
                      </th>
                    ),
                  )}
                </tr>
              </thead>
              <tbody>
                {products.length === 0 && (
                  <tr>
                    <td colspan="7" style="padding:1.2rem .8rem; color:var(--muted);">
                      No products yet — create one above.
                    </td>
                  </tr>
                )}
                {products.map((p) => (
                  <tr style="border-bottom:1px solid var(--stroke);">
                    <td style="padding:.7rem .8rem;">
                      <a href={`/admin/products/${p.id}`} style="color:var(--mark);">
                        {p.title}
                      </a>
                    </td>
                    <td style="padding:.7rem .8rem; color:var(--muted); white-space:nowrap;">
                      {p.slug}
                    </td>
                    <td style="padding:.7rem .8rem;">
                      <span class="tag" style={`color:${statusHue(p.status)}; border-color:${statusHue(p.status)};`}>
                        {p.status}
                      </span>
                    </td>
                    <td style="padding:.7rem .8rem; white-space:nowrap;">{p.fulfillment_type}</td>
                    <td style="padding:.7rem .8rem;">{p.variants?.length ?? 0}</td>
                    <td style="padding:.7rem .8rem; white-space:nowrap; color:var(--muted);">
                      {fmtDate(p.created_at)}
                    </td>
                    <td style="padding:.7rem .8rem;">
                      <form
                        method="POST"
                        action="/api/admin/product"
                        style="display:flex; gap:.4rem; align-items:center;"
                      >
                        <input type="hidden" name="action" value="set-status" />
                        <input type="hidden" name="id" value={p.id} />
                        <label class="mono" for={`pst-${p.id}`} style="position:absolute; width:1px; height:1px; overflow:hidden; clip:rect(0 0 0 0);">
                          Status for {p.title}
                        </label>
                        <select id={`pst-${p.id}`} name="status" class="fld" style="width:auto; padding:.4rem .6rem;">
                          {PRODUCT_STATUS.map((st) => (
                            <option value={st} selected={st === p.status}>
                              {st}
                            </option>
                          ))}
                        </select>
                        <button type="submit" class="btn btn-ghost" style="padding:.45rem .8rem;">
                          Save
                        </button>
                      </form>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </>
      )
    }
  </section>
</Base>
