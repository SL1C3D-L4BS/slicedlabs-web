---
// SlicedLabs · commerce · © 2026 SlicedLabs — Admin cockpit: Orders
export const prerender = false;
import DashShell from "../../layouts/DashShell.astro";
import EmptyState from "../../components/EmptyState.astro";
import { createServiceSupabase } from "../../lib/supabase";
import { isAdmin } from "../../lib/admin";
import { formatMoney } from "../../lib/commerce/cart";

const { userId } = Astro.locals.auth();
if (!userId) return Astro.redirect("/account/login?next=" + encodeURIComponent(Astro.url.pathname));
const cu = await Astro.locals.currentUser();
if (!isAdmin(cu?.primaryEmailAddress?.emailAddress)) return new Response("Forbidden", { status: 403 });

let svc;
try {
  svc = createServiceSupabase();
} catch {
  /* SUPABASE_SERVICE_ROLE_KEY not set — render a friendly notice below */
}

const ORDER_STATUS = [
  "pending",
  "paid",
  "fulfilling",
  "shipped",
  "delivered",
  "refunded",
  "canceled",
];

type OrderRow = {
  id: string;
  email: string | null;
  status: string;
  total_cents: number;
  currency: string;
  fulfillment_type: string;
  printful_order_id: string | null;
  created_at: string;
};

let orders: OrderRow[] = [];
let loadError: string | null = null;
if (svc) {
  const { data, error } = await svc
    .from("orders")
    .select(
      "id,email,status,total_cents,currency,fulfillment_type,printful_order_id,created_at",
    )
    .order("created_at", { ascending: false })
    .limit(100);
  if (error) { loadError = "Couldn't load orders right now. Refresh, or check the Supabase connection."; console.error("[admin/orders]", error.message); }
  else orders = (data as OrderRow[]) ?? [];
}

// recurring-revenue signal — count of `member` entitlements (the KPI that compounds).
let memberCount = 0;
if (svc) {
  const { count } = await svc
    .from("entitlements")
    .select("id", { count: "exact", head: true })
    .eq("kind", "member");
  memberCount = count ?? 0;
}

const REVENUE_STATES = new Set(["paid", "fulfilling", "shipped", "delivered"]);
const ACTION_STATES = new Set(["paid", "fulfilling"]);
const totalOrders = orders.length;
const revenueCents = orders
  .filter((o) => REVENUE_STATES.has(o.status))
  .reduce((sum, o) => sum + (o.total_cents ?? 0), 0);
const revenueCurrency = orders.find((o) => REVENUE_STATES.has(o.status))?.currency ?? "usd";
const needsAction = orders.filter((o) => ACTION_STATES.has(o.status)).length;

// order status → SEMANTIC state for .tag-status[data-state] (color carries meaning):
// paid/delivered = success · fulfilling = in-progress · shipped = info · refunded/
// canceled = danger · pending = warning. No more coral-on-everything decoration.
const orderState = (st: string): string => {
  switch (st) {
    case "paid":
    case "delivered":
      return "success";
    case "fulfilling":
      return "progress";
    case "shipped":
      return "info";
    case "pending":
      return "warning";
    case "refunded":
    case "canceled":
      return "danger";
    default:
      return "neutral";
  }
};

const fmtDate = (iso: string) =>
  new Date(iso).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
---

<DashShell
  title="Orders — Admin · SlicedLabs"
  description="SlicedLabs operator cockpit — orders."
  section="admin"
  active="/admin"
  email={cu?.primaryEmailAddress?.emailAddress}
  crumbs={[{ label: "Orders" }]}
>
  <h1 class="dash-h1">Orders</h1>
  <p class="dash-sub">Every order, newest first. Update status + tracking inline.</p>

  {!svc && (
    <div class="dash-notice warn">
      <strong>Service role key not set.</strong>
      <p style="color:var(--muted); margin:.4rem 0 0;">
        Set <code>SUPABASE_SERVICE_ROLE_KEY</code> in the environment so the cockpit can
        read every order and write updates. Until then, this view is empty.
      </p>
    </div>
  )}

  {svc && loadError && (
    <div class="dash-notice danger">
      <p style="margin:0;">{loadError}</p>
    </div>
  )}

  {svc && !loadError && (
    <>
      <div class="kpi-grid">
        <div class="kpi">
          <span class="kpi-k">total orders</span>
          <span class="kpi-n">{totalOrders}</span>
        </div>
        <div class="kpi">
          <span class="kpi-k">revenue · paid &amp; up</span>
          <span class="kpi-n">{formatMoney(revenueCents, revenueCurrency)}</span>
        </div>
        <div class="kpi">
          <span class="kpi-k">needs action</span>
          <span class="kpi-n">{needsAction}</span>
        </div>
        <div class="kpi">
          <span class="kpi-k">members</span>
          <span class="kpi-n">{memberCount}</span>
        </div>
      </div>

      {orders.length === 0 ? (
        <EmptyState
          title="No orders yet"
          detail="When a customer checks out, their order lands here — ready to fulfil and track."
          ctaHref="/shop"
          ctaLabel="View the shop"
        />
      ) : (
        <div class="dash-table-wrap">
          <table class="dash-table">
            <thead>
              <tr>
                {["Date", "Email", "Fulfillment", "Status", "Total", "Printful", "Action"].map((h) => (
                  <th class={h === "Total" ? "num" : undefined}>{h}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {orders.map((o) => (
                <tr>
                  <td class="muted" style="white-space:nowrap;">{fmtDate(o.created_at)}</td>
                  <td>{o.email || "—"}</td>
                  <td style="white-space:nowrap;">{o.fulfillment_type}</td>
                  <td>
                    <span class="tag-status" data-state={orderState(o.status)}>{o.status}</span>
                  </td>
                  <td class="num">{formatMoney(o.total_cents ?? 0, o.currency)}</td>
                  <td class="muted" style="white-space:nowrap;">{o.printful_order_id || "—"}</td>
                  <td>
                    <form method="POST" action="/api/admin/order-status" style="display:flex; gap:.4rem; align-items:center;">
                      <input type="hidden" name="order_id" value={o.id} />
                      <label class="mono" for={`st-${o.id}`} style="position:absolute; width:1px; height:1px; overflow:hidden; clip:rect(0 0 0 0);">
                        Status for order {o.id}
                      </label>
                      <select id={`st-${o.id}`} name="status" class="fld" style="width:auto; padding:.4rem 1.8rem .4rem .6rem;">
                        {ORDER_STATUS.map((st) => (
                          <option value={st} selected={st === o.status}>{st}</option>
                        ))}
                      </select>
                      {o.fulfillment_type === "in_house" && (
                        <input type="text" name="tracking_number" placeholder="tracking #" class="fld" style="width:7rem; padding:.4rem .5rem;" aria-label={`Tracking number for order ${o.id}`} />
                      )}
                      <button type="submit" class="btn btn-ghost btn-sm">Save</button>
                    </form>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </>
  )}
</DashShell>
