---
// SlicedLabs · commerce · © 2026 SlicedLabs — Admin cockpit: Vault assets
export const prerender = false;
import Base from "../../layouts/Base.astro";
import { getServerSupabase, createServiceSupabase } from "../../lib/supabase";
import { isAdmin } from "../../lib/admin";
import { VAULT_DROPS } from "../../lib/perks";

const supabase = getServerSupabase(Astro.cookies, Astro.request);
const {
  data: { user },
} = await supabase.auth.getUser();
if (!user) return Astro.redirect("/account/login?next=" + encodeURIComponent(Astro.url.pathname));
if (!isAdmin(user.email)) return new Response("Forbidden", { status: 403 });

let svc: ReturnType<typeof createServiceSupabase> | undefined;
try {
  svc = createServiceSupabase();
} catch {
  /* SUPABASE_SERVICE_ROLE_KEY not set — render a notice */
}

type FileRow = { name: string; size: number };
const drops: { ref: string; label: string; files: FileRow[] }[] = [];
if (svc) {
  for (const d of VAULT_DROPS) {
    const { data } = await svc.storage
      .from("vault")
      .list(d.ref_id, { limit: 100, sortBy: { column: "name", order: "asc" } });
    const files = (data ?? [])
      .filter((o) => o.id && !o.name.startsWith("."))
      .map((o) => ({ name: o.name, size: (o.metadata?.size as number) ?? 0 }));
    drops.push({ ref: d.ref_id, label: d.label, files });
  }
}

const fmtSize = (b: number) => (b >= 1e6 ? `${(b / 1e6).toFixed(1)} MB` : `${Math.max(1, Math.round(b / 1024))} KB`);
const err = Astro.url.searchParams.get("err");
const ok = Astro.url.searchParams.get("ok");
---
<Base title="Vault — Admin" description="Upload entitlement-gated vault assets." noindex={true}>
  <section class="wrap" style="padding-block:clamp(2.5rem,7vw,4rem);">
    <div
      data-reveal
      style="display:flex; justify-content:space-between; gap:1rem; flex-wrap:wrap; align-items:baseline; margin-bottom:1.4rem;"
    >
      <div>
        <p class="mono" style="margin:0;">cockpit</p>
        <h1 style="font-size:clamp(1.8rem,6vw,2.6rem); margin:.2rem 0 0;">
          <span class="blend-text">Vault drops</span>
        </h1>
      </div>
      <nav style="display:flex; gap:1.2rem; align-items:center;">
        <a href="/admin">Orders</a>
        <a href="/admin/products">Products</a>
      </nav>
    </div>

    {!svc && (
      <p class="glass island" data-reveal style="color:var(--coral);">
        Set <code>SUPABASE_SERVICE_ROLE_KEY</code> to manage vault files.
      </p>
    )}
    {ok && <p class="mono" data-reveal style="color:var(--teal); margin-bottom:1rem;">Saved.</p>}
    {err && <p class="mono" data-reveal style="color:var(--coral); margin-bottom:1rem;">{err}</p>}

    {svc &&
      drops.map((d, i) => (
        <article class="glass island" data-reveal style={`--i:${i}; margin-bottom:1rem;`}>
          <div style="display:flex; justify-content:space-between; gap:.6rem; flex-wrap:wrap; align-items:baseline;">
            <h2 style="font-size:1.2rem; margin:0;">{d.label}</h2>
            <span class="tag">{d.ref}</span>
          </div>

          {d.files.length === 0 ? (
            <p style="color:var(--muted); margin:.7rem 0 0;">No files yet — upload below.</p>
          ) : (
            <ul style="list-style:none; padding:0; margin:.9rem 0 0; display:flex; flex-direction:column; gap:.5rem;">
              {d.files.map((f) => (
                <li style="display:flex; justify-content:space-between; gap:.8rem; align-items:center; border-bottom:1px solid var(--stroke); padding-bottom:.5rem;">
                  <span>{f.name}<span class="mono" style="margin-left:.5rem;">{fmtSize(f.size)}</span></span>
                  <form method="POST" action="/api/admin/vault-upload">
                    <input type="hidden" name="action" value="delete" />
                    <input type="hidden" name="ref" value={d.ref} />
                    <input type="hidden" name="name" value={f.name} />
                    <button class="btn-ghost" type="submit" style="padding:.3rem .75rem;">Delete</button>
                  </form>
                </li>
              ))}
            </ul>
          )}

          <form
            method="POST"
            action="/api/admin/vault-upload"
            enctype="multipart/form-data"
            style="margin-top:1rem; display:flex; gap:.6rem; flex-wrap:wrap; align-items:center;"
          >
            <input type="hidden" name="action" value="upload" />
            <input type="hidden" name="ref" value={d.ref} />
            <label class="mono" for={`f-${d.ref}`} style="position:absolute; left:-9999px;">Upload a file to {d.label}</label>
            <input id={`f-${d.ref}`} class="fld" type="file" name="file" required style="max-width:24rem;" />
            <button class="btn" type="submit">Upload</button>
          </form>
        </article>
      ))}
  </section>
</Base>
