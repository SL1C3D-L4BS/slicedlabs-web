---
// SlicedLabs · studio · © 2026 SlicedLabs — Admin cockpit: Recipes list + create/edit.
// Recipes are the food data model AND the in-house "inspiration behind the food" blog.
// The operator edits the JSONB ingredients/steps as plain text (one per line); the
// /api/admin/recipe endpoint parses them. Edit mode loads via ?edit=<id>.
export const prerender = false;
import Base from "../../layouts/Base.astro";
import { createServiceSupabase } from "../../lib/supabase";
import { isAdmin } from "../../lib/admin";

const { userId } = Astro.locals.auth();
if (!userId) return Astro.redirect("/account/login?next=" + encodeURIComponent(Astro.url.pathname));
const cu = await Astro.locals.currentUser();
if (!isAdmin(cu?.primaryEmailAddress?.emailAddress)) return new Response("Forbidden", { status: 403 });

let svc: ReturnType<typeof createServiceSupabase> | undefined;
try {
  svc = createServiceSupabase();
} catch {
  /* SUPABASE_SERVICE_ROLE_KEY not set — render a friendly notice below */
}

type Ingredient = { group?: string; item: string; amount?: string };
type RecipeRow = {
  id: string;
  slug: string;
  title: string;
  sl_code: string | null;
  kicker: string | null;
  summary: string | null;
  story: string | null;
  ingredients: Ingredient[] | null;
  steps: string[] | null;
  dietary: string[] | null;
  season: string | null;
  section: string;
  hero_image: string | null;
  status: string;
  sort: number;
};

const SECTIONS = [
  { id: "anchor", label: "Anchor" },
  { id: "drop", label: "Seasonal drop" },
  { id: "dough", label: "Dough lab" },
  { id: "sweet", label: "Sweet" },
];
const RECIPE_STATUS = ["draft", "published", "archived"];

const statusHue = (st: string): string =>
  st === "published" ? "var(--teal)" : st === "archived" ? "var(--muted)" : "var(--coral)";

// inverse of the /api/admin/recipe parsers — JSON → editable plain text
const ingredientsToText = (rows: Ingredient[] | null): string =>
  (rows ?? [])
    .map((r) => `${r.group ? r.group + " :: " : ""}${r.item}${r.amount ? " | " + r.amount : ""}`)
    .join("\n");
const stepsToText = (rows: string[] | null): string => (rows ?? []).join("\n");

let recipes: RecipeRow[] = [];
let editing: RecipeRow | null = null;
let loadError: string | null = null;
const editId = Astro.url.searchParams.get("edit");

if (svc) {
  const { data, error } = await svc
    .from("recipes")
    .select(
      "id,slug,title,sl_code,kicker,summary,story,ingredients,steps,dietary,season,section,hero_image,status,sort",
    )
    .order("section")
    .order("sort");
  if (error) loadError = error.message;
  else recipes = (data as unknown as RecipeRow[]) ?? [];
  if (editId) editing = recipes.find((r) => r.id === editId) ?? null;
}

const err = Astro.url.searchParams.get("err");
const ok = Astro.url.searchParams.get("ok");
const e = editing; // shorthand for the form defaults
---

<Base title="Admin — Recipes · SlicedLabs" description="SlicedLabs operator cockpit — recipes." noindex={true}>
  <section class="wrap section">
    <div style="display:flex; align-items:baseline; gap:1rem; flex-wrap:wrap; justify-content:space-between;">
      <div>
        <p class="mono" data-reveal>operator cockpit</p>
        <h1 class="t-h1" data-reveal style="--i:1; margin:.2rem 0 0;">
          <span class="blend-text">Recipes</span>
        </h1>
      </div>
      <nav data-reveal style="--i:2; display:flex; gap:1.2rem; align-items:center; flex-wrap:wrap;">
        <a href="/admin">Orders</a>
        <a href="/admin/products">Products</a>
        <a href="/admin/workshops">Workshops</a>
        <a href="/admin/vault">Vault</a>
        <a href="/admin/truck">Truck</a>
      </nav>
    </div>

    {err && <p class="mono" data-reveal style="color:var(--coral); margin-top:1rem;">{err}</p>}
    {ok && <p class="mono" data-reveal style="color:var(--teal); margin-top:1rem;">Saved · {ok}</p>}

    {
      !svc && (
        <div class="glass island" data-reveal style="margin-top:1.6rem;">
          <h2 style="font-size:1.2rem; margin:0 0 .4rem;">Service role key not set</h2>
          <p style="color:var(--muted); margin:0;">
            Set <code>SUPABASE_SERVICE_ROLE_KEY</code> so the cockpit can read drafts and write recipes.
          </p>
        </div>
      )
    }

    {
      svc && (
        <>
          {/* ---- new / edit recipe ------------------------------------------- */}
          <div class="glass island" data-reveal style="margin-top:1.6rem;">
            <div style="display:flex; justify-content:space-between; align-items:baseline; gap:1rem; flex-wrap:wrap;">
              <h2 style="font-size:1.25rem; margin:0 0 1rem;">{e ? `Edit · ${e.title}` : "New recipe"}</h2>
              {e && <a href="/admin/recipes" class="mono" style="color:var(--muted);">+ new instead</a>}
            </div>
            <form method="POST" action="/api/admin/recipe" style="display:flex; flex-direction:column; gap:.8rem;">
              <input type="hidden" name="action" value={e ? "update" : "create"} />
              {e && <input type="hidden" name="id" value={e.id} />}
              <div class="row2">
                <label>
                  <span class="mono">Title *</span>
                  <input class="fld" type="text" name="title" required value={e?.title ?? ""} placeholder="The Inland Cubano" />
                </label>
                <label>
                  <span class="mono">Slug (optional)</span>
                  <input class="fld" type="text" name="slug" value={e?.slug ?? ""} placeholder="auto from title" />
                </label>
              </div>
              <div class="row2">
                <label>
                  <span class="mono">SL code</span>
                  <input class="fld" type="text" name="sl_code" value={e?.sl_code ?? ""} placeholder="SL-A01" />
                </label>
                <label>
                  <span class="mono">Kicker</span>
                  <input class="fld" type="text" name="kicker" value={e?.kicker ?? ""} placeholder="the signature press" />
                </label>
              </div>
              <label>
                <span class="mono">Summary</span>
                <input class="fld" type="text" name="summary" value={e?.summary ?? ""} placeholder="One line for the card + meta description." />
              </label>
              <label>
                <span class="mono">Story (the inspiration — blank line = new paragraph)</span>
                <textarea class="fld" name="story" rows="5" placeholder="Where it came from, the technique, the source.">{e?.story ?? ""}</textarea>
              </label>
              <div class="row2">
                <label>
                  <span class="mono">Ingredients — one per line: <code>group :: item | amount</code></span>
                  <textarea class="fld" name="ingredients" rows="8" placeholder={"Press :: ciabatta | 1 loaf\nyellow mustard | 2 tbsp"}>{e ? ingredientsToText(e.ingredients) : ""}</textarea>
                </label>
                <label>
                  <span class="mono">Steps — one per line</span>
                  <textarea class="fld" name="steps" rows="8" placeholder={"Sear the pork.\nBuild the press.\nGriddle until the cheese weeps."}>{e ? stepsToText(e.steps) : ""}</textarea>
                </label>
              </div>
              <div class="row2">
                <label>
                  <span class="mono">Section</span>
                  <select name="section" class="fld">
                    {SECTIONS.map((sec) => (
                      <option value={sec.id} selected={(e?.section ?? "anchor") === sec.id}>{sec.label}</option>
                    ))}
                  </select>
                </label>
                <label>
                  <span class="mono">Status</span>
                  <select name="status" class="fld">
                    {RECIPE_STATUS.map((st) => (
                      <option value={st} selected={(e?.status ?? "draft") === st}>{st}</option>
                    ))}
                  </select>
                </label>
              </div>
              <div class="row2">
                <label>
                  <span class="mono">Dietary (comma): gf, v, vg, gf-avail, vg-avail</span>
                  <input class="fld" type="text" name="dietary" value={(e?.dietary ?? []).join(", ")} placeholder="gf-avail, v" />
                </label>
                <label>
                  <span class="mono">Season</span>
                  <input class="fld" type="text" name="season" value={e?.season ?? ""} placeholder="summer" />
                </label>
              </div>
              <div class="row2">
                <label>
                  <span class="mono">Hero image URL (optional)</span>
                  <input class="fld" type="url" name="hero_image" value={e?.hero_image ?? ""} placeholder="https://…" />
                </label>
                <label>
                  <span class="mono">Sort (within section)</span>
                  <input class="fld" type="number" name="sort" step="1" value={e?.sort ?? 0} />
                </label>
              </div>
              <div>
                <button type="submit" class="btn">{e ? "Save changes" : "Create recipe"}</button>
              </div>
            </form>
          </div>

          {/* ---- recipes table ---------------------------------------------- */}
          {loadError && (
            <p class="mono" data-reveal style="color:var(--coral); margin-top:1.4rem;">Couldn't load recipes: {loadError}</p>
          )}

          <div data-reveal style="--i:1; margin-top:1.8rem; overflow-x:auto; border:1px solid var(--stroke); border-radius:var(--radius);">
            <table style="width:100%; border-collapse:collapse; min-width:50rem; font-size:.92rem;">
              <thead>
                <tr style="text-align:left;">
                  {["Title", "Code", "Section", "Status", "Set status", "Edit"].map((h) => (
                    <th class="mono" style="padding:.7rem .8rem; border-bottom:1px solid var(--stroke); white-space:nowrap;">{h}</th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {recipes.length === 0 && (
                  <tr><td colspan="6" style="padding:1.2rem .8rem; color:var(--muted);">No recipes yet — create one above.</td></tr>
                )}
                {recipes.map((r) => (
                  <tr style="border-bottom:1px solid var(--stroke);">
                    <td style="padding:.7rem .8rem;">
                      <a href={`/recipes/${r.slug}`} style="color:var(--mark);">{r.title}</a>
                    </td>
                    <td style="padding:.7rem .8rem; color:var(--muted); white-space:nowrap;">{r.sl_code ?? "—"}</td>
                    <td style="padding:.7rem .8rem; color:var(--muted); white-space:nowrap;">{r.section}</td>
                    <td style="padding:.7rem .8rem;">
                      <span class="tag" style={`color:${statusHue(r.status)}; border-color:${statusHue(r.status)};`}>{r.status}</span>
                    </td>
                    <td style="padding:.7rem .8rem;">
                      <form method="POST" action="/api/admin/recipe" style="display:flex; gap:.4rem; align-items:center;">
                        <input type="hidden" name="action" value="set-status" />
                        <input type="hidden" name="id" value={r.id} />
                        <label class="mono" for={`rst-${r.id}`} style="position:absolute; width:1px; height:1px; overflow:hidden; clip:rect(0 0 0 0);">Status for {r.title}</label>
                        <select id={`rst-${r.id}`} name="status" class="fld" style="width:auto; padding:.4rem .6rem;">
                          {RECIPE_STATUS.map((st) => (
                            <option value={st} selected={st === r.status}>{st}</option>
                          ))}
                        </select>
                        <button type="submit" class="btn btn-ghost" style="padding:.45rem .8rem;">Save</button>
                      </form>
                    </td>
                    <td style="padding:.7rem .8rem;">
                      <a href={`/admin/recipes?edit=${r.id}`} class="btn btn-ghost" style="padding:.45rem .8rem;">Edit</a>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </>
      )
    }
  </section>
</Base>

<style>
  .row2 { display: grid; gap: .8rem; grid-template-columns: 1fr; }
  @media (min-width: 640px) { .row2 { grid-template-columns: 1fr 1fr; } }
  label { display: flex; flex-direction: column; gap: .35rem; }
  label .mono { color: var(--muted); font-size: .8rem; }
  textarea.fld { resize: vertical; font-family: var(--font-mono); font-size: .9rem; line-height: 1.5; }
</style>
