---
// SlicedLabs · studio · © 2026 SlicedLabs — Playbook detail + buy
// Server-rendered. Public reads see only published playbooks (RLS). If the
// signed-in user already holds the `playbook:<slug>` entitlement we show the
// "you own this" panel; otherwise we offer Stripe Embedded Checkout (price comes
// from the server, never the client).
export const prerender = false;
import Base from "../../layouts/Base.astro";
import { getServerSupabase } from "../../lib/supabase";
import { formatMoney } from "../../lib/commerce/cart";

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/playbooks");

const supabase = getServerSupabase(Astro.cookies, Astro.request);

type Playbook = {
  slug: string;
  title: string;
  summary: string | null;
  description: string | null;
  price_cents: number;
  currency: string;
  cover_image: string | null;
};

const { data: pbRow } = await supabase
  .from("playbooks")
  .select("slug,title,summary,description,price_cents,currency,cover_image")
  .eq("slug", slug)
  .eq("status", "published")
  .maybeSingle();

const pb = (pbRow as Playbook | null) ?? null;

// --- not found -----------------------------------------------------------
if (!pb) {
  Astro.response.status = 404;
}

// --- ownership / entitlement state (only when the playbook exists) -------
let owned = false;
if (pb) {
  const {
    data: { user },
  } = await supabase.auth.getUser();
  if (user) {
    const { data: ent } = await supabase
      .from("entitlements")
      .select("id")
      .eq("kind", "playbook:" + slug)
      .eq("ref_id", slug)
      .maybeSingle();
    owned = !!ent;
  }
}

const justPaid = Boolean(Astro.url.searchParams.get("bought"));
const isFree = pb ? pb.price_cents <= 0 : false;
const isPaid = pb ? pb.price_cents > 0 : false;
---
{!pb ? (
  <Base title="Playbook not found — SlicedLabs" description="That playbook isn't available." noindex={true}>
    <section class="wrap" style="padding-block:clamp(2.5rem,7vw,4rem);">
      <p class="mono" data-reveal>404</p>
      <h1 data-reveal style="--i:1; font-size:clamp(1.8rem,6vw,3rem);"><span class="blend-text">Playbook not found</span></h1>
      <hr class="blade" data-reveal style="--i:2; max-width:12rem; margin:1.2rem 0 1.4rem;" />
      <p data-reveal style="--i:3; color:var(--muted); max-width:36rem;">It may have been pulled, archived, or never existed at this address.</p>
      <div data-reveal style="--i:4; margin-top:1.6rem;"><a class="btn" href="/playbooks">← All playbooks</a></div>
    </section>
  </Base>
) : (
  <Base title={`${pb.title} — Playbooks · SlicedLabs`} description={pb.summary ?? pb.description ?? `A SlicedLabs playbook: ${pb.title}.`}>
    <section class="wrap" style="padding-block:clamp(2.5rem,7vw,4rem);">
      <p class="mono" data-reveal><a href="/playbooks" style="color:inherit; text-decoration:none;">← playbooks</a></p>

      {pb.cover_image && (
        <div
          data-reveal
          style="--i:1; margin:1.2rem 0 0; aspect-ratio:16/7; border-radius:var(--radius); overflow:hidden; background:var(--panel); border:1px solid var(--stroke);"
        >
          <img src={pb.cover_image} alt={pb.title} style="width:100%; height:100%; object-fit:cover; display:block;" />
        </div>
      )}

      <h1 data-reveal style="--i:2; font-size:clamp(2rem,7vw,4rem); margin-top:1.4rem;"><span class="blend-text">{pb.title}</span></h1>
      <hr class="blade" data-reveal style="--i:3; max-width:16rem; margin:1.2rem 0 0;" />

      <div data-reveal style="--i:4; display:flex; gap:.6rem; flex-wrap:wrap; margin-top:1.2rem;">
        <span class="tag">playbook</span>
        <span class="tag">{isFree ? "Free" : formatMoney(pb.price_cents, pb.currency)}</span>
      </div>

      {pb.description && (
        <p data-reveal style="--i:5; font-size:clamp(1.05rem,2.2vw,1.3rem); color:var(--muted); max-width:46rem; margin-top:1.4rem; white-space:pre-line;">{pb.description}</p>
      )}

      {justPaid && (
        <div class="glass island" data-reveal style="--i:6; margin-top:1.8rem; border-color:var(--teal);">
          <p class="mono" style="color:var(--teal); margin:0 0 .3rem;">payment received</p>
          <h2 style="font-size:1.25rem; margin:0 0 .4rem;">Your playbook is yours.</h2>
          <p style="color:var(--muted); margin:0;">Check your email or your <a href="/account" style="color:var(--mark);">account</a> for the deliverable.</p>
        </div>
      )}

      {/* ---- already owns it -------------------------------------------- */}
      {owned ? (
        <div class="glass island" data-reveal style="--i:7; margin-top:1.8rem;">
          <p class="mono" style="margin:0 0 .3rem;">your playbook</p>
          <h2 style="font-size:1.35rem; margin:0 0 .6rem;"><span class="blend-text">You own this</span></h2>
          <p style="color:var(--muted); margin:0 0 1rem;">It's unlocked on your account — open it any time.</p>
          <a class="btn" href="/account">Open my playbook →</a>
        </div>
      ) : isPaid ? (
        /* ---- paid, not owned yet → embedded Stripe checkout ----------- */
        <div data-reveal style="--i:7; margin-top:1.8rem;">
          <button id="buy-playbook" class="btn" type="button" data-slug={pb.slug}>
            Buy playbook — {formatMoney(pb.price_cents, pb.currency)}
          </button>
          <p id="checkout-msg" class="mono" role="status" aria-live="polite" style="color:var(--muted); margin-top:1rem;" hidden></p>
          <div id="checkout" style="margin-top:1rem;"></div>
        </div>
      ) : (
        /* ---- free playbook ------------------------------------------- */
        <div class="glass island" data-reveal style="--i:7; margin-top:1.8rem;">
          <p class="mono" style="margin:0 0 .3rem;">free</p>
          <h2 style="font-size:1.25rem; margin:0 0 .4rem;">This one's on the house.</h2>
          <p style="color:var(--muted); margin:0;">Free to grab. <a href="/playbooks" style="color:var(--mark);">See all playbooks →</a></p>
        </div>
      )}
    </section>

    {/* Embedded Stripe Checkout — mirrors src/pages/checkout.astro. */}
    <script>
      import { loadStripe } from "@stripe/stripe-js";

      const btn = document.getElementById("buy-playbook") as HTMLButtonElement | null;
      const msg = document.getElementById("checkout-msg");
      const mount = document.getElementById("checkout");

      function say(html: string) {
        if (!msg) return;
        msg.innerHTML = html;
        msg.hidden = false;
      }

      async function start() {
        if (!btn) return;
        const slug = btn.dataset.slug;
        if (!slug) return;
        btn.disabled = true;
        say("Preparing your playbook…");

        let data: { clientSecret?: string; error?: string };
        try {
          const res = await fetch("/api/playbooks/checkout", {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({ slug }),
          });
          data = await res.json();
        } catch {
          say("Something went wrong starting checkout. Please try again.");
          btn.disabled = false;
          return;
        }

        if (data.error || !data.clientSecret) {
          const friendly: Record<string, string> = {
            not_found: "This playbook isn't on sale right now.",
            not_purchasable: "This one's free — no checkout needed.",
            stripe_not_configured: "Payments aren't switched on yet. Check back soon.",
          };
          const text =
            (data.error && friendly[data.error]) || "We couldn't start checkout right now.";
          say(text);
          btn.disabled = false;
          return;
        }

        const clientSecret = data.clientSecret;
        const stripe = await loadStripe(import.meta.env.PUBLIC_STRIPE_PUBLISHABLE_KEY);
        if (!stripe) {
          say("Payments unavailable right now. Please try again later.");
          btn.disabled = false;
          return;
        }

        try {
          const checkout = await stripe.initEmbeddedCheckout({
            fetchClientSecret: async () => clientSecret,
          });
          if (msg) msg.hidden = true;
          btn.hidden = true;
          if (mount) checkout.mount("#checkout");
        } catch {
          say("We couldn't load the payment form. Please try again.");
          btn.disabled = false;
        }
      }

      btn?.addEventListener("click", start);
    </script>
  </Base>
)}
