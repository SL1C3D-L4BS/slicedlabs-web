---
// SlicedLabs · studio · © 2026 SlicedLabs — Playbooks
// Server-rendered. If published playbooks exist, show the grid; otherwise fall
// back to an honest "in build" state with the list so we still capture intent.
export const prerender = false;
import Base from "../../layouts/Base.astro";
import Newsletter from "../../components/Newsletter.astro";
import { getServerSupabase } from "../../lib/supabase";
import { formatMoney } from "../../lib/commerce/cart";

const supabase = getServerSupabase(Astro.cookies, Astro.request);
const { data: rows } = await supabase
  .from("playbooks")
  .select("slug,title,summary,price_cents,currency,cover_image")
  .eq("status", "published")
  .order("sort", { ascending: true });

type PlaybookCard = {
  slug: string;
  title: string;
  summary: string | null;
  price_cents: number;
  currency: string;
  cover_image: string | null;
};

const playbooks = (rows ?? []) as unknown as PlaybookCard[];
const hasPlaybooks = playbooks.length > 0;

const fmtPrice = (cents: number, currency: string): string =>
  cents > 0 ? formatMoney(cents, currency) : "Free";
---
<Base title="Playbooks — SlicedLabs" description="The playbooks — the systems we run, packaged. Owned, repeatable, and yours to run.">
  <section class="wrap" style="padding-block:clamp(2.5rem,7vw,4rem);">
    <p class="mono" data-reveal>the systems · packaged · yours to run</p>
    <h1 data-reveal style="--i:1; font-size:clamp(2.2rem,8vw,4.6rem);"><span class="blend-text">Playbooks</span></h1>
    <hr class="blade" data-reveal style="--i:2; max-width:18rem; margin:1.4rem 0 0;" />
    <p data-reveal style="--i:3; font-size:clamp(1.1rem,2.4vw,1.4rem); color:var(--muted); max-width:46rem; margin-top:1.4rem;">
      The systems we actually run — <strong style="color:var(--ink);">packaged</strong>. Not theory: the exact frameworks, templates, and steps we use to build in public. Buy it once, run it forever.
    </p>
    {hasPlaybooks && (
      <div data-reveal style="--i:4; margin-top:1.8rem;"><a class="btn" href="#shelf">See the playbooks →</a></div>
    )}
  </section>

  {hasPlaybooks ? (
    <section id="shelf" class="wrap" aria-labelledby="shelf-h" style="padding-block:clamp(2rem,6vw,3.5rem);">
      <div data-reveal style="display:flex; align-items:baseline; gap:.8rem; margin-bottom:1.2rem; flex-wrap:wrap;">
        <h2 id="shelf-h" style="font-size:clamp(1.4rem,4vw,2rem); margin:0;">On the shelf</h2>
        <span class="tag">own the system</span>
      </div>
      <div class="bento">
        {playbooks.map((p, i) => (
          <a
            class="glass island col-3"
            href={`/playbooks/${p.slug}`}
            data-reveal
            style={`--i:${i}; display:flex; flex-direction:column; gap:.6rem; text-decoration:none; color:inherit;`}
          >
            {p.cover_image && (
              <div style="aspect-ratio:4/3; border-radius:var(--radius); overflow:hidden; background:var(--panel); border:1px solid var(--stroke);">
                <img
                  src={p.cover_image}
                  alt={p.title}
                  loading="lazy"
                  style="width:100%; height:100%; object-fit:cover; display:block;"
                />
              </div>
            )}
            <h3 style="font-size:1.3rem; margin:0;"><span class="blend-text">{p.title}</span></h3>
            {p.summary && (
              <p style="color:var(--muted); margin:0;">{p.summary}</p>
            )}
            <div style="display:flex; align-items:center; justify-content:space-between; gap:.8rem; margin-top:auto; padding-top:.4rem;">
              <span class="tag">{fmtPrice(p.price_cents, p.currency)}</span>
              <span class="mono" aria-hidden="true">Get it →</span>
            </div>
          </a>
        ))}
      </div>
      <div class="wrap" style="padding-inline:0;"><Newsletter /></div>
    </section>
  ) : (
    <>
      <section class="wrap" style="padding-block:2rem;">
        <article class="glass glass-ultra island" data-reveal>
          <p class="mono" style="text-align:center;">in build · the list gets first dibs</p>
          <h2 style="font-size:clamp(1.5rem,4vw,2.2rem); margin:.3rem 0 .5rem; text-align:center;">The first playbooks are coming.</h2>
          <p style="color:var(--muted); max-width:40rem; margin:0 auto 1.4rem; text-align:center;">The systems we run — the Atomise Machine, the offer ladder, the build-in-public engine — packaged and ready to run. First access goes to the list.</p>
          <div style="max-width:34rem; margin:0 auto;"><Newsletter /></div>
        </article>
      </section>
    </>
  )}
</Base>
