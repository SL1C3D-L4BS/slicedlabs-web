---
// SlicedLabs · studio · © 2026 SlicedLabs — Watch (the channel)
import Base from "../layouts/Base.astro";
const shows = [
  { k: "Cook with me", d: "How I cook and what I cook — technique, the chaos-menu drops, real ingredients. Not a vlog; a food channel you can actually learn from." },
  { k: "The build", d: "The venture arm, on camera — the truck, the permits, the first sale. A real business, documented with the numbers shown." },
  { k: "Local PNW", d: "The farms, the breweries, the Inland Northwest sourcing behind every plate." },
  { k: "Workshops on demand", d: "Recorded cook-alongs and build sessions — learn at your pace. The live ones go deeper.", href: "/workshops" },
  { k: "Behind the pass", d: "The systems, the failures, the real days. The honest part nobody films." },
];
---
<Base title="Watch — SlicedLabs" description="A full food channel and a business built in public. Cook with me, watch the venture, learn the craft. YouTube is home base.">
  <section class="wrap section">
    <p class="mono" data-reveal>the channel · home base</p>
    <h1 class="t-h1" data-reveal style="--i:1; margin:.3rem 0 0;"><span class="blend-text">Watch &amp; cook along</span></h1>
    <hr class="blade" data-reveal style="--i:2; max-width:24rem; margin:1.4rem 0 0;" />
    <p data-reveal style="--i:3; color:var(--muted); max-width:44rem; margin-top:1.4rem;">
      It's two things at once: a real <strong style="color:var(--ink);">food channel</strong> — how I cook, what I cook, the chaos menu — and a <strong style="color:var(--ink);">business built in public</strong>, the whole venture on camera. Subscribe before Episode 0 drops — you'll catch the build from frame one.
    </p>
    <div data-reveal style="--i:4; display:flex; gap:.8rem; flex-wrap:wrap; margin:1.6rem 0 2.6rem;">
      <a class="btn" href="https://www.youtube.com/channel/UCodcvZ6u4N4PACwxYaM8sTw">Subscribe on YouTube →</a>
      <a class="btn btn-ghost" href="/workshops">Join a workshop</a>
    </div>

    <h2 class="mono" data-reveal style="color:var(--muted); margin-bottom:1rem;">what's on the channel</h2>
    <div class="bento">
      {shows.map((s, i) => (
        <article class="glass island col-2" data-reveal style={`--i:${i}`}>
          <h3 style="font-size:1.3rem; margin:0 0 .3rem;"><span class="blend-text">{s.k}</span></h3>
          <p style="color:var(--muted); margin:0;">{s.d}</p>
          {s.href && <a href={s.href} class="mono" style="display:inline-block; margin-top:.6rem; text-decoration:none;">learn more →</a>}
        </article>
      ))}
    </div>
  </section>
</Base>
