---
// SlicedLabs · account · © 2026 SlicedLabs — Magic-link sign in
// Passwordless. POSTs to itself; sends a Supabase OTP magic link that returns
// the visitor to wherever they were headed (?next=) via /auth/callback.
export const prerender = false;
import Base from "../../layouts/Base.astro";
import { getServerSupabase } from "../../lib/supabase";

const supabase = getServerSupabase(Astro.cookies, Astro.request);

// Where to send them after sign-in. Only allow same-origin internal paths.
const nextRaw = Astro.url.searchParams.get("next") || "/account";
const next = nextRaw.startsWith("/") && !nextRaw.startsWith("//") ? nextRaw : "/account";

// Already signed in? Skip the form.
const {
  data: { user },
} = await supabase.auth.getUser();
if (user) return Astro.redirect(next);

let sent = false;
let error = Astro.url.searchParams.get("error");

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const email = String(form.get("email") || "")
    .trim()
    .toLowerCase();
  if (/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)) {
    const { error: e } = await supabase.auth.signInWithOtp({
      email,
      options: {
        emailRedirectTo: `${Astro.url.origin}/auth/callback?next=${encodeURIComponent(next)}`,
      },
    });
    if (e) error = e.message;
    else sent = true;
  } else {
    error = "That email doesn't look right.";
  }
}
---
<Base
  title="Sign in — SlicedLabs"
  description="Sign in to your SlicedLabs account."
  noindex={true}
>
  <section class="wrap" style="padding-block:clamp(2.5rem,7vw,4rem);">
    <div
      class="glass island"
      data-reveal
      style="max-width:30rem; margin-inline:auto; display:flex; flex-direction:column; gap:1rem;"
    >
      <p class="mono" style="margin:0;">your account</p>
      <h1 style="font-size:clamp(1.8rem,6vw,2.6rem); margin:0; line-height:1.05;">
        <span class="blend-text">Sign in</span>
      </h1>
      <p style="color:var(--muted); margin:0;">
        Magic link — no passwords. We email you a sign-in link.
      </p>

      {sent ? (
        <p
          data-reveal
          style="--i:1; margin:0; color:var(--ink); font-size:1.05rem;"
        >
          Check your inbox — we sent a sign-in link to your email.
        </p>
      ) : (
        <form
          method="POST"
          style="display:flex; flex-direction:column; gap:.8rem; margin-top:.2rem;"
        >
          <label
            for="email"
            class="mono"
            style="font-size:.78rem; color:var(--muted);"
          >
            Email
          </label>
          <input
            class="fld"
            id="email"
            type="email"
            name="email"
            autocomplete="email"
            placeholder="you@example.com"
            required
          />
          <button class="btn" type="submit">Send my link</button>
          {error && (
            <p
              role="alert"
              style="margin:.2rem 0 0; color:var(--coral); font-size:.92rem;"
            >
              {error}
            </p>
          )}
        </form>
      )}

      <p class="mono" style="margin:.2rem 0 0; color:var(--muted); font-size:.72rem;">
        The link returns you to wherever you were going.
      </p>
    </div>
  </section>
</Base>
