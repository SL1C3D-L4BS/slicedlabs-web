---
// SlicedLabs · account · © 2026 SlicedLabs — Sign in (Clerk)
// Clerk hosted sign-in, embedded on-brand. Email code + any enabled social provider — no
// email server of our own needed. isStatic={false} is required under output:'static' so the
// widget hydrates against the request. After sign-in we return to ?next= (same-origin only).
export const prerender = false;
import Base from "../../layouts/Base.astro";
import { SignIn } from "@clerk/astro/components";

const nextRaw = Astro.url.searchParams.get("next") || "/account";
const next = nextRaw.startsWith("/") && !nextRaw.startsWith("//") ? nextRaw : "/account";

// Already signed in (Clerk) → skip the form.
const { userId } = Astro.locals.auth();
if (userId) return Astro.redirect(next);
---
<Base title="Sign in — SlicedLabs" description="Sign in to your SlicedLabs account." noindex={true}>
  <section class="wrap" style="padding-block:clamp(2.5rem,7vw,4rem); display:flex; justify-content:center;">
    <SignIn forceRedirectUrl={next} signUpUrl="/account/sign-up" />
  </section>
</Base>
