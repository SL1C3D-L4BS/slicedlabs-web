---
// SlicedLabs · account · © 2026 SlicedLabs — Customer dashboard
// Shows the signed-in customer's own orders (RLS scopes the query to them).
// Handles a sign-out POST. Gated: anonymous visitors bounce to the login page.
export const prerender = false;
import DashShell from "../../layouts/DashShell.astro";
import EmptyState from "../../components/EmptyState.astro";
import { getClerkSupabase } from "../../lib/supabase";
import { ensureClerkProfile } from "../../lib/clerkProfile";
import { formatMoney } from "../../lib/commerce/cart";

const { userId } = Astro.locals.auth();
if (!userId) return Astro.redirect("/account/login?next=/account");
const cu = await Astro.locals.currentUser();
const email = cu?.primaryEmailAddress?.emailAddress ?? null;
// Belt before the Clerk webhook is live: link/create the profile so RLS resolves.
await ensureClerkProfile(userId, email);
const supabase = getClerkSupabase(Astro.locals);

// Orders + entitlements + saved recipes — independent reads fired in PARALLEL
// (one round-trip floor instead of three serial awaits). RLS scopes each read to
// the signed-in user; getUser() above already gated/short-circuited anon visitors.
const [ordersRes, entRes, recipeRes] = await Promise.all([
  supabase
    .from("orders")
    .select(
      "id,status,total_cents,currency,fulfillment_type,printful_order_id,tracking,created_at,order_items(title,qty,unit_price_cents)",
    )
    .order("created_at", { ascending: false }),
  supabase
    .from("entitlements")
    .select("kind, source, ref_id, granted_at, expires_at")
    .order("granted_at", { ascending: false }),
  supabase
    .from("saved_recipes")
    .select("recipe_slug, note, saved_at")
    .order("saved_at", { ascending: false }),
]);
const orderRows = ordersRes.data;
const entRows = entRes.data;
const recipeRows = recipeRes.data;

type LineItem = { title: string; qty: number; unit_price_cents: number };
type Tracking = { carrier?: string; number?: string; url?: string } | null;
type Order = {
  id: string;
  status: string;
  total_cents: number;
  currency: string;
  fulfillment_type: string;
  printful_order_id: string | null;
  tracking: Tracking;
  created_at: string;
  order_items: LineItem[];
};

const orders = (orderRows ?? []) as unknown as Order[];

type Entitlement = {
  kind: string;
  source: string;
  ref_id: string | null;
  granted_at: string;
  expires_at: string | null;
};
type SavedRecipe = { recipe_slug: string; note: string | null; saved_at: string };

const nowMs = Date.now();
const activeEnts = ((entRows ?? []) as unknown as Entitlement[]).filter(
  (e) => !e.expires_at || new Date(e.expires_at).getTime() > nowMs,
);
const isMember = activeEnts.some((e) => e.kind === "member");
const vaultDrops = activeEnts.filter((e) => e.kind === "vault_drops");
const playbooks = activeEnts.filter((e) => e.kind.startsWith("playbook:"));
const workshops = activeEnts.filter((e) => e.kind.startsWith("workshop:"));
const recipes = (recipeRows ?? []) as unknown as SavedRecipe[];

// Resolve saved-recipe titles (saved_recipes stores only the slug). Recipes RLS allows
// public read of published rows, so the signed-in client can fetch the titles directly.
const savedSlugs = recipes.map((r) => r.recipe_slug);
let recipeTitle: Record<string, string> = {};
if (savedSlugs.length) {
  const { data: rt } = await supabase.from("recipes").select("slug,title").in("slug", savedSlugs);
  recipeTitle = Object.fromEntries(
    ((rt ?? []) as { slug: string; title: string }[]).map((r) => [r.slug, r.title]),
  );
}

const fmtDate = (iso: string) =>
  new Date(iso).toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });

// Humanize a "playbook:debt-in-order" entitlement slug into a readable title
// (drop the prefix, de-kebab, title-case) so the dashboard never shows raw slugs.
const playbookTitle = (kind: string): string =>
  kind
    .replace(/^playbook:/, "")
    .replace(/[-_]+/g, " ")
    .replace(/\b\w/g, (c) => c.toUpperCase())
    .trim() || "Playbook";

// Surface a Billing-Portal hiccup if /api/account/portal bounced back here.
const billing = Astro.url.searchParams.get("billing");
const BILLING_MSG: Record<string, string> = {
  none: "We couldn't find a subscription on file for this account yet.",
  not_configured: "Billing isn't configured yet.",
  error: "Couldn't open the billing portal — try again shortly.",
};
const billingMsg = billing ? BILLING_MSG[billing] : null;
---
<DashShell
  title="Dashboard — Account · SlicedLabs"
  description="Your SlicedLabs orders and account."
  section="account"
  active="/account"
  email={email}
  crumbs={[{ label: "Dashboard" }]}
>
  <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:1rem; flex-wrap:wrap;">
    <div>
      <h1 class="dash-h1">Welcome back</h1>
      <p class="dash-sub" style="margin-bottom:0;">
        {email}
        {isMember && <span class="tag-status" data-state="success" style="margin-left:.55rem;">Member</span>}
      </p>
    </div>
  </div>

  {billingMsg && <p role="status" style="color:var(--danger); margin:1.2rem 0 0;">{billingMsg}</p>}

  <div class="stack" style="margin-top:var(--space-6);">
    {!isMember && (
      <a href="/membership" class="card" style="display:flex; align-items:center; justify-content:space-between; gap:1rem; flex-wrap:wrap; text-decoration:none;">
        <span>
          <span class="kpi-k">the inner circle</span>
          <span style="display:block; font-weight:600; color:var(--ink); margin-top:.25rem;">Become a member — early drops, every playbook, the build updates.</span>
        </span>
        <span class="btn btn-sm">Become a member →</span>
      </a>
    )}

    <a href="/kitchen/tools" class="card" style="display:flex; align-items:center; justify-content:space-between; gap:1rem; flex-wrap:wrap; text-decoration:none;">
      <span>
        <span class="kpi-k">your kitchen</span>
        <span style="display:block; font-weight:600; color:var(--ink); margin-top:.25rem;">Track food waste + your dietary profile — synced to your account.</span>
      </span>
      <span class="btn btn-ghost btn-sm">Open food tools →</span>
    </a>
  </div>

  <h2 class="dash-h1" style="font-size:var(--step-1); margin:var(--space-6) 0 var(--space-4);">Orders</h2>

  {orders.length === 0 ? (
    <EmptyState
      title="No orders yet"
      detail="When you place an order, it shows up here with live status and tracking."
      ctaHref="/shop"
      ctaLabel="Shop the drop"
    />
  ) : (
    <div class="stack">
      {orders.map((o) => (
        <article class="card stack-sm">
          <div style="display:flex; align-items:center; justify-content:space-between; gap:.8rem; flex-wrap:wrap;">
            <span class="kpi-k">{fmtDate(o.created_at)}</span>
            <span class="tag-status" data-state={
              o.status === "paid" || o.status === "delivered" ? "success"
              : o.status === "fulfilling" ? "progress"
              : o.status === "shipped" ? "info"
              : o.status === "refunded" || o.status === "canceled" ? "danger"
              : o.status === "pending" ? "warning" : "neutral"
            }>{o.status}</span>
          </div>
          <p style="margin:0; font-weight:700; font-variant-numeric:tabular-nums; font-size:1.15rem;">{formatMoney(o.total_cents, o.currency)}</p>
          {o.order_items?.length > 0 && (
            <ul style="list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:.3rem;">
              {o.order_items.map((it) => (
                <li style="color:var(--muted); display:flex; gap:.6rem;">
                  <span class="mono">{it.qty}×</span>
                  <span>{it.title}</span>
                </li>
              ))}
            </ul>
          )}
          {o.tracking?.url && (
            <a href={o.tracking.url} target="_blank" rel="noopener noreferrer" style="color:var(--mark); text-decoration:underline; text-underline-offset:3px; font-weight:600; align-self:flex-start;">Track package →</a>
          )}
        </article>
      ))}
    </div>
  )}

  {vaultDrops.length > 0 && (
    <>
      <h2 class="dash-h1" style="font-size:var(--step-1); margin:var(--space-6) 0 var(--space-4);">Vault drops</h2>
      <div class="stack">
        {vaultDrops.map((d) => (
          <article class="card" style="display:flex; align-items:center; justify-content:space-between; gap:1rem; flex-wrap:wrap;">
            <span>{d.ref_id ?? "Drop"}</span>
            {d.ref_id ? (
              <a class="btn btn-ghost btn-sm" href={`/api/vault/${encodeURIComponent(d.ref_id)}`}>Download →</a>
            ) : (
              <span class="kpi-k">preparing…</span>
            )}
          </article>
        ))}
      </div>
    </>
  )}

  {playbooks.length > 0 && (
    <>
      <h2 class="dash-h1" style="font-size:var(--step-1); margin:var(--space-6) 0 var(--space-4);">Playbooks</h2>
      <div class="stack-sm" style="display:flex; flex-direction:column;">
        {playbooks.map((p) => (
          <div class="card card-sm">{playbookTitle(p.kind)}</div>
        ))}
      </div>
    </>
  )}

  {workshops.length > 0 && (
    <>
      <h2 class="dash-h1" style="font-size:var(--step-1); margin:var(--space-6) 0 var(--space-4);">Your workshops</h2>
      <div class="stack-sm" style="display:flex; flex-direction:column;">
        {workshops.map((w) => (
          <a class="card card-sm" href={`/workshops/${w.ref_id}`} style="text-decoration:none; display:flex; justify-content:space-between; align-items:center; gap:.8rem;">
            <span style="color:var(--ink);">{w.ref_id}</span>
            <span class="mono" style="color:var(--teal);">View workshop →</span>
          </a>
        ))}
      </div>
    </>
  )}

  {recipes.length > 0 && (
    <>
      <h2 class="dash-h1" style="font-size:var(--step-1); margin:var(--space-6) 0 var(--space-4);">Saved recipes</h2>
      <div class="stack-sm" style="display:flex; flex-direction:column;">
        {recipes.map((r) => (
          <a class="card card-sm" href={`/recipes/${r.recipe_slug}`} style="text-decoration:none; display:block;">
            <span style="color:var(--ink);">{recipeTitle[r.recipe_slug] ?? r.recipe_slug}</span>
            {r.note && <p style="color:var(--muted); margin:.3rem 0 0;">{r.note}</p>}
          </a>
        ))}
      </div>
    </>
  )}
</DashShell>
