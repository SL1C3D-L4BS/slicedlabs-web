---
// SlicedLabs · account · © 2026 SlicedLabs — Customer dashboard
// Shows the signed-in customer's own orders (RLS scopes the query to them).
// Handles a sign-out POST. Gated: anonymous visitors bounce to the login page.
export const prerender = false;
import Base from "../../layouts/Base.astro";
import { getServerSupabase } from "../../lib/supabase";
import { formatMoney } from "../../lib/commerce/cart";

const supabase = getServerSupabase(Astro.cookies, Astro.request);

// Sign-out POST.
if (Astro.request.method === "POST") {
  const f = await Astro.request.formData();
  if (f.get("intent") === "signout") {
    await supabase.auth.signOut();
    return Astro.redirect("/");
  }
}

const {
  data: { user },
} = await supabase.auth.getUser();
if (!user) return Astro.redirect("/account/login?next=/account");

// Orders + entitlements + saved recipes — independent reads fired in PARALLEL
// (one round-trip floor instead of three serial awaits). RLS scopes each read to
// the signed-in user; getUser() above already gated/short-circuited anon visitors.
const [ordersRes, entRes, recipeRes] = await Promise.all([
  supabase
    .from("orders")
    .select(
      "id,status,total_cents,currency,fulfillment_type,printful_order_id,tracking,created_at,order_items(title,qty,unit_price_cents)",
    )
    .order("created_at", { ascending: false }),
  supabase
    .from("entitlements")
    .select("kind, source, ref_id, granted_at, expires_at")
    .order("granted_at", { ascending: false }),
  supabase
    .from("saved_recipes")
    .select("recipe_slug, note, saved_at")
    .order("saved_at", { ascending: false }),
]);
const orderRows = ordersRes.data;
const entRows = entRes.data;
const recipeRows = recipeRes.data;

type LineItem = { title: string; qty: number; unit_price_cents: number };
type Tracking = { carrier?: string; number?: string; url?: string } | null;
type Order = {
  id: string;
  status: string;
  total_cents: number;
  currency: string;
  fulfillment_type: string;
  printful_order_id: string | null;
  tracking: Tracking;
  created_at: string;
  order_items: LineItem[];
};

const orders = (orderRows ?? []) as unknown as Order[];

type Entitlement = {
  kind: string;
  source: string;
  ref_id: string | null;
  granted_at: string;
  expires_at: string | null;
};
type SavedRecipe = { recipe_slug: string; note: string | null; saved_at: string };

const nowMs = Date.now();
const activeEnts = ((entRows ?? []) as unknown as Entitlement[]).filter(
  (e) => !e.expires_at || new Date(e.expires_at).getTime() > nowMs,
);
const isMember = activeEnts.some((e) => e.kind === "member");
const vaultDrops = activeEnts.filter((e) => e.kind === "vault_drops");
const playbooks = activeEnts.filter((e) => e.kind.startsWith("playbook:"));
const workshops = activeEnts.filter((e) => e.kind.startsWith("workshop:"));
const recipes = (recipeRows ?? []) as unknown as SavedRecipe[];

// Resolve saved-recipe titles (saved_recipes stores only the slug). Recipes RLS allows
// public read of published rows, so the signed-in client can fetch the titles directly.
const savedSlugs = recipes.map((r) => r.recipe_slug);
let recipeTitle: Record<string, string> = {};
if (savedSlugs.length) {
  const { data: rt } = await supabase.from("recipes").select("slug,title").in("slug", savedSlugs);
  recipeTitle = Object.fromEntries(
    ((rt ?? []) as { slug: string; title: string }[]).map((r) => [r.slug, r.title]),
  );
}

const fmtDate = (iso: string) =>
  new Date(iso).toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
---
<Base
  title="Your account — SlicedLabs"
  description="Your SlicedLabs orders and account."
  noindex={true}
>
  <section class="wrap" style="padding-block:clamp(2.5rem,7vw,4rem);">
    <div
      data-reveal
      style="display:flex; align-items:flex-start; justify-content:space-between; gap:1rem; flex-wrap:wrap; margin-bottom:1.6rem;"
    >
      <div>
        <p class="mono" style="margin:0;">your account</p>
        <h1 style="font-size:clamp(1.8rem,6vw,2.8rem); margin:.2rem 0 0; line-height:1.05;">
          <span class="blend-text">Welcome back</span>
        </h1>
        <p style="color:var(--muted); margin:.5rem 0 0;">
          {user.email}
          {isMember && (
            <span
              class="tag"
              style="margin-left:.55rem; color:var(--muted-strong); border-color:color-mix(in oklab, var(--teal) 45%, var(--stroke));"
            >Member</span>
          )}
        </p>
      </div>
      <form method="POST" style="margin-top:.4rem;">
        <input type="hidden" name="intent" value="signout" />
        <button class="btn-ghost" type="submit">Sign out</button>
      </form>
    </div>

    <h2 data-reveal style="--i:1; font-size:clamp(1.3rem,4vw,1.8rem); margin:0 0 1rem;">
      Orders
    </h2>

    {orders.length === 0 ? (
      <div
        class="glass island"
        data-reveal
        style="--i:2; display:flex; flex-direction:column; gap:1rem; align-items:flex-start;"
      >
        <p style="margin:0; color:var(--muted);">
          No orders yet —
        </p>
        <a class="btn" href="/shop">Shop the drop</a>
      </div>
    ) : (
      <div style="display:flex; flex-direction:column; gap:1rem;">
        {orders.map((o, i) => (
          <article
            class="glass island"
            data-reveal
            style={`--i:${i}; display:flex; flex-direction:column; gap:.75rem;`}
          >
            <div
              style="display:flex; align-items:center; justify-content:space-between; gap:.8rem; flex-wrap:wrap;"
            >
              <span class="mono" style="color:var(--muted);">{fmtDate(o.created_at)}</span>
              <span class="tag">{o.status}</span>
            </div>

            <p
              class="mono"
              style="margin:0; font-size:1.15rem;"
            >
              {formatMoney(o.total_cents, o.currency)}
            </p>

            {o.order_items?.length > 0 && (
              <ul
                style="list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:.3rem;"
              >
                {o.order_items.map((it) => (
                  <li style="color:var(--muted); display:flex; gap:.6rem;">
                    <span class="mono">{it.qty}×</span>
                    <span>{it.title}</span>
                  </li>
                ))}
              </ul>
            )}

            {o.tracking?.url && (
              <a
                href={o.tracking.url}
                target="_blank"
                rel="noopener noreferrer"
                style="color:var(--muted-strong); text-decoration:underline; text-underline-offset:3px; font-weight:600; align-self:flex-start;"
              >
                Track package →
              </a>
            )}
          </article>
        ))}
      </div>
    )}

    {vaultDrops.length > 0 && (
      <>
        <h2 data-reveal style="font-size:clamp(1.3rem,4vw,1.8rem); margin:2.6rem 0 1rem;">
          Vault drops
        </h2>
        <div style="display:flex; flex-direction:column; gap:.8rem;">
          {vaultDrops.map((d, i) => (
            <article
              class="glass island"
              data-reveal
              style={`--i:${i}; display:flex; align-items:center; justify-content:space-between; gap:1rem; flex-wrap:wrap;`}
            >
              <span>{d.ref_id ?? "Drop"}</span>
              {d.ref_id ? (
                <a class="btn-ghost" href={`/api/vault/${encodeURIComponent(d.ref_id)}`}>
                  Download →
                </a>
              ) : (
                <span class="mono" style="color:var(--muted);">preparing…</span>
              )}
            </article>
          ))}
        </div>
      </>
    )}

    {playbooks.length > 0 && (
      <>
        <h2 data-reveal style="font-size:clamp(1.3rem,4vw,1.8rem); margin:2.6rem 0 1rem;">
          Playbooks
        </h2>
        <ul style="list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:.5rem;">
          {playbooks.map((p) => (
            <li class="glass island" style="padding:.9rem 1.1rem;">
              {p.kind.replace("playbook:", "")}
            </li>
          ))}
        </ul>
      </>
    )}

    {workshops.length > 0 && (
      <>
        <h2 data-reveal style="font-size:clamp(1.3rem,4vw,1.8rem); margin:2.6rem 0 1rem;">
          Your workshops
        </h2>
        <div style="display:flex; flex-direction:column; gap:.6rem;">
          {workshops.map((w) => (
            <a
              class="glass island"
              href={`/workshops/${w.ref_id}`}
              style="text-decoration:none; display:flex; justify-content:space-between; align-items:center; gap:.8rem;"
            >
              <span style="color:var(--ink);">{w.ref_id}</span>
              <span class="mono" style="color:var(--teal);">View workshop →</span>
            </a>
          ))}
        </div>
      </>
    )}

    {recipes.length > 0 && (
      <>
        <h2 data-reveal style="font-size:clamp(1.3rem,4vw,1.8rem); margin:2.6rem 0 1rem;">
          Saved recipes
        </h2>
        <div style="display:flex; flex-direction:column; gap:.6rem;">
          {recipes.map((r) => (
            <a
              class="glass island"
              href={`/recipes/${r.recipe_slug}`}
              style="text-decoration:none; display:block;"
            >
              <span style="color:var(--ink);">{recipeTitle[r.recipe_slug] ?? r.recipe_slug}</span>
              {r.note && <p style="color:var(--muted); margin:.3rem 0 0;">{r.note}</p>}
            </a>
          ))}
        </div>
      </>
    )}
  </section>
</Base>
