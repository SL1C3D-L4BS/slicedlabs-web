---
// SlicedLabs · account · © 2026 SlicedLabs — Account settings
// Edit your display name + manage your subscription (Stripe Billing Portal). All RLS-scoped
// to the signed-in user; anonymous visitors bounce to login.
export const prerender = false;
import DashShell from "../../layouts/DashShell.astro";
import { getClerkSupabase } from "../../lib/supabase";
import { ensureClerkProfile } from "../../lib/clerkProfile";

const { userId } = Astro.locals.auth();
if (!userId) return Astro.redirect("/account/login?next=/account/settings");
const cu = await Astro.locals.currentUser();
const email = cu?.primaryEmailAddress?.emailAddress ?? null;
const pid = await ensureClerkProfile(userId, email);
const supabase = getClerkSupabase(Astro.locals);

let saved = false;
let saveError: string | null = null;
if (Astro.request.method === "POST") {
  const f = await Astro.request.formData();
  if (f.get("intent") === "profile") {
    const fullName = String(f.get("full_name") ?? "").trim().slice(0, 120) || null;
    const { error } = await supabase
      .from("profiles")
      .update({ full_name: fullName })
      .eq("id", pid ?? "");
    if (error) { saveError = "Couldn't save your changes — please try again."; console.error("[account/settings]", error.message); }
    else saved = true;
  }
}

const { data: prof } = await supabase
  .from("profiles")
  .select("full_name, stripe_customer_id")
  .eq("id", pid ?? "")
  .maybeSingle();

const { data: ent } = await supabase
  .from("entitlements")
  .select("kind, expires_at")
  .eq("kind", "member")
  .maybeSingle();
const isMember = Boolean(ent && (!ent.expires_at || new Date(ent.expires_at).getTime() > Date.now()));

const billing = Astro.url.searchParams.get("billing");
const BILLING_MSG: Record<string, string> = {
  none: "We couldn't find a subscription on file for this account yet.",
  not_configured: "Billing isn't configured yet.",
  error: "Couldn't open the billing portal — try again shortly.",
};
const billingMsg = billing ? BILLING_MSG[billing] : null;
---
<DashShell
  title="Settings — Account · SlicedLabs"
  description="Manage your SlicedLabs account."
  section="account"
  active="/account/settings"
  email={email}
  crumbs={[{ label: "Settings" }]}
>
  <div style="max-width:42rem;">
    <h1 class="dash-h1">Settings</h1>
    <p class="dash-sub">Your profile and subscription.</p>

    {saved && <p role="status" style="color:var(--teal); margin:0 0 1rem;">Saved.</p>}
    {saveError && <p role="status" style="color:var(--danger); margin:0 0 1rem;">{saveError}</p>}

    <div class="dash-panel">
      <h2 class="dash-panel-h">Profile</h2>
      <form method="POST" class="stack">
        <input type="hidden" name="intent" value="profile" />
        <label class="field">
          <span class="field-label">Email</span>
          <input class="fld" type="email" value={email ?? ""} disabled />
        </label>
        <label class="field">
          <span class="field-label">Display name</span>
          <input class="fld" type="text" name="full_name" value={prof?.full_name ?? ""} placeholder="Your name" />
        </label>
        <div><button class="btn btn-sm" type="submit">Save profile</button></div>
      </form>
    </div>

    <div class="dash-panel">
      <h2 class="dash-panel-h">Subscription</h2>
      {billingMsg && <p role="status" style="color:var(--danger); margin:0 0 .8rem;">{billingMsg}</p>}
      {isMember ? (
        <>
          <p style="color:var(--muted); margin:0 0 1rem;">You're a member. Manage your plan, payment method, or cancel anytime in the Stripe portal.</p>
          <a class="btn btn-sm" href="/api/account/portal">Manage subscription →</a>
        </>
      ) : (
        <>
          <p style="color:var(--muted); margin:0 0 1rem;">You're not a member yet.</p>
          <a class="btn btn-sm" href="/membership">Become a member →</a>
        </>
      )}
    </div>
  </div>
</DashShell>
