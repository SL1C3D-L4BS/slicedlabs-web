---
// SlicedLabs · studio · © 2026 SlicedLabs — Shop
// Server-rendered storefront. If active products exist, show the grid; otherwise
// fall back to the honest waitlist funnel so we still capture intent.
export const prerender = false;
import Base from "../layouts/Base.astro";
import Newsletter from "../components/Newsletter.astro";
import LeadForm from "../components/LeadForm.astro";
import { getServerSupabase } from "../lib/supabase";
import { formatMoney } from "../lib/commerce/cart";

const supabase = getServerSupabase(Astro.cookies, Astro.request);
const { data: rows } = await supabase
  .from("products")
  .select(
    "id, slug, title, description, images, fulfillment_type, variants(id, price_cents, currency, title)",
  )
  .eq("status", "active")
  .order("created_at", { ascending: false });

type Variant = { id: string; price_cents: number; currency: string; title: string };
type Product = {
  id: string;
  slug: string;
  title: string;
  description: string | null;
  images: unknown;
  fulfillment_type: "pod" | "in_house" | "digital";
  variants: Variant[];
};

const products = (rows ?? []) as unknown as Product[];

const FULFILL_LABEL: Record<Product["fulfillment_type"], string> = {
  pod: "made to order",
  in_house: "limited drop",
  digital: "digital",
};

function firstImage(images: unknown): string | null {
  if (!Array.isArray(images) || images.length === 0) return null;
  const a = images[0];
  if (typeof a === "string") return a;
  if (a && typeof a === "object" && typeof (a as { url?: unknown }).url === "string") {
    return (a as { url: string }).url;
  }
  return null;
}

function minPrice(variants: Variant[]): { cents: number; currency: string } | null {
  if (!variants || variants.length === 0) return null;
  let best = variants[0];
  for (const v of variants) if (v.price_cents < best.price_cents) best = v;
  return { cents: best.price_cents, currency: best.currency || "usd" };
}

const hasProducts = products.length > 0;

// Fallback funnel content (preserved from the original shop page).
const food = [
  { k: "The chaos menu", d: "The truck's rotating drop — preview the concept, order when we're live.", tag: "phase 1" },
  { k: "Pre-orders", d: "Reserve a plate from the first service. Opens with the truck.", tag: "soon" },
];
const merch = [
  { k: "Tees", d: "The mark, the colors, the build.", tag: "dropping soon" },
  { k: "Caps", d: "Low-key, on-brand, sharp.", tag: "dropping soon" },
  { k: "Stickers", d: "Slap the chevron everywhere.", tag: "dropping soon" },
];
const playbooks = [
  { k: "The Atomise Machine", d: "Film once, publish six. The repurposing system that feeds every surface." },
  { k: "Own The List", d: "Build the audience the algorithm can't throttle." },
  { k: "Sell Without Sleaze", d: "Offers that convert because they're true, not pushy." },
  { k: "Buy Back Your Time", d: "The delegation + systems stack that returns your hours." },
];
---
<Base title="Shop — SlicedLabs" description="Food, merch, and the playbooks. Most of it's coming — here's what, and how to be first.">
  <section class="wrap" style="padding-block:clamp(2.5rem,7vw,4rem);">
    <p class="mono" data-reveal>everything we make</p>
    <h1 data-reveal style="--i:1; font-size:clamp(2.4rem,8vw,4.6rem);"><span class="blend-text">Shop</span></h1>
    <hr class="blade" data-reveal style="--i:2; max-width:14rem; margin:1.4rem 0 0;" />
    <p data-reveal style="--i:3; font-size:clamp(1.1rem,2.4vw,1.4rem); color:var(--muted); max-width:46rem; margin-top:1.4rem;">
      The food, the merch, and the playbooks we run. Most of it isn't live yet — that's the honest part. Here's what's coming, and how to be first in line.
    </p>
  </section>

  {hasProducts ? (
    <section class="wrap" aria-labelledby="store" style="padding-block:clamp(2rem,6vw,3.5rem);">
      <div data-reveal style="display:flex; align-items:baseline; gap:.8rem; margin-bottom:1.2rem; flex-wrap:wrap;">
        <h2 id="store" style="font-size:clamp(1.4rem,4vw,2rem); margin:0;">In stock</h2>
        <span class="tag">order now</span>
      </div>
      <div class="bento">
        {products.map((p, i) => {
          const img = firstImage(p.images);
          const mp = minPrice(p.variants);
          return (
            <a
              class="glass island col-3"
              href={`/shop/${p.slug}`}
              data-reveal
              style={`--i:${i}; display:flex; flex-direction:column; gap:.75rem; text-decoration:none; color:inherit;`}
            >
              <div style="aspect-ratio:4/3; border-radius:var(--radius); overflow:hidden; background:var(--panel); border:1px solid var(--stroke);">
                {img ? (
                  <img
                    src={img}
                    alt={p.title}
                    loading="lazy"
                    style="width:100%; height:100%; object-fit:cover; display:block;"
                  />
                ) : (
                  <span class="mono" style="display:grid; place-items:center; width:100%; height:100%; color:var(--muted);">SlicedLabs</span>
                )}
              </div>
              <span class="tag">{FULFILL_LABEL[p.fulfillment_type]}</span>
              <h3 style="font-size:1.3rem; margin:0;"><span class="blend-text">{p.title}</span></h3>
              {mp && (
                <p class="mono" style="margin:0; color:var(--muted);">from {formatMoney(mp.cents, mp.currency)}</p>
              )}
            </a>
          );
        })}
      </div>
      <div class="wrap" style="padding-inline:0;"><Newsletter /></div>
    </section>
  ) : (
    <>
      <section class="wrap" aria-labelledby="food" style="padding-block:1.5rem;">
        <div data-reveal style="display:flex; align-items:baseline; gap:.8rem; margin-bottom:1rem; flex-wrap:wrap;">
          <h2 id="food" style="font-size:clamp(1.4rem,4vw,2rem); margin:0;">Food</h2>
          <span class="tag">from the truck</span>
        </div>
        <div class="bento">
          {food.map((f, i) => (
            <article class="glass island col-3" data-reveal style={`--i:${i}`}>
              <span class="tag">{f.tag}</span>
              <h3 style="font-size:1.3rem; margin:.6rem 0 .3rem;"><span class="blend-text">{f.k}</span></h3>
              <p style="color:var(--muted); margin:0;">{f.d}</p>
            </article>
          ))}
        </div>
        <div data-reveal style="max-width:30rem; margin:1.4rem auto 0;"><LeadForm source="food-preorder" anchor="food" cta="Notify me when food drops →" /></div>
      </section>

      <section class="wrap" aria-labelledby="merch" style="padding-block:1.5rem;">
        <div data-reveal style="display:flex; align-items:baseline; gap:.8rem; margin-bottom:1rem; flex-wrap:wrap;">
          <h2 id="merch" style="font-size:clamp(1.4rem,4vw,2rem); margin:0;">Merch</h2>
          <span class="tag">wear the build</span>
        </div>
        <div class="bento">
          {merch.map((m, i) => (
            <article class="glass island col-2" data-reveal style={`--i:${i}`}>
              <span class="tag">{m.tag}</span>
              <h3 style="font-size:1.25rem; margin:.6rem 0 .3rem;">{m.k}</h3>
              <p style="color:var(--muted); margin:0;">{m.d}</p>
            </article>
          ))}
        </div>
        <div data-reveal style="max-width:30rem; margin:1.4rem auto 0;"><LeadForm source="merch-waitlist" anchor="merch" cta="Join the merch waitlist →" /></div>
      </section>

      <section class="wrap" aria-labelledby="play" style="padding-block:1.5rem;">
        <div data-reveal style="display:flex; align-items:baseline; gap:.8rem; margin-bottom:.3rem; flex-wrap:wrap;">
          <h2 id="play" style="font-size:clamp(1.4rem,4vw,2rem); margin:0;">The Playbooks</h2>
          <span class="tag">coming</span>
        </div>
        <p data-reveal style="color:var(--muted); max-width:42rem; margin:0 0 1.4rem;">The systems we run the business on — packaged once they've earned it on camera. Not theory; the actual machine.</p>
        <div class="bento">
          {playbooks.map((p, i) => (
            <article class="glass island col-3" data-reveal style={`--i:${i}`}>
              <h3 style="font-size:1.2rem; margin:0 0 .3rem;"><span class="blend-text">{p.k}</span></h3>
              <p style="color:var(--muted); margin:0;">{p.d}</p>
            </article>
          ))}
        </div>
        <div data-reveal style="max-width:30rem; margin:1.4rem auto 0;"><LeadForm source="playbooks-waitlist" anchor="play" cta="Get the playbooks first →" /></div>
      </section>

      <div class="wrap"><Newsletter /></div>
    </>
  )}
</Base>
