---
// SlicedLabs · studio · © 2026 SlicedLabs — a single recipe (editorial long-form)
// The blog showcase: the inspiration, the technique, the source, and the build —
// laid out, in public. Server-rendered from `recipes` (RLS: public read of
// published rows). Voice: confident, plain, receipts-first.
export const prerender = false;
import Base from "../../layouts/Base.astro";
import { getClerkSupabase } from "../../lib/supabase";

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/recipes");

const supabase = getClerkSupabase(Astro.locals);
const { data: row } = await supabase
  .from("recipes")
  .select("slug,title,sl_code,kicker,summary,story,ingredients,steps,dietary,season,section,hero_image")
  .eq("status", "published")
  .eq("slug", slug)
  .maybeSingle();

type Ingredient = { group?: string; item: string; amount?: string };
type Recipe = {
  slug: string;
  title: string;
  sl_code: string | null;
  kicker: string | null;
  summary: string | null;
  story: string | null;
  ingredients: Ingredient[] | null;
  steps: string[] | null;
  dietary: string[] | null;
  season: string | null;
  section: "anchor" | "drop" | "dough" | "sweet";
  hero_image: string | null;
};

const recipe = (row ?? null) as unknown as Recipe | null;

// member "save" state — is this recipe already in the signed-in user's saved list?
const { userId } = Astro.locals.auth();
let isSaved = false;
if (userId && recipe) {
  const { data: sv } = await supabase
    .from("saved_recipes")
    .select("recipe_slug")
    .eq("recipe_slug", recipe.slug)
    .maybeSingle();
  isSaved = Boolean(sv);
}

// Dietary legend — code → label. Anything unknown falls through as-is.
const DIET_LABEL: Record<string, string> = {
  gf: "GF",
  "gf-avail": "GF✓",
  v: "V",
  vg: "VG",
  "vg-avail": "VG✓",
};
const dietLabel = (code: string): string => DIET_LABEL[code] ?? code.toUpperCase();

const SECTION_LABEL: Record<string, string> = {
  anchor: "anchor",
  drop: "seasonal drop",
  dough: "dough lab",
  sweet: "sweet",
};

if (!recipe) {
  Astro.response.status = 404;
}

// ── derive (only when we have a recipe) ──────────────────────────────────────
const story = recipe?.story ?? "";
const paragraphs = story.split(/\n\n+/).map((p) => p.trim()).filter(Boolean);

const ingredients: Ingredient[] = Array.isArray(recipe?.ingredients) ? recipe!.ingredients : [];
const steps: string[] = Array.isArray(recipe?.steps) ? recipe!.steps : [];
const diet: string[] = Array.isArray(recipe?.dietary) ? recipe!.dietary : [];

// group ingredients only if any line declares a `group`
const hasGroups = ingredients.some((g) => g && typeof g.group === "string" && g.group.trim());
const ingredientGroups: Array<{ group: string; items: Ingredient[] }> = [];
if (hasGroups) {
  const map = new Map<string, Ingredient[]>();
  const order: string[] = [];
  for (const ing of ingredients) {
    const key = (ing.group ?? "").trim() || "—";
    if (!map.has(key)) { map.set(key, []); order.push(key); }
    map.get(key)!.push(ing);
  }
  for (const key of order) ingredientGroups.push({ group: key, items: map.get(key)! });
}

const pageTitle = recipe ? `${recipe.title} — Recipes — SlicedLabs` : "Recipe not found — SlicedLabs";
const pageDesc = recipe?.summary ?? "The inspiration behind the food — the technique, the source, and the story.";

// schema.org/Recipe — rich results in search (recipe cards are big organic traffic for food).
const recipeLd = recipe
  ? {
      "@context": "https://schema.org",
      "@type": "Recipe",
      name: recipe.title,
      ...(recipe.summary ? { description: recipe.summary } : {}),
      ...(recipe.hero_image ? { image: [recipe.hero_image] } : {}),
      author: { "@type": "Organization", name: "SlicedLabs" },
      recipeCategory: SECTION_LABEL[recipe.section] ?? recipe.section,
      ...(recipe.season ? { recipeCuisine: recipe.season } : {}),
      ...(ingredients.length
        ? { recipeIngredient: ingredients.map((i) => [i.amount, i.item].filter(Boolean).join(" ").trim()) }
        : {}),
      ...(steps.length
        ? { recipeInstructions: steps.map((st, i) => ({ "@type": "HowToStep", position: i + 1, text: st })) }
        : {}),
    }
  : undefined;
---
<Base title={pageTitle} description={pageDesc} noindex={!recipe} jsonLd={recipeLd} ogImage="/og/recipes.png">
  {recipe ? (
    <article>
      {/* ── HEADER ──────────────────────────────────────────────────────── */}
      <section class="wrap" style="max-width:52rem; padding-block:clamp(2.5rem,7vw,4rem) clamp(1rem,3vw,1.6rem);">
        <a href="/recipes" class="mono" style="text-decoration:none;">← Recipes</a>

        <div data-reveal style="display:flex; gap:.4rem; flex-wrap:wrap; margin-top:1.2rem;">
          {recipe.sl_code && <span class="tag">{recipe.sl_code}</span>}
          <span class="tag">{SECTION_LABEL[recipe.section] ?? recipe.section}</span>
        </div>

        {recipe.kicker && <p class="mono" data-reveal style="--i:1; margin:1rem 0 0;">{recipe.kicker}</p>}
        <h1 data-reveal style={`--i:2; font-size:clamp(2rem,7vw,3.8rem); margin:.3rem 0 0; view-transition-name:vtr-${recipe.slug};`}><span class="blend-text">{recipe.title}</span></h1>
        {recipe.summary && (
          <p data-reveal style="--i:3; font-size:clamp(1.15rem,2.6vw,1.5rem); color:var(--muted); max-width:44rem; margin-top:1.2rem; line-height:1.5;">{recipe.summary}</p>
        )}

        {(diet.length > 0 || recipe.season) && (
          <div data-reveal style="--i:4; display:flex; gap:.4rem; flex-wrap:wrap; margin-top:1.2rem;">
            {recipe.season && <span class="tag">{recipe.season}</span>}
            {diet.map((d) => <span class="tag">{dietLabel(d)}</span>)}
          </div>
        )}

        <hr class="blade" data-reveal style="--i:5; max-width:11rem; margin:1.6rem 0 0;" />
      </section>

      {/* ── HERO (only when a real image is set) ────────────────────────── */}
      {recipe.hero_image && (
        <section class="wrap" style="padding-block:clamp(1rem,3vw,1.8rem) 0; max-width:60rem;">
          <div class="detail-hero" data-reveal>
            <img src={recipe.hero_image} alt={recipe.title} width="1200" height="600" loading="eager" />
          </div>
        </section>
      )}

      {/* ── STORY (the inspiration) ─────────────────────────────────────── */}
      {paragraphs.length > 0 && (
        <section class="wrap" style="max-width:46rem; padding-block:clamp(1.5rem,4vw,2.5rem);">
          <div class="prose" data-reveal>
            {paragraphs.map((p) => <p>{p}</p>)}
          </div>
        </section>
      )}

      {/* ── INGREDIENTS + BUILD (2-col, stacks on mobile) ───────────────── */}
      {(ingredients.length > 0 || steps.length > 0) && (
        <section class="wrap" style="padding-block:clamp(1.5rem,4vw,2.5rem);">
          <div class="recipe-cols">
            {ingredients.length > 0 && (
              <div class="glass island" data-reveal>
                <h2 style="font-size:1.4rem; margin:0 0 1rem;">Ingredients</h2>
                {hasGroups ? (
                  ingredientGroups.map((grp) => (
                    <div style="margin-bottom:1.1rem;">
                      <p class="mono" style="margin:0 0 .5rem; color:var(--muted);">{grp.group}</p>
                      <ul class="ing-list">
                        {grp.items.map((ing) => (
                          <li class="ing-row">
                            <span class="ing-item">{ing.item}</span>
                            {ing.amount && <span class="ing-amt mono">{ing.amount}</span>}
                          </li>
                        ))}
                      </ul>
                    </div>
                  ))
                ) : (
                  <ul class="ing-list">
                    {ingredients.map((ing) => (
                      <li class="ing-row">
                        <span class="ing-item">{ing.item}</span>
                        {ing.amount && <span class="ing-amt mono">{ing.amount}</span>}
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            )}

            {steps.length > 0 && (
              <div class="glass island" data-reveal style="--i:1;">
                <h2 style="font-size:1.4rem; margin:0 0 1rem;">The build</h2>
                <ol class="step-list">
                  {steps.map((s) => <li class="step-row">{s}</li>)}
                </ol>
              </div>
            )}
          </div>
        </section>
      )}

      {/* ── CTAs ────────────────────────────────────────────────────────── */}
      <section class="wrap" style="padding-block:clamp(1.5rem,5vw,3rem);">
        <div data-reveal style="display:flex; gap:.8rem; flex-wrap:wrap; align-items:center;">
          <a class="btn" href="/menu">See it on the menu →</a>
          <a class="btn btn-ghost" href="/truck">Where to find the truck →</a>
          <form method="POST" action="/api/recipe" style="margin:0;">
            <input type="hidden" name="slug" value={recipe.slug} />
            <input type="hidden" name="action" value={isSaved ? "unsave" : "save"} />
            <button class="btn btn-ghost" type="submit" aria-pressed={isSaved ? "true" : "false"}>
              {isSaved ? "★ Saved" : "☆ Save recipe"}
            </button>
          </form>
        </div>
      </section>
    </article>
  ) : (
    <section class="wrap" style="padding-block:clamp(3rem,8vw,5rem); max-width:40rem;">
      <p class="mono" data-reveal>404 · off the board</p>
      <h1 data-reveal style="--i:1; font-size:clamp(1.8rem,6vw,3rem); margin:.3rem 0 0;"><span class="blend-text">Recipe not found</span></h1>
      <p data-reveal style="--i:2; color:var(--muted); margin-top:1rem;">That one isn't on the board — it may have been a seasonal drop, or the link's off.</p>
      <div data-reveal style="--i:3; margin-top:1.4rem;">
        <a class="btn" href="/recipes">← Back to Recipes</a>
      </div>
    </section>
  )}
</Base>

<style>
  /* hero banner — only rendered when a real image is set */
  .detail-hero {
    border-radius: var(--radius); overflow: hidden; aspect-ratio: 2 / 1;
    border: 1px solid var(--stroke);
  }
  .detail-hero img { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* the editorial 2-col — ingredients beside the build, stacks on mobile */
  .recipe-cols {
    display: grid; gap: 1rem;
    grid-template-columns: 1fr;
    align-items: start;
  }
  @media (min-width: 760px) {
    .recipe-cols { grid-template-columns: 1fr 1.25fr; }
  }

  /* ingredients */
  .ing-list { list-style: none; padding: 0; margin: 0; }
  .ing-row {
    display: flex; align-items: baseline; justify-content: space-between; gap: 1rem;
    padding: .55rem 0;
    border-bottom: 1px solid color-mix(in oklab, var(--stroke) 70%, transparent);
  }
  .ing-row:last-child { border-bottom: 0; }
  .ing-item { color: var(--ink); }
  .ing-amt { color: var(--muted); white-space: nowrap; text-align: right; flex: none; }

  /* the build — numbered steps with spectrum markers */
  .step-list {
    list-style: none; counter-reset: step; padding: 0; margin: 0;
    display: grid; gap: 1rem;
  }
  .step-row {
    counter-increment: step;
    position: relative; padding-left: 2.6rem;
    line-height: 1.65; color: color-mix(in oklab, var(--ink) 92%, var(--muted));
  }
  .step-row::before {
    content: counter(step);
    position: absolute; left: 0; top: -.05em;
    width: 1.85rem; height: 1.85rem;
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: 999px;
    font-family: var(--font-mono); font-size: .82rem; font-weight: 600;
    color: #0B0B0F; background: var(--blend);
    box-shadow: 0 0 18px color-mix(in oklab, var(--teal) 22%, transparent);
  }
</style>
