---
// SlicedLabs · studio · © 2026 SlicedLabs — a lead-magnet drop
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import LeadForm from "../../components/LeadForm.astro";

export async function getStaticPaths() {
  const magnets = await getCollection("magnets");
  return magnets.map((m) => ({ params: { slug: m.id }, props: { m } }));
}

const { m } = Astro.props;
const { Content } = await render(m);
---
<Base title={`${m.data.title} — SlicedLabs`} description={m.data.summary}>
  <article class="wrap section" style="max-width:46rem;">
    <a href="/free" class="mono" style="text-decoration:none;">← free drops</a>
    <hr class="blade" data-reveal style="max-width:8rem; margin:1.2rem 0 2rem;" />
    <div class="prose"><Content /></div>
    <div style="margin-top:2.4rem;">
      <article class="glass glass-focal island" style="text-align:center;">
        <p class="mono">get all three + the weekly receipts</p>
        <h2 style="font-size:1.4rem; margin:.3rem 0 .8rem;">Own your slice.</h2>
        <LeadForm source="vault" anchor="more" cta="Send me the drops →" />
      </article>
    </div>
  </article>
</Base>
