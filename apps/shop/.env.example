# SlicedLabs storefront (apps/shop) — copy to .env and fill with real values.
# .env is gitignored; only this example is committed. The build SUCCEEDS with
# these placeholders (Storefront queries degrade to empty states at runtime).

# Signs the session cookie. Generate a real one: `openssl rand -base64 32`
SESSION_SECRET="REPLACE_WITH_openssl_rand_base64_32"

# The store. Free .myshopify.com domain for now.
PUBLIC_STORE_DOMAIN="slicedlabs.myshopify.com"

# Storefront API access. Get the public token + ID from the Hydrogen/Headless
# channel in Shopify admin. PLACEHOLDER below → queries fail gracefully.
PUBLIC_STOREFRONT_API_TOKEN="placeholder-storefront-api-token"
PUBLIC_STOREFRONT_ID="placeholder-storefront-id"
PUBLIC_STOREFRONT_API_VERSION="2026-04"

# Optional — private (server-only, delegated-access) Storefront token.
# PRIVATE_STOREFRONT_API_TOKEN=""

# Optional — Customer Account API (login/account). Leave unset for the shell.
# PUBLIC_CUSTOMER_ACCOUNT_API_CLIENT_ID=""
# PUBLIC_CUSTOMER_ACCOUNT_API_URL=""
# PUBLIC_CHECKOUT_DOMAIN=""
