---
// SlicedLabs · studio · © 2026 SlicedLabs — Watch (YouTube hub)
import Base from "../layouts/Base.astro";
const pillars = [
  ["the build", "Every rung climbed in public — the truck, the lot, the first sale."],
  ["the food", "The chaos-menu drops, the cooks, the sourcing."],
  ["the local", "The farms and breweries behind the food."],
  ["the philosophy", "Own your slice — the principles, lived."],
  ["behind-the-scenes", "The systems, the failures, the real days."],
];
---
<Base title="Watch — SlicedLabs" description="YouTube is home base. The build documentary, by pillar.">
  <section class="wrap" style="padding-block:clamp(2.5rem,7vw,4rem);">
    <p class="mono" data-reveal>home base</p>
    <h1 data-reveal style="--i:1; font-size:clamp(2.2rem,7vw,4rem); margin:.3rem 0 0;"><span class="blend-text">Watch the build</span></h1>
    <hr class="blade" data-reveal style="--i:2; max-width:22rem; margin:1.4rem 0 0;" />
    <p data-reveal style="--i:3; color:var(--muted); max-width:42rem; margin-top:1.4rem;">
      YouTube is where the journey accumulates — searchable, evergreen, receipts and all.
      The channel launches with Episode 0. Subscribe to catch the climb from the start.
    </p>
    <div data-reveal style="--i:4; margin:1.6rem 0 2.6rem;"><a class="btn" href="https://www.youtube.com/channel/UCodcvZ6u4N4PACwxYaM8sTw">Subscribe on YouTube →</a></div>

    <h2 class="mono" data-reveal style="color:var(--muted); margin-bottom:1rem;">the five pillars</h2>
    <div class="bento">
      {pillars.map(([k, d], i) => (
        <article class="glass island col-2" data-reveal style={`--i:${i}`}>
          <h3 style="font-size:1.3rem; margin:0 0 .3rem;"><span class="blend-text">{k}</span></h3>
          <p style="color:var(--muted); margin:0;">{d}</p>
        </article>
      ))}
    </div>
  </section>
</Base>
