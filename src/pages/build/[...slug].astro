---
// SlicedLabs · studio · © 2026 SlicedLabs — a single build entry
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";

export async function getStaticPaths() {
  const posts = await getCollection("build");
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<Base title={`${post.data.title} — SlicedLabs`} description={post.data.summary}>
  <article class="wrap" style="max-width:46rem; padding-block:3rem;">
    <a href="/build" class="mono" style="text-decoration:none;">← the build</a>
    <p class="mono" style="margin-top:1.2rem;">{post.data.date.toISOString().slice(0, 10)}</p>
    <h1 style="font-size:clamp(2rem,6vw,3.4rem); margin:.3rem 0 1.4rem;">{post.data.title}</h1>
    <hr class="spectrum-rule" style="max-width:8rem; margin:0 0 2rem;" />
    <div style="line-height:1.8;"><Content /></div>
  </article>
</Base>
