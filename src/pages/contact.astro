---
// SlicedLabs · studio · © 2026 SlicedLabs — Get in touch
import Base from "../layouts/Base.astro";
import ContactForm from "../components/ContactForm.astro";
---
<Base title="Get in touch — SlicedLabs" description="Catering, press, partnerships, or just a hello. Reach the SlicedLabs team.">
  <section class="wrap" style="max-width:42rem; padding-block:clamp(2.5rem,7vw,4rem);">
    <p class="mono" data-reveal>get in touch</p>
    <h1 data-reveal style="--i:1; font-size:clamp(2.2rem,7vw,4rem);"><span class="spectrum-text">Say hello.</span></h1>
    <hr class="blade" data-reveal style="--i:2; max-width:12rem; margin:1.3rem 0 0;" />
    <p data-reveal style="--i:3; color:var(--muted); margin-top:1.4rem;">
      Catering, press, partnerships, brewery + market collabs, or just a hello. We read everything — and the build-in-public crowd gets a reply.
    </p>
    <article class="glass glass-focal island" data-reveal style="margin-top:1.8rem;">
      <ContactForm />
    </article>
  </section>
</Base>
