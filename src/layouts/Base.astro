---
// SlicedLabs · studio · © 2026 SlicedLabs
import "../styles/global.css";
import Analytics from "@vercel/analytics/astro";
import { MARK_PATH, OG_PATH } from "../lib/brand";
interface Props { title?: string; description?: string; temp?: "dark" | "warm"; }
const {
  title = "SlicedLabs — own your slice",
  description = "A food · media · marketing company building a real food empire in public. We don't pitch. We prove.",
  temp = "dark",
} = Astro.props;
const ogUrl = Astro.site ? new URL(OG_PATH, Astro.site).href : OG_PATH;
const nav = [
  { href: "/", label: "Home" },
  { href: "/build", label: "The Build" },
  { href: "/watch", label: "Watch" },
  { href: "/about", label: "Manifesto" },
];
---
<!doctype html>
<html lang="en" data-temp={temp}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogUrl} />
    <meta name="theme-color" content="#1A1A1A" />
    {/* SlicedLabs favicon & icon pack — operator-provided handoff (public/) */}
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@300..800&family=Inter:wght@400..700&family=JetBrains+Mono:wght@400..600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <a href="#main" class="skip">Skip to content</a>
    <header class="wrap" style="display:flex; align-items:center; justify-content:space-between; padding-block:1.1rem; position:sticky; top:0; z-index:10; background:color-mix(in oklab, var(--bg) 68%, transparent); backdrop-filter:blur(14px) saturate(1.3); -webkit-backdrop-filter:blur(14px) saturate(1.3); border-bottom:1px solid var(--stroke);">
      <a href="/" style="display:flex; align-items:center; gap:.55rem; text-decoration:none;">
        <img src={MARK_PATH} alt="" width="26" height="26" style="display:block;" />
        <span style="font-family:var(--font-display); font-weight:800; letter-spacing:-.02em; font-size:1.2rem;">SlicedLabs</span>
      </a>
      <nav style="display:flex; align-items:center; gap:1.1rem;">
        {nav.map((n) => <a href={n.href} style="text-decoration:none; color:var(--muted); font-size:.95rem;">{n.label}</a>)}
        <button id="temp" class="tag" aria-label="Toggle warm/dark theme" title="warm ↔ dark" style="cursor:pointer;">◑</button>
      </nav>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="wrap" style="border-top:1px solid var(--stroke); margin-top:4rem; padding-block:2rem; color:var(--muted); display:flex; gap:1rem; flex-wrap:wrap; justify-content:space-between; align-items:center;">
      <span class="mono">own your slice · build it in public · show the math</span>
      <span class="mono">© 2026 SlicedLabs</span>
    </footer>

    <Analytics />

    <script is:inline>
      // dark ↔ warm temperature (the two-temperature system). Persists; respects no-shimmer.
      const root = document.documentElement;
      const saved = localStorage.getItem("sl-temp");
      if (saved) root.setAttribute("data-temp", saved);
      document.getElementById("temp")?.addEventListener("click", () => {
        const next = root.getAttribute("data-temp") === "warm" ? "dark" : "warm";
        root.setAttribute("data-temp", next);
        localStorage.setItem("sl-temp", next);
      });
    </script>

    <script is:inline>
      // Entrance choreography — plays ONCE per element, reduced-motion gated.
      // Drives [data-reveal] fades, the .blade slice, and [data-count-to] count-ups.
      (function () {
        var reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
        var targets = document.querySelectorAll("[data-reveal], .blade, [data-count-to]");
        function fmt(el, v) {
          var dp = +(el.getAttribute("data-count-decimals") || 0);
          var pre = el.getAttribute("data-count-prefix") || "";
          var suf = el.getAttribute("data-count-suffix") || "";
          return pre + v.toLocaleString("en-US", { minimumFractionDigits: dp, maximumFractionDigits: dp }) + suf;
        }
        function run(el) {
          var to = +el.getAttribute("data-count-to");
          var dur = +(el.getAttribute("data-count-dur") || 1500);
          var t0 = null;
          (function step(ts) {
            if (!t0) t0 = ts;
            var p = Math.min((ts - t0) / dur, 1);
            var e = 1 - Math.pow(1 - p, 3); // easeOutCubic
            el.textContent = fmt(el, to * e);
            if (p < 1) requestAnimationFrame(step); else el.textContent = fmt(el, to);
          })(performance.now());
        }
        if (reduce) {
          targets.forEach(function (el) {
            el.classList.add("is-in");
            if (el.hasAttribute("data-count-to")) el.textContent = fmt(el, +el.getAttribute("data-count-to"));
          });
          return;
        }
        // pre-zero the counters so the count-up reads from 0 → target
        targets.forEach(function (el) { if (el.hasAttribute("data-count-to")) el.textContent = fmt(el, 0); });
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (en) {
            if (!en.isIntersecting) return;
            en.target.classList.add("is-in");
            if (en.target.hasAttribute("data-count-to")) run(en.target);
            io.unobserve(en.target);
          });
        }, { threshold: 0.2, rootMargin: "0px 0px -8% 0px" });
        targets.forEach(function (el) { io.observe(el); });
      })();
    </script>
  </body>
</html>
