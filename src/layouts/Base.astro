---
// SlicedLabs · studio · © 2026 SlicedLabs
import "../styles/global.css";
import Analytics from "@vercel/analytics/astro";
import { MARK_PATH, OG_PATH } from "../lib/brand";
interface Props { title?: string; description?: string; temp?: "dark" | "warm"; }
const {
  title = "SlicedLabs — own your slice",
  description = "A food · media · marketing company building a real food empire in public. We don't pitch. We prove.",
  temp = "dark",
} = Astro.props;
const ogUrl = Astro.site ? new URL(OG_PATH, Astro.site).href : OG_PATH;
const path = (Astro.url.pathname.replace(/\/+$/, "") || "/");
const ic = {
  home: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 10.6 12 3l9 7.6"/><path d="M5.5 9.4V20h13V9.4"/><path d="M9.5 20v-5.5h5V20"/></svg>`,
  build: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3.5" y="3.5" width="7" height="7" rx="1.6"/><rect x="13.5" y="3.5" width="7" height="7" rx="1.6"/><rect x="3.5" y="13.5" width="7" height="7" rx="1.6"/><rect x="13.5" y="13.5" width="7" height="7" rx="1.6"/></svg>`,
  watch: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M10 8.5v7l6-3.5-6-3.5Z"/></svg>`,
  manifesto: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 4.5A1.5 1.5 0 0 1 6.5 3H19v15H6.5A1.5 1.5 0 0 0 5 19.5V4.5Z"/><path d="M19 18v3H6.5A1.5 1.5 0 0 1 5 19.5"/></svg>`,
  sun: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2.5v2.2M12 19.3v2.2M4.4 4.4 6 6M18 18l1.6 1.6M2.5 12h2.2M19.3 12h2.2M4.4 19.6 6 18M18 6l1.6-1.6"/></svg>`,
  moon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20.5 13.5A8 8 0 1 1 10.5 3.5a6.3 6.3 0 0 0 10 10Z"/></svg>`,
};
const nav = [
  { href: "/", label: "Home", hue: "#38B6FF", icon: ic.home },
  { href: "/build", label: "The Build", hue: "#CB6820", icon: ic.build },
  { href: "/watch", label: "Watch", hue: "#D9583C", icon: ic.watch },
  { href: "/about", label: "Manifesto", hue: "#2F9B80", icon: ic.manifesto },
];
const isActive = (href: string) => (href === "/" ? path === "/" : path === href || path.startsWith(href + "/"));
---
<!doctype html>
<html lang="en" data-temp={temp}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogUrl} />
    <meta name="theme-color" content="#1A1A1A" />
    {/* SlicedLabs favicon & icon pack — operator-provided handoff (public/) */}
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@300..800&family=Inter:wght@400..700&family=JetBrains+Mono:wght@400..600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <a href="#main" class="skip">Skip to content</a>
    <header class="pillbar-wrap">
      <div class="pillbar" data-pillbar>
        <a href="/" class="pb-brand" aria-label="SlicedLabs — home">
          <img src={MARK_PATH} alt="" width="24" height="24" />
          <span class="pb-word">SlicedLabs</span>
        </a>
        <span class="pb-sep"></span>
        <nav class="pb-nav" data-magnify aria-label="Primary">
          {nav.map((n) => (
            <a href={n.href} class:list={["pb-chip", isActive(n.href) && "is-active"]} style={`--hue:${n.hue}`} aria-current={isActive(n.href) ? "page" : undefined}>
              <span class="pb-ico" set:html={n.icon}></span>
              <span class="pb-label">{n.label}</span>
            </a>
          ))}
        </nav>
        <span class="pb-sep"></span>
        <button id="temp" class="pb-chip pb-toggle" aria-label="Toggle light and dark" title="light ↔ dark">
          <span class="pb-ico" data-ico-moon set:html={ic.moon}></span>
          <span class="pb-ico" data-ico-sun set:html={ic.sun}></span>
        </button>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="wrap" style="border-top:1px solid var(--stroke); margin-top:4rem; padding-block:2rem; color:var(--muted); display:flex; gap:1rem; flex-wrap:wrap; justify-content:space-between; align-items:center;">
      <span class="mono">own your slice · build it in public · show the math</span>
      <span class="mono">© 2026 SlicedLabs</span>
    </footer>

    <Analytics />

    <script is:inline>
      // dark ↔ warm temperature (the two-temperature system). Persists; respects no-shimmer.
      const root = document.documentElement;
      const saved = localStorage.getItem("sl-temp");
      if (saved) root.setAttribute("data-temp", saved);
      document.getElementById("temp")?.addEventListener("click", () => {
        const next = root.getAttribute("data-temp") === "warm" ? "dark" : "warm";
        root.setAttribute("data-temp", next);
        localStorage.setItem("sl-temp", next);
      });
    </script>

    <script is:inline>
      // Dock-style magnification on the pill nav (web flourish over the cockpit chips).
      (function () {
        var nav = document.querySelector("[data-magnify]");
        if (!nav) return;
        if (!matchMedia("(hover:hover) and (pointer:fine)").matches) return;
        if (matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        var chips = Array.prototype.slice.call(nav.querySelectorAll(".pb-chip"));
        var AMP = 0.42, SPREAD = 76;
        nav.addEventListener("pointermove", function (e) {
          for (var i = 0; i < chips.length; i++) {
            var r = chips[i].getBoundingClientRect();
            var d = e.clientX - (r.left + r.width / 2);
            chips[i].style.setProperty("--mag", (1 + AMP * Math.exp(-(d * d) / (2 * SPREAD * SPREAD))).toFixed(3));
          }
        });
        nav.addEventListener("pointerleave", function () {
          for (var i = 0; i < chips.length; i++) chips[i].style.setProperty("--mag", "1");
        });
      })();
    </script>

    <script is:inline>
      // Entrance choreography — plays ONCE per element, reduced-motion gated.
      // Drives [data-reveal] fades, the .blade slice, and [data-count-to] count-ups.
      (function () {
        var reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
        var targets = document.querySelectorAll("[data-reveal], .blade, [data-count-to]");
        function fmt(el, v) {
          var dp = +(el.getAttribute("data-count-decimals") || 0);
          var pre = el.getAttribute("data-count-prefix") || "";
          var suf = el.getAttribute("data-count-suffix") || "";
          return pre + v.toLocaleString("en-US", { minimumFractionDigits: dp, maximumFractionDigits: dp }) + suf;
        }
        function run(el) {
          var to = +el.getAttribute("data-count-to");
          var dur = +(el.getAttribute("data-count-dur") || 1500);
          var t0 = null;
          (function step(ts) {
            if (!t0) t0 = ts;
            var p = Math.min((ts - t0) / dur, 1);
            var e = 1 - Math.pow(1 - p, 3); // easeOutCubic
            el.textContent = fmt(el, to * e);
            if (p < 1) requestAnimationFrame(step); else el.textContent = fmt(el, to);
          })(performance.now());
        }
        if (reduce) {
          targets.forEach(function (el) {
            el.classList.add("is-in");
            if (el.hasAttribute("data-count-to")) el.textContent = fmt(el, +el.getAttribute("data-count-to"));
          });
          return;
        }
        // pre-zero the counters so the count-up reads from 0 → target
        targets.forEach(function (el) { if (el.hasAttribute("data-count-to")) el.textContent = fmt(el, 0); });
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (en) {
            if (!en.isIntersecting) return;
            en.target.classList.add("is-in");
            if (en.target.hasAttribute("data-count-to")) run(en.target);
            io.unobserve(en.target);
          });
        }, { threshold: 0.2, rootMargin: "0px 0px -8% 0px" });
        targets.forEach(function (el) { io.observe(el); });
      })();
    </script>
  </body>
</html>
