{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".vercel/output/**", ".next/**", "!.next/cache/**"],
      "env": [
        "NODE_ENV",
        "SITE_URL",
        "PUBLIC_SUPABASE_URL",
        "PUBLIC_SUPABASE_ANON_KEY",
        "SUPABASE_SERVICE_ROLE_KEY",
        "SUPABASE_COOKIE_DOMAIN",
        "BEEHIIV_API_KEY",
        "BEEHIIV_PUBLICATION_ID",
        "HUBSPOT_TOKEN",
        "DISCORD_WEBHOOK_URL",
        "N8N_LEAD_WEBHOOK_URL",
        "N8N_WEBHOOK_SECRET",
        "STRIPE_SECRET_KEY",
        "PUBLIC_STRIPE_PUBLISHABLE_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "PRINTFUL_API_KEY",
        "PRINTFUL_WEBHOOK_SECRET",
        "RESEND_API_KEY",
        "ADMIN_EMAILS"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {}
  }
}
