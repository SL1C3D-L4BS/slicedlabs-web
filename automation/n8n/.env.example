# Copy to .env (gitignored) and fill in. NEVER commit real keys.
# Generate the encryption key once:  openssl rand -hex 24
N8N_ENCRYPTION_KEY=

# Public base URL — only needed when you expose n8n for inbound webhooks / the
# Claude MCP connector (a tunnel or reverse proxy). Leave default for loopback.
WEBHOOK_URL=http://localhost:5678/

# The API keys live in `pass` (sovereign) — pull them into n8n CREDENTIALS in the
# UI, not here. For reference, the pass paths are:
#   pass show sl/apollo-api-key
#   pass show sl/clay-api-key
#   HubSpot private-app token (create one) → n8n HubSpot credential
#   beehiiv:  BEEHIIV_API_KEY (already in Vercel)
